/* components/avatarNicknameModal/avatarNicknameModal.wxss */
.super-page-box {
	background-color: transparent;
	position: fixed;
	width: 100vw;
	height: 100vh;
	z-index: 103;
	animation: supermodal 200ms;
}

@keyframes supermodal{
	0% {
		transform: scaleY(0);
	}
	50% {
		transform: scaleY(0.5);
	}
	100% {
		transform: scaleY(1);
	}
}

.super-modal-box {
	position: fixed;
	z-index: 999;
	height: auto;
	width: 100vw;
	bottom: 0rpx;
	left: 0rpx;
}

.super-modal-body-box {
	background-color: #ffffff;
	border-top-left-radius: 30rpx;
	border-top-right-radius: 30rpx;
	height: auto;
	min-height: 310rpx;
	padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
	width: 100%;
	display: flex;
	flex-direction: column;
	overflow: hidden;
}

.super-modal-title {
	height: 88rpx;
	width: 100%;
	font-size: 30rpx;
	font-weight: bold;
	color: #222222;
	position: relative;
}

.auth-desc {
	padding: 12rpx 42rpx 20rpx;
	color: #8c7b68;
	font-size: 24rpx;
	line-height: 1.6;
	text-align: center;
}

.super-modal-content {
	flex: 1;
	overflow-y: auto;
	padding-bottom: 20rpx;
}

.super-avatar-box {
	width: 250rpx;
	position: relative;
	margin: auto;
	margin-top: 25rpx;
}

.avatar-btn {
	position: absolute;
	top: 0rpx;
	left: 0rpx;
	height: 100% !important;
	width: 100% !important;
	background-color: transparent;
	z-index: 99;
}

.avatar-img-box {
	background-color: #f5f5f5;
	height: 200rpx;
	width: 200rpx;
	border-radius: 20rpx;
	margin: auto;
}

.avatar-select-tips {
	font-size: 24rpx;
	color: #8a8a8a;
	margin-top: 15rpx;
}

.super-nick-name-box {
	height: 92rpx;
	padding: 0rpx 32rpx;
	margin-top: 4rpx;
	border-bottom: 1rpx solid #f0f0f0;
}

.nick-name-box {
	height: 100%;
	width: 85%;
}
.nick-name-input{
	height: 92rpx;
	flex: 1;
	font-size: 28rpx;
	color: #333333;
}

.nickname-label {
	width: 150rpx;
	font-size: 28rpx;
	color: #222222;
}

.nickname-wechat-btn {
	flex: 0 0 auto;
	margin-left: 14rpx;
	padding: 10rpx 12rpx;
	border-radius: 10rpx;
	background: #fbf3e6;
	color: #9a682d;
	font-size: 22rpx;
	line-height: 1.3;
}

.nickname-wechat-btn-hover {
	background: #f0dfc6;
}

.super-phone-box {
	height: 96rpx;
	padding: 0rpx 32rpx;
	margin-top: 0;
}

.phone-label-box {
	height: 100%;
	flex: 1;
}

.phone-display {
	font-size: 28rpx;
	color: #999;
}

.phone-btn {
	padding: 12rpx 30rpx;
	background: linear-gradient(135deg, #d6a24a 0%, #b8792f 100%);
	color: #fff7e8;
	font-size: 24rpx;
	border-radius: 14rpx;
	border: none;
	line-height: 1.5;
	width:250rpx !important;
}

.phone-btn::after {
	border: none;
}

.apply-btn {
	display: none;
	width: 450rpx;
	height: 95rpx;
	border-radius: 20rpx;
	background: linear-gradient(135deg, #e54d42 0%, #f37370 100%);
	color: #ffffff;
	font-size: 28rpx;
	font-weight: bold;
	margin: 35rpx auto 30rpx;
	flex-shrink: 0;
}

.flex-ac,
.flex-jc-ac,
.flex-jb-ac {
	display: flex;
}

.flex-jc-ac {
	justify-content: center;
}

.flex-ac,
.flex-jc-ac,
.flex-jb-ac {
	align-items: center;
}

.flex-jb-ac {
	justify-content: space-between;
}

.auth-loading-float {
	position: fixed;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	z-index: 1200;
	background: transparent;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: center;
	pointer-events: none;
}

.auth-loading-img {
	width: 230rpx;
	height: 230rpx;
}

.auth-loading-text {
	margin-top: 4rpx;
	color: #6a4527;
	font-size: 28rpx;
	font-weight: 600;
	line-height: 1.3;
}
