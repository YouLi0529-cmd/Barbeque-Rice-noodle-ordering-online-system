/* pages/outdoor/outdoor.wxss */
.outdoor-page {
  padding-bottom: 170rpx;
}

.outdoor-hero {
  margin: 0 0 26rpx;
  padding: 52rpx 30rpx 42rpx;
  color: #FFF7EC;
  border-radius: 0 0 40rpx 40rpx;
}

.hero-label {
  color: rgba(255, 247, 236, 0.58);
  font-size: 21rpx;
  font-weight: 900;
}

.hero-title {
  margin-top: 20rpx;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.12;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 247, 236, 0.82);
  font-size: 28rpx;
}

.point-tag {
  display: inline-flex;
  margin-top: 26rpx;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  color: #1E1714;
  background: #FFF2DD;
  font-size: 24rpx;
  font-weight: 800;
}

.section {
  margin: 0 24rpx 30rpx;
}

.section-head {
  margin-bottom: 18rpx;
}

.section-note {
  margin-top: 6rpx;
  color: rgba(58, 36, 24, 0.58);
  font-size: 24rpx;
}

.grill-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.grill-card {
  min-height: 112rpx;
  padding: 20rpx 14rpx;
  border-radius: 22rpx;
  background: #FFF2DD;
  border: 2rpx solid transparent;
  box-shadow: 0 10rpx 24rpx rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.grill-card.active {
  background: #1E1714;
  border-color: #F26A2E;
}

.grill-name {
  color: #1E1714;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
}

.grill-card.active .grill-name {
  color: #FFF7EC;
}

.grill-status {
  margin-top: 10rpx;
  color: #C9341C;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.grill-card.active .grill-status {
  color: #FFD8BC;
}

.menu-layout {
  height: 820rpx;
  display: flex;
  overflow: hidden;
  border-radius: 28rpx;
  background: #FFF2DD;
  box-shadow: 0 12rpx 30rpx rgba(58, 36, 24, 0.08);
}

.category-side {
  width: 166rpx;
  height: 100%;
  background: rgba(30, 23, 20, 0.05);
}

.category-item {
  min-height: 92rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  color: rgba(58, 36, 24, 0.62);
  font-size: 25rpx;
  font-weight: 800;
  border-left: 6rpx solid transparent;
  box-sizing: border-box;
}

.category-item.active {
  color: #C9341C;
  background: #FFF7EC;
  border-left-color: #F26A2E;
}

.dish-list {
  flex: 1;
  height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}

.dish-card {
  display: flex;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #FFF7EC;
}

.dish-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.dish-image.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFF7EC;
  font-size: 23rpx;
  font-weight: 800;
  text-align: center;
  background: linear-gradient(135deg, #1E1714 0%, #3A2418 100%);
}

.dish-info {
  min-width: 0;
  flex: 1;
}

.dish-name {
  color: #1E1714;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
}

.dish-desc {
  margin-top: 8rpx;
  color: rgba(58, 36, 24, 0.58);
  font-size: 23rpx;
  line-height: 1.38;
}

.dish-bottom {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.dish-price {
  color: #C9341C;
  font-size: 32rpx;
  font-weight: 900;
}

.dish-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.count-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 32rpx;
  font-weight: 900;
}

.count-btn.plus {
  color: #fff;
  background: linear-gradient(135deg, #F26A2E 0%, #C9341C 100%);
}

.count-btn.minus {
  color: #C9341C;
  background: #FFE0D2;
}

.dish-count {
  min-width: 34rpx;
  text-align: center;
  color: #1E1714;
  font-size: 27rpx;
  font-weight: 900;
}

.cart-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 28rpx;
  min-height: 106rpx;
  padding: 16rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-radius: 28rpx;
  background: #1E1714;
  box-shadow: 0 16rpx 34rpx rgba(30, 23, 20, 0.28);
  box-sizing: border-box;
  z-index: 10;
}

.cart-summary {
  min-width: 0;
  flex: 1;
}

.cart-count {
  color: rgba(255, 247, 236, 0.62);
  font-size: 23rpx;
}

.cart-price {
  margin-top: 2rpx;
  color: #FFF7EC;
  font-size: 36rpx;
  font-weight: 900;
}

.submit-btn {
  min-width: 230rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  border-radius: 999rpx;
  color: rgba(255, 247, 236, 0.55);
  background: rgba(255, 247, 236, 0.12);
  font-size: 26rpx;
  font-weight: 900;
}

.submit-btn.active {
  color: #fff;
  background: linear-gradient(135deg, #F26A2E 0%, #C9341C 100%);
}
