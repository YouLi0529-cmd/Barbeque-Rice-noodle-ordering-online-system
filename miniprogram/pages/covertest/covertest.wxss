  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.preview-loading-img {
  width: 430rpx;
  height: 430rpx;
}

.preview-loading-text {
  margin-top: 10rpx;
  color: #6f8b98;
  font-size: 26rpx;
  letter-spacing: 0;
}

.preview-cart {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  bottom: 30rpx;
  height: 110rpx;
  border-radius: 55rpx;
  background: #2d3d46;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(35, 65, 80, 0.28);
}

.preview-cart-icon {
  width: 46rpx;
  height: 46rpx;
  padding: 15rpx;
  border-radius: 50%;
  background: #ffffff;
}

.preview-cart-text {
  flex: 1;
  margin-left: 18rpx;
}

.preview-cart-title {
  width: 120rpx;
  height: 26rpx;
  border-radius: 13rpx;
}

.preview-cart-line {
  width: 220rpx;
  height: 20rpx;
  border-radius: 10rpx;
  margin-top: 10rpx;
}

.preview-cart-btn {
  width: 144rpx;
  height: 68rpx;
  border-radius: 34rpx;
  background: #74b7d8;
}

.giant-plane {
  width: 260rpx;
  height: 260rpx;
  opacity: 0;
  z-index: 1;
  transform: translate3d(-170vw, 72vh, 0) rotate(-12deg) scale(13);
}

.plane-covering .plane-screen {
  opacity: 1;
}

.plane-covering .giant-plane {
  animation: planeCover 1080ms cubic-bezier(0.42, 0, 1, 1) forwards;
}

.btn-hover {
  opacity: 0.86;
}

.contact-mask {
  position: absolute;
  inset: 0;
  z-index: 8;
  background: rgba(0, 0, 0, 0.42);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 180ms ease;
}

.contact-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.contact-dialog {
  position: relative;
  width: 560rpx;
  border-radius: 8rpx;
  background: #ffffff;
  padding: 42rpx 38rpx 38rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.22);
}

.contact-close {
  position: absolute;
  right: 18rpx;
  top: 14rpx;
  width: 56rpx;
  height: 56rpx;
  line-height: 52rpx;
  text-align: center;
  color: #7a8b95;
  font-size: 42rpx;
}

.contact-title {
  color: #253842;
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 30rpx;
}

.qr-placeholder {
  width: 360rpx;
  height: 360rpx;
  padding: 18rpx;
  margin: 0 auto;
  border-radius: 8rpx;
  border: 2rpx dashed rgba(225, 195, 157, 0.95);
  box-sizing: border-box;
}

.qr-inner {
  width: 100%;
  height: 100%;
  border-radius: 6rpx;
  background: #ebd0ab;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5f3d20;
  font-size: 28rpx;
}

.phone-box {
  margin-top: 30rpx;
  height: 82rpx;
  border-radius: 8rpx;
  background: #ebd0ab;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 26rpx;
  box-sizing: border-box;
}

.phone-label {
  color: #9a7440;
  font-size: 26rpx;
}

.phone-value {
  color: #253842;
  font-size: 30rpx;
  font-weight: 600;
}

.cover-tabbar {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 2;
  height: 144rpx;
  border-radius: 0;
  border-top: 2rpx solid rgba(225, 195, 157, 0.9);
  border-left: 0;
  border-right: 0;
  border-bottom: 0;
  background: rgba(235, 208, 171, 0.96);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  box-shadow: 0 -10rpx 28rpx rgba(95, 61, 32, 0.12);
  overflow: hidden;
  transform: translate3d(0, 0, 0);
  transition: transform 520ms cubic-bezier(0.2, 0.78, 0.18, 1), opacity 260ms ease;
  will-change: transform, opacity;
}

.cover-tab {
  position: relative;
  color: #684626;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 0;
}

.cover-tab.active {
  color: #4f321a;
  background: rgba(225, 195, 157, 0.72);
}

.order-lifting .cover-bg,
.order-lifting .cover-mask {
  transform: translate3d(0, -96vh, 0);
}

.order-lifting .cover-mask {
  opacity: 0;
}

.order-lifting .cover-content {
  transform: translate3d(0, -42vh, 0);
  opacity: 0;
}

.order-lifting .cover-tabbar {
  transform: translate3d(0, 150rpx, 0);
  opacity: 0;
}

.order-lifting .action-card {
  pointer-events: none;
}

@keyframes planeTakeoff {
  0% {
    transform: translate3d(0, 0, 0) rotate(-18deg) scale(1);
    opacity: 1;
  }
  38% {
    transform: translate3d(96rpx, -86rpx, 0) rotate(-16deg) scale(1.02);
    opacity: 1;
  }
  100% {
    transform: translate3d(760rpx, -520rpx, 0) rotate(-24deg) scale(0.9);
    opacity: 0;
  }
}

@keyframes planeCover {
  0% {
    opacity: 1;
    transform: translate3d(-170vw, 72vh, 0) rotate(-12deg) scale(13);
  }
  12% {
    opacity: 1;
    transform: translate3d(-138vw, 58vh, 0) rotate(-11deg) scale(13);
  }
  34% {
    opacity: 1;
    transform: translate3d(-96vw, 38vh, 0) rotate(-8deg) scale(13);
  }
  58% {
    opacity: 1;
    transform: translate3d(-58vw, 18vh, 0) rotate(-4deg) scale(13);
  }
  82% {
    opacity: 1;
    transform: translate3d(-16vw, -6vh, 0) rotate(-1deg) scale(13);
  }
  100% {
    opacity: 1;
    transform: translate3d(190vw, -130vh, 0) rotate(12deg) scale(13);
  }
}

@keyframes previewShimmer {
  0% {
    background-position: 200% 0;
  }
  100% {
    background-position: -200% 0;
  }
}
