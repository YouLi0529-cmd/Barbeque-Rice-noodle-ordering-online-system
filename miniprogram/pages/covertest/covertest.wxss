/* pages/covertest/covertest.wxss */
.cover-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background: #ebd0ab;
}

.cover-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  transform: translate3d(0, 0, 0);
  transition: transform 680ms cubic-bezier(0.2, 0.78, 0.18, 1);
  will-change: transform;
}

.cover-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.08) 0%, rgba(0, 0, 0, 0.03) 44%, rgba(255, 255, 255, 0) 72%, rgba(255, 255, 255, 0) 100%);
  transform: translate3d(0, 0, 0);
  transition: transform 680ms cubic-bezier(0.2, 0.78, 0.18, 1), opacity 420ms ease;
  will-change: transform, opacity;
}

.status-bar {
  position: relative;
  z-index: 1;
}

.cover-content {
  position: relative;
  z-index: 1;
  min-height: calc(100vh - 120rpx);
  padding: 80rpx 52rpx 172rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  box-sizing: border-box;
  transform: translate3d(0, 0, 0);
  opacity: 1;
  transition: transform 620ms cubic-bezier(0.2, 0.78, 0.18, 1), opacity 260ms ease;
  will-change: transform, opacity;
}

.actions {
  display: flex;
  gap: 20rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18rpx;
}

.action-card {
  position: relative;
  height: 116rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(225, 195, 157, 0.95);
  background: rgba(235, 208, 171, 0.92);
  color: #5f3d20;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  box-shadow: 0 12rpx 28rpx rgba(95, 61, 32, 0.14);
  overflow: visible;
}

.camping-card {
  padding-right: 12rpx;
  z-index: 1;
}

.corner-plane {
  position: absolute;
  top: -16rpx;
  right: -10rpx;
  width: 62rpx;
  height: 62rpx;
  z-index: 2;
  transform: rotate(-18deg);
  transform-origin: center;
  filter: drop-shadow(0 8rpx 12rpx rgba(0, 0, 0, 0.2));
}

.plane-img {
  display: block;
}

.plane-launching .corner-plane {
  animation: planeTakeoff 680ms cubic-bezier(0.42, 0, 1, 1) forwards;
}

.plane-launching .action-card,
.plane-covering .action-card {
  pointer-events: none;
}

.plane-launching .action-card:not(.camping-card),
.plane-covering .action-card:not(.camping-card) {
  opacity: 0.46;
}

.plane-screen {
  position: absolute;
  inset: 0;
  z-index: 4;
  pointer-events: none;
  opacity: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.camping-preview {
  position: absolute;
  inset: 0;
  z-index: 3;
  opacity: 0;
  pointer-events: none;
  background: #f4f8fb;
  transform: translate3d(0, 20rpx, 0);
  transition: opacity 220ms linear, transform 220ms linear;
}

.camping-preview.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f4f8fb;
}

.order-preview {
  position: absolute;
  inset: 0;
  z-index: 3;
  opacity: 0;
  pointer-events: none;
  background: #f5e7d5;
  transform: translate3d(0, 100%, 0) scale(0.98);
  transform-origin: center bottom;
  border-radius: 28rpx 28rpx 0 0;
  overflow: hidden;
  transition: transform 820ms cubic-bezier(0.18, 0.82, 0.18, 1), opacity 220ms linear, border-radius 520ms ease;
  will-change: transform, opacity;
}

.order-preview.show {
  opacity: 1;
}

.order-lifting .order-preview.show {
  transform: translate3d(0, 0, 0) scale(1);
  border-radius: 0;
}

.order-preview-status,
.order-preview-header,
.order-preview-notice,
.order-preview-main,
.order-preview-cart {
  box-sizing: border-box;
}

.order-preview-status,
