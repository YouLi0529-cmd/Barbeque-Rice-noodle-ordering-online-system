<!--pages/index/index.wxml-->
<wxs module="tagHelper" src="../../utils/tagHelper.wxs"></wxs>
<view class="brand-page index-page">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="hero fire-gradient">
    <view class="hero-tags">
      <text class="hero-tag">今日营业中</text>
      <text class="hero-tag muted">人均 ¥60-70</text>
    </view>
    <view class="hero-title">张南火盆烧烤</view>
    <view class="hero-subtitle">石柱本地火盆烧烤 · 堂食自烤 · 户外烧烤</view>
    <view class="hero-meta">
      <text>炭火现烤</text>
      <text>朋友聚餐</text>
      <text>DIY 自烤</text>
    </view>
    <view class="table-chip" wx:if="{{tableNumber}}">
      当前桌号：{{tableNumber}}
    </view>
    <view class="table-chip ghost" wx:else>
      扫桌面二维码后自动绑定桌号
    </view>
  </view>

  <view class="notice-wrapper" wx:if="{{noticeList.length > 0}}">
    <van-notice-bar left-icon="volume-o" text="{{noticeText}}" scrollable color="#3A2418" background="#FFF2DD" />
  </view>

  <view class="entry-grid">
    <view class="entry-card primary" bindtap="goDineInEntry">
      <view class="entry-kicker">DINE IN</view>
      <view class="entry-title">堂食点单</view>
      <view class="entry-desc">扫码绑定桌号，边烤边加菜</view>
    </view>
    <view class="entry-card" bindtap="goOutdoorEntry">
      <view class="entry-kicker">OUTDOOR</view>
      <view class="entry-title">户外烧烤</view>
      <view class="entry-desc">选择免费烤架，备货后自取</view>
    </view>
    <view class="entry-card" bindtap="goQueueEntry">
      <view class="entry-kicker">QUEUE</view>
      <view class="entry-title">排队取号</view>
      <view class="entry-desc">旺季先取号，到号再入座</view>
    </view>
    <view class="entry-card" bindtap="goReservationEntry">
      <view class="entry-kicker">BOOKING</view>
      <view class="entry-title">预约订座</view>
      <view class="entry-desc">提前预约，朋友聚餐更稳</view>
    </view>
  </view>

  <view class="recommend-section">
    <view class="section-head">
      <view class="section-title">本店推荐</view>
      <view class="section-note">生肉、生菜、配菜、酒水都能点</view>
    </view>
    <scroll-view class="recommend-scroll" scroll-x enhanced show-scrollbar="{{false}}" wx:if="{{recommendedDishes.length > 0}}">
      <view class="recommend-row">
        <view class="recommend-card" wx:for="{{recommendedDishes}}" wx:key="_id">
          <image class="recommend-image" wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill"></image>
          <view class="recommend-image placeholder" wx:else>{{item.name}}</view>
          <view class="recommend-name">{{item.name}}</view>
          <view class="recommend-desc">{{item.description || item.desc || '炭火烧烤现点现备'}}</view>
          <view class="recommend-price">¥{{item.price}}</view>
        </view>
      </view>
    </scroll-view>
    <scroll-view class="recommend-scroll" scroll-x enhanced show-scrollbar="{{false}}" wx:else>
      <view class="recommend-row">
        <view class="recommend-card" wx:for="{{fallbackRecommendations}}" wx:key="name">
          <view class="recommend-image placeholder">{{item.name}}</view>
          <view class="recommend-name">{{item.name}}</view>
          <view class="recommend-desc">{{item.description}}</view>
          <view class="recommend-price">¥{{item.price}}</view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="service-notes">
    <view class="service-note">
      <text class="note-label">堂食</text>
      <text class="note-text">扫桌码下单，服务员送至桌台</text>
    </view>
    <view class="service-note">
      <text class="note-label">户外</text>
      <text class="note-text">扫户外码下单，选择烤架，备货完成后自取</text>
    </view>
    <view class="service-note">
      <text class="note-label">吧台</text>
      <text class="note-text">支持线下扫码付款，管理员确认已付款</text>
    </view>
  </view>

  <view class="menu-board" id="menuBoard">
    <view class="section-head menu-head">
      <view>
        <view class="section-title">火盆菜单</view>
        <view class="section-note">同一套菜单支持堂食和户外自取</view>
      </view>
      <view class="scan-btn" bindtap="scanTableCode">扫桌码</view>
    </view>

    <view class="main-content">
      <scroll-view class="menu-sidebar" scroll-y enhanced show-scrollbar="{{false}}">
        <view
          class="menu-item {{currentMenuId === item._id ? 'active' : ''}}"
          wx:for="{{menuList}}"
          wx:key="_id"
          bindtap="switchMenu"
          data-id="{{item._id}}">
          <text class="menu-name">{{item.name}}</text>
        </view>
      </scroll-view>

      <scroll-view class="goods-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="goods-item" wx:for="{{goodsList}}" wx:key="_id">
          <image class="goods-image" wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill"></image>
          <view class="goods-image no-image" wx:else>{{item.name}}</view>
          <view class="goods-info">
            <view class="goods-name">{{item.name}}</view>
            <view class="goods-desc" wx:if="{{item.description || item.desc}}">{{item.description || item.desc}}</view>
            <view class="miandan-tip" wx:if="{{item.canUseMiandan}}">可参与免单活动</view>
            <view class="goods-footer">
              <view class="goods-price">
                <text class="price-symbol">¥</text>
                <text class="price-num">{{item.price}}</text>
                <text class="price-original" wx:if="{{item.originalPrice && item.originalPrice > 0}}">¥{{item.originalPrice}}</text>
              </view>
              <view class="goods-actions">
                <view class="action-btn reduce" wx:if="{{item.cartCount > 0}}" bindtap="reduceDishFromCart" data-goods="{{item}}">
                  <text>-</text>
                </view>
                <view class="goods-count" wx:if="{{item.cartCount > 0}}">{{item.cartCount}}</view>
                <view class="action-btn add" bindtap="addDishToCartDirect" data-goods="{{item}}">
                  <text>+</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <van-empty wx:if="{{goodsList.length === 0}}" description="暂无菜品" />
      </scroll-view>
    </view>
  </view>

  <view class="float-cart-wrapper">
    <view class="float-cart-card">
      <view class="cart-left" bindtap="toggleCart">
        <view class="cart-icon-wrapper">
          <image class="cart-icon" src="/images/shopping.png" mode="aspectFit"></image>
          <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
        </view>
        <view class="cart-info">
          <view class="cart-price">
            <text class="price-label">合计</text>
            <text class="price-symbol">¥</text>
            <text class="price-num">{{cartTotalPriceText}}</text>
          </view>
          <view class="cart-tip" wx:if="{{tableNumber}}">{{tableNumber}}号桌</view>
          <view class="cart-tip" wx:else>结算前请扫桌码</view>
        </view>
      </view>
      <view class="cart-right">
        <view class="settle-btn {{cartCount > 0 ? 'active' : ''}}" bindtap="goToSettle">去结算</view>
      </view>
    </view>
  </view>

  <view class="cart-mask {{showCart ? 'show' : ''}}" bindtap="toggleCart"></view>
  <view class="cart-detail {{showCart ? 'show' : ''}}">
    <view class="cart-header">
      <text class="cart-title">已选菜品</text>
      <text class="cart-clear" bindtap="clearCart">清空</text>
    </view>
    <scroll-view class="cart-content" scroll-y>
      <view class="cart-goods-item" wx:for="{{cart}}" wx:for-item="item" wx:key="index">
        <view class="cart-goods-info">
          <image class="cart-goods-image" wx:if="{{item.info.image}}" src="{{item.info.image}}" mode="aspectFill"></image>
          <view class="cart-goods-image empty" wx:else>{{item.info.name}}</view>
          <view class="cart-goods-detail">
            <view class="cart-goods-name">{{item.info.name}}</view>
            <view class="cart-goods-tags" wx:if="{{item.tagLabels && item.tagLabels.length > 0}}">
              <text class="tag-text" wx:for="{{item.tagLabels}}" wx:key="index" wx:for-item="tagVal">{{tagVal}}</text>
            </view>
            <view class="cart-goods-price">¥{{item.info.price}} × {{item.count}}</view>
          </view>
        </view>
        <view class="cart-goods-actions">
          <view class="action-btn reduce" bindtap="reduceFromCart" data-id="{{index}}"><text>-</text></view>
          <view class="cart-count">{{item.count}}</view>
          <view class="action-btn add" bindtap="addToCartFromCart" data-id="{{index}}"><text>+</text></view>
        </view>
      </view>

      <van-empty wx:if="{{cartCount === 0}}" description="购物车是空的" />
    </scroll-view>

    <view class="cart-footer" wx:if="{{cartCount > 0}}">
      <view class="cart-footer-left">
        <view class="cart-total-label">合计</view>
        <view class="cart-total-price">
          <text class="price-symbol">¥</text>
          <text class="price-num">{{cartTotalPriceText}}</text>
        </view>
      </view>
      <view class="cart-footer-right">
        <view class="cart-settle-btn" bindtap="goToSettle">去结算</view>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showTagModal}}" catchtap="closeTagModal">
    <view class="modal-dialog dish-detail-modal" catchtap="stopPropagation">
      <view class="modal-close" bindtap="closeTagModal">×</view>
      <scroll-view class="modal-content" scroll-y>
        <view class="dish-detail-header">
          <image class="dish-detail-image" wx:if="{{currentDish.image}}" src="{{currentDish.image}}" mode="aspectFill"></image>
          <view class="dish-detail-image empty" wx:else>{{currentDish.name}}</view>
          <view class="dish-detail-info">
            <view class="dish-detail-name">{{currentDish.name}}</view>
            <view class="dish-detail-desc" wx:if="{{currentDish.description}}">{{currentDish.description}}</view>
            <view class="miandan-tip" wx:if="{{currentDish.canUseMiandan}}">可参与免单活动</view>
            <view class="dish-detail-price">
              <text class="price-symbol">¥</text>
              <text class="price-num">{{currentDish.price}}</text>
            </view>
          </view>
        </view>

        <view class="tag-section" wx:if="{{currentDish.tags && currentDish.tags.length > 0}}" wx:for="{{currentDish.tags}}" wx:key="id" wx:for-item="tag">
          <view class="tag-title">
            {{tag.name}}
            <text class="tag-type-label">{{tag.type === 'single' ? '(单选)' : '(多选)'}}</text>
            <text class="tag-required-label" wx:if="{{tag.required}}">必选</text>
          </view>

          <view class="tag-options" wx:if="{{tag.type === 'single'}}">
            <view
              class="tag-option {{selectedTags[tag.id] === option ? 'selected' : ''}}"
              wx:for="{{tag.options}}"
              wx:key="index"
              wx:for-item="option"
              bindtap="selectTagOption"
              data-tag-id="{{tag.id}}"
              data-option="{{option}}">
              {{option}}
            </view>
          </view>

          <view class="tag-options" wx:if="{{tag.type === 'multiple'}}">
            <view
              wx:for="{{tag.options}}"
              wx:key="index"
              wx:for-item="option"
              class="tag-option {{tagHelper.isTagOptionSelected(selectedTags, tag.id, option) ? 'selected' : ''}}"
              bindtap="toggleTagOption"
              data-tag-id="{{tag.id}}"
              data-option="{{option}}">
              {{option}}
            </view>
          </view>
        </view>

        <view class="quantity-section">
          <view class="quantity-label">数量</view>
          <view class="quantity-controls">
            <view class="quantity-btn {{modalDishCount <= 1 ? 'disabled' : ''}}" bindtap="decreaseModalCount">-</view>
            <view class="quantity-num">{{modalDishCount}}</view>
            <view class="quantity-btn" bindtap="increaseModalCount">+</view>
          </view>
        </view>
      </scroll-view>

      <view class="modal-footer-bar">
        <view class="footer-price">
          <text class="total-label">小计</text>
          <text class="price-symbol">¥</text>
          <text class="price-num">{{modalTotalPrice}}</text>
        </view>
        <view class="add-cart-btn" bindtap="confirmAddToCart">加入购物车</view>
      </view>
    </view>
  </view>

  <avatar-nickname-modal showAvaModal="{{showAuthModal}}" bind:saved="onUserInfoSaved"></avatar-nickname-modal>
</view>
