/* pages/reservation/reservation.wxss */
.reservation-page {
  padding-bottom: 50rpx;
}

.reservation-hero {
  padding: 54rpx 30rpx 44rpx;
  color: #FFF7EC;
  border-radius: 0 0 40rpx 40rpx;
}

.hero-label {
  color: rgba(255, 247, 236, 0.58);
  font-size: 21rpx;
  font-weight: 900;
}

.hero-title {
  margin-top: 20rpx;
  font-size: 56rpx;
  font-weight: 900;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 247, 236, 0.82);
  font-size: 28rpx;
}

.form-card {
  margin: 28rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #FFF2DD;
  box-shadow: 0 12rpx 30rpx rgba(58, 36, 24, 0.08);
}

.field-group {
  margin-bottom: 24rpx;
}

.field-label {
  margin-bottom: 12rpx;
  color: #1E1714;
  font-size: 27rpx;
  font-weight: 900;
}

.field-input,
.picker-field {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  color: #3A2418;
  background: #FFF7EC;
  font-size: 27rpx;
  box-sizing: border-box;
}

.remark-input {
  width: 100%;
  min-height: 170rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  color: #3A2418;
  background: #FFF7EC;
  font-size: 27rpx;
  box-sizing: border-box;
}

.primary-action {
  margin-top: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 999rpx;
  color: #fff;
  background: linear-gradient(135deg, #F26A2E 0%, #C9341C 100%);
  font-size: 30rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 24rpx rgba(201, 52, 28, 0.18);
}
