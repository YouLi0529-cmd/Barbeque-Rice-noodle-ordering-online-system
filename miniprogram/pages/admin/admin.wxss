/* pages/admin/admin.wxss */
.admin-page {
  min-height: 100vh;
  padding-bottom: 48rpx;
  background: #FFF7EC;
  color: #3A2418;
}

.admin-hero {
  padding: 56rpx 30rpx 42rpx;
  color: #FFF7EC;
  border-radius: 0 0 40rpx 40rpx;
}

.hero-kicker {
  color: rgba(255, 247, 236, 0.58);
  font-size: 21rpx;
  font-weight: 900;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 46rpx;
  font-weight: 900;
  line-height: 1.18;
}

.hero-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 247, 236, 0.82);
  font-size: 26rpx;
}

.menu-section {
  margin: 30rpx 24rpx 0;
}

.section-title {
  margin-bottom: 18rpx;
}

.admin-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.admin-menu-card {
  min-height: 146rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #FFF2DD;
  box-shadow: 0 12rpx 28rpx rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.admin-menu-card.hot {
  color: #FFF7EC;
  background: linear-gradient(135deg, #F26A2E 0%, #C9341C 100%);
}

.card-title {
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.25;
}

.card-desc {
  margin-top: 12rpx;
  color: rgba(58, 36, 24, 0.62);
  font-size: 23rpx;
  line-height: 1.42;
}

.admin-menu-card.hot .card-desc {
  color: rgba(255, 247, 236, 0.82);
}

.bottom-actions {
  margin: 34rpx 24rpx 0;
  display: flex;
  gap: 18rpx;
}

.ghost-action {
  flex: 1;
  height: 82rpx;
  line-height: 82rpx;
  text-align: center;
  border-radius: 999rpx;
  color: #F26A2E;
  border: 2rpx solid rgba(242, 106, 46, 0.42);
  background: rgba(255, 242, 221, 0.62);
  font-size: 27rpx;
  font-weight: 900;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(30, 23, 20, 0.56);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-dialog {
  width: 620rpx;
  background: #FFF7EC;
  border-radius: 26rpx;
  overflow: hidden;
}

.modal-title {
  padding: 38rpx 30rpx 18rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 900;
  color: #1E1714;
}

.modal-content {
  padding: 20rpx 30rpx 36rpx;
}

.password-input {
  width: 100%;
  height: 82rpx;
  border-radius: 18rpx;
  padding: 0 20rpx;
  font-size: 27rpx;
  color: #3A2418;
  background: #FFF2DD;
  box-sizing: border-box;
  margin-bottom: 18rpx;
}

.password-input:last-child {
  margin-bottom: 0;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid rgba(58, 36, 24, 0.08);
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 800;
}

.modal-btn.cancel {
  color: rgba(58, 36, 24, 0.54);
  border-right: 1rpx solid rgba(58, 36, 24, 0.08);
}

.modal-btn.confirm {
  color: #C9341C;
}
