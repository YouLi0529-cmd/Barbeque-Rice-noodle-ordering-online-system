<!--pages/admin/grill/grill.wxml-->
<view class="admin-list-page">
  <view class="top-bar fire-gradient">
    <view class="top-title">烤架管理</view>
    <view class="top-desc">管理 outdoorGrill 集合</view>
  </view>

  <view class="create-card">
    <view class="field-label">新增烤架</view>
    <view class="create-row">
      <input class="name-input" placeholder="例如 A1烤架" value="{{newGrillName}}" bindinput="onNameInput" />
      <view class="create-btn" bindtap="addGrill">新增</view>
    </view>
    <view class="default-btn" bindtap="createDefaults">创建默认 A1/A2/A3/B1/B2</view>
  </view>

  <view class="grill-card" wx:for="{{list}}" wx:key="_id">
    <view>
      <view class="grill-name">{{item.name}}</view>
      <view class="grill-meta">点位 {{item.outdoorPointId || 'main'}} · {{item.statusText}}</view>
    </view>
    <view class="toggle-btn" bindtap="toggleStatus" data-id="{{item._id}}" data-status="{{item.nextStatus}}">{{item.nextText}}</view>
  </view>

  <van-empty wx:if="{{list.length === 0}}" description="暂无烤架，建议先创建默认烤架" />
</view>
