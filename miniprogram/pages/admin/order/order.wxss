/* pages/admin/order/order.wxss */
.order-admin-page {
  min-height: 100vh;
  padding-bottom: 44rpx;
  background: #FFF7EC;
  color: #3A2418;
}

.top-bar {
  padding: 52rpx 30rpx 38rpx;
  color: #FFF7EC;
  border-radius: 0 0 36rpx 36rpx;
}

.top-title {
  font-size: 44rpx;
  font-weight: 900;
}

.top-desc {
  margin-top: 10rpx;
  color: rgba(255, 247, 236, 0.78);
  font-size: 25rpx;
}

.summary-row {
  margin: 24rpx 24rpx 0;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.summary-item {
  padding: 18rpx 8rpx;
  border-radius: 20rpx;
  background: #FFF2DD;
  text-align: center;
  box-shadow: 0 10rpx 22rpx rgba(58, 36, 24, 0.06);
}

.summary-item.urgent {
  color: #FFF7EC;
  background: linear-gradient(135deg, #F26A2E 0%, #C9341C 100%);
}

.summary-num,
.summary-label {
  display: block;
}

.summary-num {
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1.1;
}

.summary-label {
  margin-top: 8rpx;
  color: rgba(58, 36, 24, 0.6);
  font-size: 20rpx;
}

.summary-item.urgent .summary-label {
  color: rgba(255, 247, 236, 0.78);
}

.filter-panel {
  margin: 22rpx 24rpx;
  padding: 20rpx;
  border-radius: 24rpx;
  background: #FFF2DD;
  box-shadow: 0 12rpx 28rpx rgba(58, 36, 24, 0.08);
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 14rpx;
}

.filter-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  color: #3A2418;
  background: #FFF7EC;
  font-size: 24rpx;
  font-weight: 800;
}

.filter-chip.active {
  color: #fff;
  background: linear-gradient(135deg, #F26A2E 0%, #C9341C 100%);
}

.refresh-line {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  color: rgba(58, 36, 24, 0.5);
  font-size: 22rpx;
}

.refresh-btn {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  color: #C9341C;
  background: rgba(201, 52, 28, 0.08);
  font-size: 24rpx;
  font-weight: 800;
}

.order-card {
  margin: 0 24rpx 22rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #FFF2DD;
  box-shadow: 0 12rpx 28rpx rgba(58, 36, 24, 0.08);
}

.urgent-card {
  border: 2rpx solid rgba(242, 106, 46, 0.58);
}

.card-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.head-main {
  flex: 1;
  min-width: 0;
}

.order-kind {
  color: #1E1714;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.order-time {
  margin-top: 8rpx;
  color: rgba(58, 36, 24, 0.58);
  font-size: 23rpx;
}

.status-tag {
  height: 46rpx;
  line-height: 46rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(58, 36, 24, 0.08);
  color: #3A2418;
  font-size: 22rpx;
  font-weight: 900;
  white-space: nowrap;
}

.status-warning {
  color: #C9341C;
  background: rgba(242, 106, 46, 0.16);
}

.status-busy {
  color: #8A4B00;
  background: rgba(255, 183, 77, 0.22);
}

.status-ready {
  color: #0F766E;
  background: rgba(15, 118, 110, 0.12);
}

.status-done {
  color: rgba(58, 36, 24, 0.56);
  background: rgba(58, 36, 24, 0.08);
}

.status-cancelled {
  color: #8A1C1C;
  background: rgba(138, 28, 28, 0.1);
}

.goods-list {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #FFF7EC;
}

.goods-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  color: #3A2418;
  font-size: 25rpx;
  line-height: 1.5;
}

.goods-row + .goods-row {
  margin-top: 10rpx;
}

.goods-name {
  flex: 1;
}

.goods-count {
  color: #C9341C;
  font-weight: 900;
}

.remark-box {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(242, 106, 46, 0.1);
}

.remark-label,
.remark-text {
  display: block;
}

.remark-label {
  color: #C9341C;
  font-size: 21rpx;
  font-weight: 900;
}

.remark-text {
  margin-top: 6rpx;
  color: #3A2418;
  font-size: 24rpx;
  line-height: 1.45;
}

.meta-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.meta-item {
  padding: 15rpx;
  border-radius: 16rpx;
  background: rgba(255, 247, 236, 0.72);
}

.meta-warning {
  background: rgba(242, 106, 46, 0.13);
}

.meta-label,
.meta-value {
  display: block;
}

.meta-label {
  color: rgba(58, 36, 24, 0.52);
  font-size: 21rpx;
}

.meta-value {
  margin-top: 6rpx;
  color: #1E1714;
  font-size: 24rpx;
  font-weight: 900;
}

.actions {
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 14rpx;
}

.action-btn {
  min-width: 150rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.action-btn.primary {
  color: #fff;
  background: linear-gradient(135deg, #F26A2E 0%, #C9341C 100%);
}

.action-btn.pay {
  color: #fff;
  background: #0F766E;
}

.action-btn.secondary {
  color: #C9341C;
  border: 2rpx solid rgba(201, 52, 28, 0.22);
  background: rgba(255, 247, 236, 0.72);
}

.action-btn.danger {
  color: #8A1C1C;
  background: rgba(138, 28, 28, 0.08);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(30, 23, 20, 0.56);
}

.remark-dialog {
  width: 640rpx;
  overflow: hidden;
  border-radius: 26rpx;
  background: #FFF7EC;
}

.modal-title {
  padding: 34rpx 30rpx 18rpx;
  color: #1E1714;
  text-align: center;
  font-size: 32rpx;
  font-weight: 900;
}

.remark-input {
  width: auto;
  height: 190rpx;
  margin: 0 30rpx 30rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  color: #3A2418;
  background: #FFF2DD;
  font-size: 26rpx;
  line-height: 1.45;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid rgba(58, 36, 24, 0.08);
}

.modal-btn {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 29rpx;
  font-weight: 900;
}

.modal-btn.cancel {
  color: rgba(58, 36, 24, 0.56);
  border-right: 1rpx solid rgba(58, 36, 24, 0.08);
}

.modal-btn.confirm {
  color: #C9341C;
}
