/* pages/admin/order/order.wxss */
.order-admin-page {
  min-height: 100vh;
  padding-bottom: 40rpx;
  background: #FFF7EC;
}

.top-bar {
  padding: 52rpx 30rpx 38rpx;
  color: #FFF7EC;
  border-radius: 0 0 36rpx 36rpx;
}

.top-title {
  font-size: 44rpx;
  font-weight: 900;
}

.top-desc {
  margin-top: 10rpx;
  color: rgba(255, 247, 236, 0.78);
  font-size: 25rpx;
}

.filter-panel {
  margin: 24rpx;
  padding: 20rpx;
  border-radius: 26rpx;
  background: #FFF2DD;
  box-shadow: 0 12rpx 28rpx rgba(58, 36, 24, 0.08);
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 14rpx;
}

.filter-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  color: #3A2418;
  background: #FFF7EC;
  font-size: 24rpx;
  font-weight: 800;
}

.filter-chip.active {
  color: #fff;
  background: linear-gradient(135deg, #F26A2E 0%, #C9341C 100%);
}

.refresh-line {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16rpx;
  color: rgba(58, 36, 24, 0.5);
  font-size: 22rpx;
}

.refresh-btn {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  color: #C9341C;
  background: rgba(201, 52, 28, 0.08);
  font-size: 24rpx;
  font-weight: 800;
}

.order-card {
  margin: 0 24rpx 22rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: #FFF2DD;
  box-shadow: 0 12rpx 28rpx rgba(58, 36, 24, 0.08);
}

.card-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.order-kind {
  color: #1E1714;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
}

.order-time {
  margin-top: 8rpx;
  color: rgba(58, 36, 24, 0.58);
  font-size: 23rpx;
}

.goods-list,
.recharge-info {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  background: #FFF7EC;
}

.goods-row,
.info-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  color: #3A2418;
  font-size: 25rpx;
  line-height: 1.5;
}

.goods-row + .goods-row,
.info-row + .info-row {
  margin-top: 10rpx;
}

.goods-name {
  flex: 1;
}

.goods-count,
.info-row text:last-child {
  color: #C9341C;
  font-weight: 900;
}

.meta-grid {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.meta-item {
  padding: 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 247, 236, 0.7);
}

.meta-label,
.meta-value {
  display: block;
}

.meta-label {
  color: rgba(58, 36, 24, 0.52);
  font-size: 21rpx;
}

.meta-value {
  margin-top: 6rpx;
  color: #1E1714;
  font-size: 25rpx;
  font-weight: 900;
}

.actions {
  margin-top: 22rpx;
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 900;
}

.action-btn.primary {
  color: #fff;
  background: linear-gradient(135deg, #F26A2E 0%, #C9341C 100%);
}
