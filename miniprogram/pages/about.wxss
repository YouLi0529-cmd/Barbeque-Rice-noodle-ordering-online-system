/* pages/about.wxss */
.about-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.about-header {
  position: relative;
  background: #e54d42;
  padding-left: 30rpx;
  padding-right: 30rpx;
  box-sizing: content-box;
}

.about-nav {
  position: relative;
  display: block;
}

.about-nav-content {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  box-sizing: border-box;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  top: 0;
  width: 64rpx;
  height: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  color: #ffffff;
  box-sizing: border-box;
}

.back-icon {
  border-left-style: solid;
  border-bottom-style: solid;
  border-color: #ffffff;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.about-title {
  color: #ffffff;
  font-weight: bold;
  line-height: 1;
  text-align: center;
  box-sizing: border-box;
}

.about-content {
  padding: 36rpx 30rpx;
}

.shop-card {
  border-radius: 20rpx;
  background: #ffffff;
  padding: 46rpx 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.shop-logo {
  width: 118rpx;
  height: 118rpx;
  border-radius: 59rpx;
  background: #fff1f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.shop-logo image {
  width: 70rpx;
  height: 70rpx;
}

.shop-name {
  margin-top: 28rpx;
  color: #333333;
  font-size: 36rpx;
  font-weight: bold;
}

.shop-desc {
  margin-top: 18rpx;
  color: #666666;
  font-size: 28rpx;
  line-height: 1.7;
  text-align: center;
}
