/* pages/index/index.wxss */
page {
  height: 100%;
  background: #f5e7d5;
  overflow: hidden;
}

.page {
  height: 100vh;
  min-height: 0;
  display: flex;
  flex-direction: column;
  background: #f5e7d5;
  overflow: hidden;
}

.top-safe-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: #f5e7d5;
  pointer-events: none;
}

/* 状态栏占位 */
/* 店名 */
.shop-header {
  position: relative;
  z-index: 21;
  background: #f5e7d5;
  padding-left: 30rpx;
  padding-right: 30rpx;
  text-align: center;
  box-sizing: content-box;
}

.shop-nav {
  position: relative;
  display: block;
}

.shop-content {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.cover-back-btn {
  position: absolute;
  left: 24rpx;
  top: 0;
  width: 64rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #5f3d20;
  box-sizing: border-box;
}

.order-search-box {
  width: 100%;
  height: 100%;
  min-width: 0;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 241, 0.86);
  border: 2rpx solid rgba(216, 180, 126, 0.36);
  box-shadow: 0 6rpx 16rpx rgba(95, 61, 32, 0.06);
  box-sizing: border-box;
}

.search-icon {
  position: relative;
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid #b78a52;
  border-radius: 50%;
  flex-shrink: 0;
  box-sizing: border-box;
}

.search-icon::after {
  content: "";
  position: absolute;
  right: -9rpx;
  bottom: -7rpx;
  width: 12rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #b78a52;
  transform: rotate(45deg);
}

.order-search-input {
  flex: 1;
  min-width: 0;
  height: 100%;
  margin-left: 18rpx;
  color: #5f3d20;
  font-size: 27rpx;
  line-height: 1;
}

.order-search-input::placeholder {
  color: #b59a78;
}

.search-clear {
  position: relative;
  width: 34rpx;
  height: 34rpx;
  margin-left: 12rpx;
  border-radius: 50%;
  background: rgba(183, 138, 82, 0.18);
  flex-shrink: 0;
}

.search-clear::before,
.search-clear::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 18rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #9b7142;
}

.search-clear::before {
  transform: translate(-50%, -50%) rotate(45deg);
}

.search-clear::after {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.shop-search-row {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.back-icon {
  position: relative;
  border-left-style: solid;
  border-bottom-style: solid;
  border-color: #5f3d20;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.shop-name {
  color: #5f3d20;
  font-weight: bold;
  line-height: 1;
  display: block;
  text-align: center;
  box-sizing: border-box;
  position: relative;
}

.nav-shop-name {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 搜索框 */
.search-wrapper {
  background: #f5e7d5;
  padding: 10rpx 0;
}

/* 轮播公告 */
.notice-wrapper {
  position: relative;
  z-index: 22;
  flex: none;
  display: block;
  min-height: 58rpx;
  padding: 0 30rpx 8rpx;
  background: #f5e7d5;
  box-sizing: border-box;
  overflow: visible;
}

.notice-component {
  display: block;
  width: 100%;
}

.notice-bar {
  width: 100%;
  height: 52rpx !important;
  --notice-bar-height: 52rpx;
  --notice-bar-line-height: 52rpx;
  --notice-bar-padding: 0 18rpx;
  --notice-bar-font-size: 22rpx;
  --notice-bar-icon-size: 24rpx;
  --notice-bar-icon-min-width: 30rpx;
  display: flex !important;
  align-items: center !important;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(255, 250, 241, 0.78) !important;
  border: 1rpx solid rgba(216, 180, 126, 0.38);
  box-shadow: 0 5rpx 14rpx rgba(95, 61, 32, 0.05);
  box-sizing: border-box;
  color: #7A4A1F !important;
  font-size: 22rpx !important;
  line-height: 52rpx !important;
}
/* 顶部用户信息栏 */
.user-bar {
  background: linear-gradient(135deg, #e54d42 0%, #f37370 100%);
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-label {
  color: rgba(255,255,255,0.9);
  font-size: 28rpx;
}

.user-balance {
  color: white;
  font-size: 36rpx;
  font-weight: bold;
  margin-left: 10rpx;
}

.user-miandan {
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.miandan-text {
  color: white;
  font-size: 24rpx;
}

/* 主内容区 */
.main-content {
  flex: 1;
  height: 0;
  display: flex;
  overflow: hidden;
  background: #f5e7d5;
  min-height: 0;
}

/* 左侧分类菜单 */
.menu-sidebar {
  width: 180rpx;
  height: 100%;
  flex-shrink: 0;
  background: #f5e7d5;
  border-right: 1rpx solid #ead6b8;
  padding-bottom: 150rpx;
  box-sizing: border-box;
}

.menu-item {
  position: relative;
  padding: 35rpx 20rpx;
  text-align: center;
  background: #f5e7d5;
  transition: all 0.3s;
}

.menu-item.active {
  background: #d8b47e;
}

.menu-name {
  font-size: 28rpx;
  color: #333;
}

.menu-item.active .menu-name {
  color: #fffaf1;
  font-weight: bold;
}

.menu-indicator {
  display: none;
}

/* 右侧菜品列表 */
.goods-list {
  flex: 1;
  height: 100%;
  padding: 20rpx;
  padding-bottom: 180rpx;
  background: #f5e7d5;
  min-height: 0;
  box-sizing: border-box;
}

.order-loading {
  min-height: 560rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.order-loading-img {
  width: 420rpx;
  height: 420rpx;
}

.order-loading-text {
  margin-top: 18rpx;
  color: #8a6847;
  font-size: 26rpx;
  letter-spacing: 0;
}

.category-section {
  margin-bottom: 18rpx;
}

.category-divider {
  display: flex;
  align-items: center;
  margin: 18rpx 0 22rpx;
}

.divider-line {
  flex: 1;
  height: 2rpx;
}

.divider-line.left {
  background: linear-gradient(90deg, rgba(47, 36, 27, 0), rgba(47, 36, 27, 0.7));
}

.divider-line.right {
  background: linear-gradient(90deg, rgba(47, 36, 27, 0.7), rgba(47, 36, 27, 0));
}

.divider-title {
  flex-shrink: 0;
  padding: 0 22rpx;
  color: #2f241b;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 2rpx;
}

.section-loading {
  position: sticky;
  bottom: 140rpx;
  z-index: 6;
  width: 160rpx;
  height: 160rpx;
  margin: 10rpx auto 34rpx;
  border-radius: 50%;
  background: rgba(255, 250, 241, 0.82);
  box-shadow: 0 8rpx 22rpx rgba(95, 61, 32, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.section-loading-img {
  width: 138rpx;
  height: 138rpx;
}

.goods-item {
  background: rgba(255, 250, 241, 0.96);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  box-shadow: 0 4rpx 12rpx rgba(95, 61, 32, 0.08);
}

.goods-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
  line-height: 1.35;
}


.goods-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 8rpx;
}

.miandan-tip {
  width:190rpx;
  font-size: 22rpx;
  color: #ff6b6b;
  background: #fff3f0;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  display: inline-block;
  margin-top: 8rpx;
  border: 1rpx solid #ffe0e0;
}

.goods-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.goods-price {
  color: #c9852f;
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  text-shadow: 0 1rpx 0 rgba(255, 250, 241, 0.96), 0 0 3rpx rgba(95, 61, 32, 0.16);
}

.goods-price .price-original {
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

.goods-price .price-symbol {
  font-size: 22rpx;
  color: #c9852f;
  font-weight: bold;
}

.goods-price .price-num {
  font-size: 36rpx;
  color: #c9852f;
  font-weight: bold;
}

.goods-price .price-unit {
  font-size: 18rpx;
  color: #c9852f;
  font-weight: bold;
}

.goods-actions {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.action-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  line-height: 1;
  box-sizing: border-box;
}

.action-btn text {
  display: block;
}

.plus-icon,
.minus-icon {
  position: relative;
  width: 22rpx;
  height: 22rpx;
}

.plus-icon::before,
.plus-icon::after,
.minus-icon::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 22rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform: translate(-50%, -50%);
}

.plus-icon::after {
  transform: translate(-50%, -50%) rotate(90deg);
}

.action-btn.reduce {
  background: rgba(255, 250, 241, 0.88);
  color: #b8792f;
  border: 2rpx solid rgba(200, 145, 70, 0.42);
}

.action-btn.add {
  background: #f1d49d;
  color: #fffaf1;
  border: 2rpx solid rgba(190, 135, 58, 0.35);
  box-shadow: 0 5rpx 10rpx rgba(169, 106, 34, 0.12);
}

.goods-count {
  min-width: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  padding: 4rpx 8rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 悬浮购物车 */
.float-cart-wrapper {
  position: fixed;
  left: 30rpx;
  right: 30rpx;
  bottom: 20rpx;
  z-index: 10;
}

.float-cart-card {
  background: rgba(255, 250, 241, 0.96);
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 15rpx;
  box-shadow: 0 8rpx 40rpx rgba(95, 61, 32, 0.18);
}

.cart-left {
  flex: 1;
  display: flex;
  align-items: center;
}

.preorder-cart-left {
  flex: 0 0 auto;
}

.cart-icon-wrapper {
  position: relative;
  width: 124rpx;
  height: 124rpx;

  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.cart-icon {
  display: block;
  width: 132rpx;
  height: 132rpx;
}

.cart-badge {
  position: absolute;
  top: -5rpx;
  right: -5rpx;
  background: #e54d42;
  color: white;
  border-radius: 50%;
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: bold;
  padding: 0 6rpx;
  border: 3rpx solid white;
}

.cart-info {
  flex: 1;
}

.cart-price {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 28rpx;
  color: #e54d42;
  margin-right: 5rpx;
  font-weight: bold;
}

.cart-price .price-symbol {
  font-size: 24rpx;
  color: #e54d42;
  font-weight: bold;
}

.cart-price .price-num {
  font-size: 32rpx;
  color: #e54d42;
  font-weight: bold;
}

.cart-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.cart-fx-layer {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 999;
}

.meat-flight {
  position: fixed;
  width: 46rpx;
  height: 34rpx;
  transform-origin: center center;
  transition: transform 0.62s cubic-bezier(0.2, 0.78, 0.24, 1), opacity 0.18s ease;
}

.meat-piece {
  position: relative;
  width: 46rpx;
  height: 34rpx;
  border-radius: 42% 50% 45% 48%;
  background: linear-gradient(135deg, #b9432f 0%, #8e2b1f 48%, #d9784e 100%);
  box-shadow: 0 4rpx 8rpx rgba(95, 36, 24, 0.18);
  overflow: hidden;
  animation: meatArcLift 0.62s cubic-bezier(0.26, 0.76, 0.26, 1);
}

.meat-piece::before {
  content: "";
  position: absolute;
  left: 6rpx;
  top: 6rpx;
  width: 16rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(255, 218, 188, 0.36);
  transform: rotate(-18deg);
}

.meat-mark {
  position: absolute;
  width: 42rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: rgba(73, 24, 15, 0.48);
  transform: rotate(-22deg);
}

.mark-one {
  left: -4rpx;
  top: 10rpx;
}

.mark-two {
  right: -4rpx;
  bottom: 9rpx;
}

.cart-heat {
  position: fixed;
  width: 48rpx;
  height: 62rpx;
  transition: transform 0.68s ease-out, opacity 0.68s ease-out;
}

.heat-line {
  position: absolute;
  bottom: 4rpx;
  width: 16rpx;
  height: 42rpx;
  border-left: 3rpx solid rgba(145, 103, 60, 0.58);
  border-radius: 50%;
}

.heat-a {
  left: 10rpx;
  transform: rotate(9deg);
}

.heat-b {
  left: 25rpx;
  height: 34rpx;
  transform: rotate(-10deg);
  opacity: 0.72;
}

.cart-bounce {
  animation: cartPressBounce 0.42s cubic-bezier(0.2, 0.84, 0.24, 1);
}

.badge-bounce {
  animation: badgePop 0.36s cubic-bezier(0.18, 0.88, 0.22, 1);
}

@keyframes meatArcLift {
  0% {
    transform: translateY(0) scale(1);
  }
  45% {
    transform: translateY(-54rpx) scale(0.88);
  }
  100% {
    transform: translateY(0) scale(1);
  }
}

@keyframes cartPressBounce {
  0% {
    transform: scale(1);
  }
  34% {
    transform: scale(0.9);
  }
  68% {
    transform: scale(1.12);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes badgePop {
  0% {
    transform: scale(1);
  }
  45% {
    transform: scale(1.28);
  }
  100% {
    transform: scale(1);
  }
}

.cart-right {
  flex-shrink: 0;
}

.cart-right-preorder {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.settle-btn {
  padding: 22rpx 45rpx;
  border-radius: 50rpx;
  background: #e0e0e0;
  color: #999;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s;
}

.settle-btn.active {
  background: linear-gradient(135deg, #d6a24a 0%, #b8792f 100%);
  color: #fffaf1;
}

.cart-action-pill {
  min-width: 142rpx;
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.15;
  white-space: nowrap;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.cart-action-pill.seated {
  color: #8a6a3f;
  background: rgba(255, 255, 255, 0.72);
  border: 2rpx solid rgba(191, 151, 86, 0.5);
}

.cart-action-pill.preorder {
  min-width: 166rpx;
  color: #fffdf8;
  background: linear-gradient(135deg, #d3a14b 0%, #b9822f 100%);
  border: 2rpx solid rgba(150, 96, 31, 0.35);
  box-shadow: 0 8rpx 20rpx rgba(150, 96, 31, 0.22);
}

.cart-action-pill:not(.active) {
  opacity: 0.55;
}

/* 购物车详情弹窗 */
.cart-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
}

.cart-mask.show {
  opacity: 1;
  visibility: visible;
}

.cart-detail {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 70vh;
  background: #fffaf1;
  border-radius: 20rpx 20rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s;
  display: flex;
  flex-direction: column;
}

.cart-detail.show {
  transform: translateY(0);
}

.cart-header {
  padding: 30rpx;
  border-bottom: 1rpx solid #ead6b8;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cart-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.cart-clear {
  font-size: 28rpx;
  color: #e54d42;
}

.cart-content {
  flex: 1;
  padding: 20rpx 30rpx;
}

.cart-goods-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #ead6b8;
}

.cart-goods-info {
  flex: 1;
  display: flex;
  align-items: center;
}

.cart-goods-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
}

.cart-goods-detail {
  flex: 1;
}

.cart-goods-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 5rpx;
  letter-spacing: 2rpx;
  line-height: 1.35;
}

.cart-goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.tag-text {
  font-size: 22rpx;
  color: #e54d42;
  background: #fff3f0;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
}

.cart-goods-price {
  font-size: 26rpx;
  color: #666;
}

.cart-goods-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-left: 20rpx;
}

.cart-count {
  min-width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  padding: 4rpx 8rpx;
}

/* 购物车底部栏 */
.cart-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx 30rpx;
  background: #fffaf1;
  border-top: 2rpx solid #ead6b8;
  flex-shrink: 0;
}

.cart-footer-left {
  display: flex;
  align-items: baseline;
  flex: 1;
}

.cart-total-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}

.cart-total-price {
  display: flex;
  align-items: baseline;
}

.cart-total-price .price-symbol {
  font-size: 24rpx;
  color: #e54d42;
  font-weight: bold;
}

.cart-total-price .price-num {
  font-size: 36rpx;
  color: #e54d42;
  font-weight: bold;
}

.cart-footer-right {
  margin-left: 20rpx;
}

.cart-footer-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.preorder-footer-actions {
  width: 100%;
  margin-left: 0;
  justify-content: space-between;
}

.preorder-footer-actions .cart-action-pill {
  flex: 1;
  min-width: 0;
}

.cart-settle-btn {
  padding: 20rpx 50rpx;
  background: linear-gradient(135deg, #d6a24a 0%, #b8792f 100%);
  color: #fffaf1;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
}

/* 商品详情弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-dialog.dish-detail-modal {
  width: 90%;
  max-height: 85vh;
  background: #fffaf1;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
}

.modal-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 48rpx;
  font-weight: 300;
  z-index: 10;
  line-height: 1;
  height: 100%;
}

.modal-content {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx;
}

/* 商品信息头部 */
.dish-detail-header {
  margin-bottom: 30rpx;
}

.dish-detail-image {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.dish-detail-info {
  padding: 0 10rpx;
}

.dish-detail-name {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.dish-detail-desc {
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
  margin-bottom: 15rpx;
}



.dish-detail-price {
  font-size: 40rpx;
  color: #e54d42;
  font-weight: bold;
}

.dish-detail-price .price-symbol {
  font-size: 28rpx;
}

/* 标签选择 */
.tag-section {
  margin-bottom: 30rpx;
  padding: 25rpx;
  background: #f5e7d5;
  border-radius: 16rpx;
}

.tag-section:last-child {
  margin-bottom: 0;
}

.tag-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
}

.tag-type-label {
  font-size: 22rpx;
  color: #999;
  font-weight: normal;
  margin-left: 8rpx;
}

.tag-required-label {
  font-size: 22rpx;
  color: white;
  background: #e54d42;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  margin-left: 10rpx;
  font-weight: normal;
}

.tag-options {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.tag-option {
  padding: 16rpx 30rpx;
  background: #fffaf1;
  border: 2rpx solid #e1c39d;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.tag-option.selected {
  background: linear-gradient(135deg, #e54d42 0%, #f37370 100%);
  border-color: #e54d42;
  color: white;
  font-weight: bold;
}

/* 数量选择 */
.quantity-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 25rpx;
  background: #f5e7d5;
  border-radius: 16rpx;
  margin-top: 30rpx;
}

.quantity-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.quantity-controls {
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.quantity-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e54d42 0%, #f37370 100%);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
}

.quantity-btn.disabled {
  background: #e5e5e5;
  color: #999;
}

.quantity-num {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  min-width: 60rpx;
  text-align: center;
}

/* 底部操作栏 */
.modal-footer-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: #fffaf1;
  border-top: 2rpx solid #ead6b8;
  flex-shrink: 0;
}

.footer-price {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 10rpx;
}

.footer-price .price-symbol {
  font-size: 24rpx;
  color: #e54d42;
  font-weight: bold;
}

.footer-price .price-num {
  font-size: 36rpx;
  color: #e54d42;
  font-weight: bold;
}

.add-cart-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #e54d42 0%, #f37370 100%);
  color: white;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 菜品规格选择弹窗 */
.modal-mask {
  align-items: flex-end;
  justify-content: center;
  background: rgba(0, 0, 0, 0.48);
}

.spec-modal {
  position: relative;
  width: 100%;
  height: 64vh;
  background: #fffaf1;
  border-radius: 42rpx 42rpx 0 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-top: 112rpx;
  overflow: visible;
}

.spec-product-card {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  top: -64rpx;
  min-height: 168rpx;
  padding: 22rpx;
  border-radius: 16rpx;
  background: #fffaf1;
  box-shadow: 0 16rpx 40rpx rgba(95, 61, 32, 0.16);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.spec-product-image {
  width: 132rpx;
  height: 132rpx;
  border-radius: 14rpx;
  background: #f2e0c6;
  flex-shrink: 0;
}

.spec-product-info {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
}

.spec-product-name {
  color: #2f241b;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.25;
  letter-spacing: 2rpx;
}

.spec-product-desc {
  margin-top: 10rpx;
  color: #8c7a66;
  font-size: 24rpx;
  line-height: 1.45;
}

.spec-content {
  flex: 1;
  min-height: 0;
  padding: 0 32rpx 24rpx;
  box-sizing: border-box;
}

.spec-section {
  margin-bottom: 42rpx;
}

.spec-title {
  color: #2f241b;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 22rpx;
}

.flavor-options {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.flavor-option {
  min-width: 160rpx;
  height: 76rpx;
  padding: 0 32rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 2rpx solid #e6dfd5;
  color: #5d5145;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.flavor-option.selected {
  background: #f5e7d5;
  border-color: #d8b47e;
  color: #5f3d20;
  font-weight: 700;
}

.flavor-note {
  margin-top: 16rpx;
  color: #9a8975;
  font-size: 24rpx;
  line-height: 1.45;
}

.remark-box {
  height: 78rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 2rpx solid rgba(230, 223, 213, 0.9);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.remark-input {
  flex: 1;
  min-width: 0;
  height: 100%;
  color: #2f241b;
  font-size: 28rpx;
}

.remark-input::placeholder {
  color: #b7aaa0;
}

.remark-count {
  margin-left: 16rpx;
  color: #8e8176;
  font-size: 24rpx;
}

.spec-footer {
  flex-shrink: 0;
  background: #fffaf1;
  border-top: 2rpx solid rgba(234, 214, 184, 0.78);
  padding: 22rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 24rpx rgba(95, 61, 32, 0.08);
  box-sizing: border-box;
}

.spec-footer-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.spec-price {
  display: flex;
  align-items: baseline;
  color: #2a2119;
  font-weight: 800;
}

.spec-price-symbol {
  font-size: 34rpx;
}

.spec-price-num {
  font-size: 52rpx;
  line-height: 1;
}

.spec-selected {
  margin-top: 4rpx;
  color: #8a7a6a;
  font-size: 26rpx;
}

.modal-quantity {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.modal-qty-btn {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  border: 2rpx solid #d8b47e;
  color: #9a5d18;
  background: #fffaf1;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.modal-qty-btn.add {
  background: #f1d49d;
  color: #fffaf1;
}

.modal-qty-btn.disabled {
  opacity: 0.45;
}

.modal-qty-num {
  min-width: 32rpx;
  text-align: center;
  color: #2f241b;
  font-size: 32rpx;
  font-weight: 600;
}

.spec-submit-btn {
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e4b95f 0%, #d49a35 100%);
  color: #fffaf1;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 22rpx rgba(181, 123, 39, 0.22);
}

.people-modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10000;
  background: rgba(0, 0, 0, 0.46);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.people-modal {
  width: 100%;
  padding: 44rpx 36rpx calc(34rpx + env(safe-area-inset-bottom));
  border-radius: 42rpx 42rpx 0 0;
  background: #fffaf1;
  box-sizing: border-box;
  box-shadow: 0 -18rpx 46rpx rgba(60, 38, 20, 0.18);
}

.people-modal-title {
  color: #2f241b;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.25;
}

.people-modal-desc {
  margin-top: 8rpx;
  color: #8a7a6a;
  font-size: 24rpx;
}

.people-options {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 34rpx;
}

.people-option {
  width: calc((100% - 54rpx) / 4);
  flex: 0 0 calc((100% - 54rpx) / 4);
  height: 74rpx;
  border-radius: 18rpx;
  border: 2rpx solid #e6dfd5;
  background: #ffffff;
  color: #5d5145;
  font-size: 27rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.people-option.active {
  border-color: #d8b47e;
  background: #f5e7d5;
  color: #5f3d20;
  box-shadow: 0 8rpx 18rpx rgba(181, 123, 39, 0.12);
}

.people-option.custom {
  width: calc((50% - 9rpx));
  flex-basis: calc((50% - 9rpx));
}

.people-custom-row {
  height: 78rpx;
  margin-top: 24rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(216, 180, 126, 0.72);
  background: rgba(255, 255, 255, 0.86);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.people-custom-input {
  flex: 1;
  min-width: 0;
  height: 100%;
  color: #2f241b;
  font-size: 30rpx;
}

.people-custom-unit {
  color: #8a6a42;
  font-size: 26rpx;
}

.people-modal-tip {
  min-height: 34rpx;
  margin-top: 18rpx;
  color: #b45f2a;
  font-size: 24rpx;
  line-height: 1.4;
}

.people-confirm-btn {
  height: 86rpx;
  margin-top: 26rpx;
  border-radius: 999rpx;
  background: #ead7b9;
  color: rgba(95, 61, 32, 0.62);
  font-size: 30rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.people-confirm-btn.active {
  background: linear-gradient(135deg, #e4b95f 0%, #d49a35 100%);
  color: #fffaf1;
  box-shadow: 0 10rpx 22rpx rgba(181, 123, 39, 0.22);
}

.action-loading-layer {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 9998;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.action-loading-card {
  width: 260rpx;
  min-height: 260rpx;
  background: transparent;
  box-shadow: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.action-loading-img {
  width: 230rpx;
  height: 230rpx;
}

.action-loading-text {
  margin-top: 4rpx;
  color: #6a4527;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.3;
}

