/* pages/settle/settle.wxss */
.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx; /* 为底部按钮留出空间 */
}

.settle-header {
  position: relative;
  background: #f5e7d5;
  padding-left: 30rpx;
  padding-right: 30rpx;
  box-sizing: content-box;
}

.settle-nav {
  position: relative;
  display: block;
}

.settle-nav-content {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  box-sizing: border-box;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  top: 0;
  width: 64rpx;
  height: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  color: #5f3d20;
  box-sizing: border-box;
}

.back-icon {
  position: relative;
  border-left-style: solid;
  border-bottom-style: solid;
  border-color: #5f3d20;
  transform: rotate(45deg);
  box-sizing: border-box;
  margin-top: 4rpx;
}

.settle-title {
  color: #5f3d20;
  font-weight: bold;
  line-height: 1;
  text-align: center;
  box-sizing: border-box;
  position: relative;
}

.section {
  background: white;
  margin-top: 20rpx;
  padding: 30rpx 0;
}

.section:first-child {
  margin-top: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
  letter-spacing: 0.5rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.section-title-wrapper .section-title {
  padding: 0;
  margin-bottom: 0;
}

.edit-order-btn {
  padding: 8rpx 24rpx;
  font-size: 26rpx;
  color: #e54d42;
  border: 2rpx solid #e54d42;
  border-radius: 8rpx;
  background: white;
}

/* 订单类型选择 */
.order-type-list {
  display: flex;
  padding: 0 30rpx;
  gap: 20rpx;
}

.order-type-item {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
  cursor: pointer;
  user-select: none;
}

.order-type-item.active {
  color: #e54d42;
  background: rgba(229, 77, 66, 0.1);
  border-color: #e54d42;
  font-weight: 600;
}

/* 桌码显示 */
.table-code-wrapper {
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.table-code-display {
  flex: 1;
  display: flex;
  align-items: center;
}

.table-code-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 12rpx;
}

.table-code-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.table-code-bold {
  font-weight: 600;
  font-size: 32rpx;
  color: #333;
}

.table-code-actions {
  margin-left: 20rpx;
}

.change-table-btn {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #e54d42;
  border: 2rpx solid #e54d42;
  border-radius: 8rpx;
  background: white;
  cursor: pointer;
  user-select: none;
}

/* 商品列表 */
.goods-list {
  padding: 0 30rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-item:active {
  background-color: #fafafa;
}

.goods-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
  overflow: hidden;
}

.goods-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 140rpx;
}

.goods-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.miandan-tip {
  width:190rpx;
  font-size: 22rpx;
  color: #ff6b6b;
  background: #fff3f0;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  display: inline-block;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
  border: 1rpx solid #ffe0e0;
  white-space: nowrap;
  box-sizing: border-box;
}

.goods-price-count {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.goods-price {
  font-size: 26rpx;
  color: #e54d42;
  font-weight: bold;
}

.goods-count {
  font-size: 24rpx;
  color: #999;
}

.goods-subtotal {
  font-size: 32rpx;
  color: #e54d42;
  font-weight: 600;
  min-width: 120rpx;
  text-align: right;
}

/* 价格信息 */
.price-info {
  padding: 0 30rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  font-size: 28rpx;
}

.price-item.total {
  font-size: 34rpx;
  font-weight: 600;
  border-top: 2rpx solid #f0f0f0;
  padding-top: 24rpx;
  margin-top: 12rpx;
}

.price-label {
  color: #666;
}

.price-value {
  color: #e54d42;
  font-weight: 600;
  font-size: 30rpx;
}

.price-item.total .price-value {
  font-size: 36rpx;
}

/* 支付方式卡片 */
.pay-method-list {
  padding: 0 30rpx;
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}

.pay-method-item {
  flex: 1;
  background: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  padding: 20rpx;
  transition: all 0.3s;
  min-width: 0;
}

.pay-method-item.active {
  background: rgba(229, 77, 66, 0.08);
  border-color: #e54d42;
}

.pay-method-item.disabled {
  opacity: 0.6;
  background: #f5f5f5;
}

.pay-method-item.disabled .pay-method-title {
  color: #999;
}

.pay-method-item.disabled .pay-method-desc {
  color: #ccc;
}

.pay-method-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.pay-method-left {
  width: 100%;
}

.pay-method-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.pay-method-item.active .pay-method-title {
  color: #e54d42;
  font-weight: 600;
}

.pay-method-desc {
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}

.pay-method-item.active .pay-method-desc {
  color: #666;
}

.pay-method-radio {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 12rpx;
}

.pay-method-radio.checked {
  border-color: #e54d42;
  background: #e54d42;
}

.radio-dot {
  width: 16rpx;
  height: 16rpx;
  background: white;
  border-radius: 50%;
}

/* 底部提交区域 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.footer-price {
  display: flex;
  align-items: baseline;
  flex: 1;
  min-width: 0;
}

.footer-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 12rpx;
}

.footer-price-num {
  font-size: 44rpx;
  color: #e54d42;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.submit-btn {
  width: 240rpx;
  min-width: 240rpx;
  max-width: 240rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  background-color: #e54d42;
  color: white;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(229, 77, 66, 0.3);
  transition: all 0.3s;
}

.submit-btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}

.submit-btn.disabled {
  background-color: #ccc;
  color: #999;
  box-shadow: none;
  opacity: 0.6;
}

.submit-btn.disabled:active {
  opacity: 0.6;
  transform: none;
}

/* Order detail redesign */
.page {
  background: #f5e7d5;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.order-card {
  margin: 26rpx 30rpx 0;
  padding: 8rpx 24rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 250, 241, 0.96);
  box-shadow: 0 12rpx 36rpx rgba(95, 61, 32, 0.14);
  box-sizing: border-box;
}

.order-card-header {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding: 18rpx 0 8rpx;
}

.order-card-title {
  color: #3d2a1b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.2;
}

.submit-success {
  margin: 24rpx 30rpx 0;
  padding: 24rpx 28rpx;
  border-radius: 22rpx;
  background: rgba(255, 250, 241, 0.9);
  border: 1rpx solid rgba(185, 138, 75, 0.24);
  box-shadow: 0 10rpx 28rpx rgba(95, 61, 32, 0.1);
  box-sizing: border-box;
}

.success-title {
  font-size: 34rpx;
  color: #5f3d20;
  font-weight: 700;
  line-height: 1.3;
}

.goods-list {
  padding: 0;
}

.goods-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(95, 61, 32, 0.08);
  transition: none;
}

.goods-item:last-child {
  border-bottom: none;
}

.goods-item:active {
  background-color: transparent;
}

.goods-image {
  width: 96rpx;
  height: 96rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  background: #f2e3cf;
}

.goods-info {
  flex: 1;
  min-width: 0;
  min-height: 96rpx;
  margin-left: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.goods-name {
  font-size: 28rpx;
  color: #3d2a1b;
  font-weight: 600;
  line-height: 1.35;
  margin-bottom: 0;
}

.goods-tags {
  display: block;
  margin-top: 8rpx;
  margin-bottom: 0;
}

.tag-text {
  display: block;
  max-width: 320rpx;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: #8c7b68;
  font-size: 22rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-count {
  width: 58rpx;
  flex-shrink: 0;
  text-align: right;
  font-size: 26rpx;
  color: #8c7b68;
}

.goods-subtotal {
  width: 128rpx;
  min-width: 0;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #c9852f;
  font-weight: 600;
  text-align: right;
}

.order-divider {
  height: 1rpx;
  margin: 18rpx 0;
  background: rgba(95, 61, 32, 0.1);
}

.order-total-divider {
  width: 100%;
  height: 1rpx;
  margin: 18rpx 0;
  background: rgba(95, 61, 32, 0.1);
}

.order-total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-total-label {
  font-size: 30rpx;
  color: #4b3524;
  font-weight: 600;
}

.order-total-price {
  font-size: 34rpx;
  color: #c9852f;
  font-weight: 700;
}

.order-count-row {
  text-align: right;
  font-size: 24rpx;
  color: #8c7b68;
}

.session-summary {
  margin: 22rpx 30rpx 0;
  padding: 24rpx 28rpx;
  border-radius: 22rpx;
  background: rgba(255, 250, 241, 0.86);
  border: 1rpx solid rgba(95, 61, 32, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 8rpx 22rpx rgba(95, 61, 32, 0.08);
  box-sizing: border-box;
}

.session-summary-label {
  color: #4b3524;
  font-size: 30rpx;
  font-weight: 700;
}

.session-summary-price {
  color: #c9852f;
  font-size: 36rpx;
  font-weight: 800;
}

.footer {
  background: rgba(245, 231, 213, 0.96);
  border-top: 1rpx solid rgba(95, 61, 32, 0.08);
  justify-content: center;
  box-shadow: 0 -8rpx 24rpx rgba(95, 61, 32, 0.08);
}

.submit-btn {
  width: 100%;
  min-width: 0;
  max-width: none;
  background-color: #b98a4b;
  box-shadow: 0 8rpx 20rpx rgba(185, 138, 75, 0.24);
}

.submit-btn.disabled {
  background-color: #d4c5b2;
  color: rgba(255, 255, 255, 0.72);
  box-shadow: none;
  opacity: 0.7;
}

.submit-btn.disabled:active {
  opacity: 0.7;
  transform: none;
}

.footer-action {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  box-sizing: border-box;
  transition: all 0.2s;
}

.footer-action:active {
  transform: scale(0.98);
}

.footer-action.primary {
  flex: 1.15;
  color: #fff;
  background: linear-gradient(135deg, #d6a24a 0%, #b8792f 100%);
  box-shadow: 0 8rpx 20rpx rgba(185, 138, 75, 0.26);
}

.footer-action.secondary {
  color: #6a4527;
  background: rgba(255, 250, 241, 0.9);
  border: 1rpx solid rgba(95, 61, 32, 0.18);
}

.submit-loading-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 9998;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.submit-loading-card {
  width: 260rpx;
  min-height: 260rpx;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.submit-loading-img {
  width: 230rpx;
  height: 230rpx;
}

.submit-loading-text {
  margin-top: 4rpx;
  color: #6a4527;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.3;
}
