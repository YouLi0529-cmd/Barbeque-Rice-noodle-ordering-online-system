<!--packages/order/pages/settle/settle.wxml-->
<wxs module="priceHelper" src="../../../../utils/priceHelper.wxs"></wxs>
<view class="page">
  <view class="settle-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="settle-nav" style="height: {{navBarHeight}}px;">
      <view class="settle-nav-content" style="top: {{navContentTop}}px; height: {{navContentHeight}}px;">
        <view class="back-btn" bindtap="editOrder">
          <view class="back-icon" style="width: {{navIconSize}}px; height: {{navIconSize}}px; border-width: {{navIconStroke}}px;"></view>
        </view>
        <view class="settle-title" style="font-size: {{navTitleFontSize}}px; line-height: {{navTitleFontSize}}px;">订单详情</view>
      </view>
    </view>
  </view>

  <view class="submit-success" wx:if="{{orderSubmitted}}">
    <view class="success-title">提交成功</view>
  </view>

  <view class="order-card" wx:for="{{orderCards}}" wx:for-item="card" wx:key="cardId">
    <view class="order-card-header">
      <view class="order-card-title">{{card.title}}</view>
    </view>
    <view class="goods-list">
      <view class="goods-item" wx:for="{{card.goods}}" wx:for-item="goods" wx:key="dishId">
        <image class="goods-image" src="{{goods.dishImage}}" mode="aspectFill"></image>
        <view class="goods-info">
          <view class="goods-name">{{goods.dishName}}</view>
          <view class="goods-tags" wx:if="{{goods.tagText}}">
            <text class="tag-text">{{goods.tagText}}</text>
          </view>
        </view>
        <view class="goods-count">×{{goods.count}}</view>
        <view class="goods-subtotal">¥{{goods.subtotal}}</view>
      </view>
      
      <van-empty wx:if="{{card.goods.length === 0}}" description="购物车为空" />
    </view>

    <view class="order-divider order-total-divider"></view>
    <view class="order-total-row">
      <view class="order-total-label">小计</view>
      <view class="order-total-price">¥{{priceHelper.formatPrice(card.finalPrice)}}</view>
    </view>
    <view class="order-divider order-total-divider"></view>
    <view class="order-count-row">共{{card.goodsCount}}件菜品</view>
  </view>

  <view class="session-summary" wx:if="{{orderCards.length > 1}}">
    <view class="session-summary-label">本次合计</view>
    <view class="session-summary-price">¥{{priceHelper.formatPrice(sessionTotalPrice)}}</view>
  </view>

  <!-- 底部提交按钮 -->
  <view class="footer">
    <view 
      wx:if="{{!orderSubmitted}}"
      class="submit-btn {{submitting || !canSubmit ? 'disabled' : ''}}"
      bind:tap="submitOrder">
      <text wx:if="{{submitting}}">提交中...</text>
      <text wx:else>提交订单</text>
    </view>
    <block wx:else>
      <view class="footer-action primary" bindtap="checkoutOrder">结账</view>
      <view class="footer-action secondary" bindtap="addMoreDishes">再加一点</view>
    </block>
  </view>

  <!-- 用户信息授权组件 -->
  <avatar-nickname-modal 
    showAvaModal="{{showAuthModal}}" 
    loadingGif="{{submitLoadingGif}}"
    bind:saved="onUserInfoSaved">
  </avatar-nickname-modal>

  <view class="submit-loading-mask" wx:if="{{submitting}}" catchtouchmove="catchSubmitLoadingMove">
    <view class="submit-loading-card">
      <image class="submit-loading-img" src="{{submitLoadingGif}}" mode="aspectFit"></image>
      <view class="submit-loading-text">下单中</view>
    </view>
  </view>
</view>
