.feedback-page {
  min-height: 100vh;
  background: #f7f4ef;
}

.feedback-header {
  position: relative;
  background: #f5e7d5;
  padding-left: 30rpx;
  padding-right: 30rpx;
  box-sizing: content-box;
}

.feedback-nav {
  position: relative;
}

.feedback-nav-content {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  box-sizing: border-box;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  top: 0;
  width: 64rpx;
  height: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.back-icon {
  border-left-style: solid;
  border-bottom-style: solid;
  border-color: #5f3d20;
  transform: rotate(45deg);
  box-sizing: border-box;
  margin-top: 4rpx;
}

.feedback-title {
  color: #5f3d20;
  font-weight: 700;
  text-align: center;
}

.feedback-content {
  padding: 38rpx 30rpx;
}

.feedback-card {
  min-height: 330rpx;
  padding: 26rpx 28rpx 22rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(82, 57, 35, 0.08);
  box-sizing: border-box;
}

.feedback-textarea {
  display: block;
  width: 100%;
  height: 252rpx;
  color: #3f3021;
  font-size: 29rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.feedback-placeholder {
  color: #b9ada1;
}

.feedback-count {
  color: #aa9c8e;
  font-size: 24rpx;
  text-align: right;
}

.feedback-submit {
  height: 88rpx;
  margin-top: 28rpx;
  padding: 0;
  border: 0;
  border-radius: 44rpx;
  background: #c99142;
  color: #ffffff;
  font-size: 30rpx;
  line-height: 1.2;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feedback-submit::after {
  border: 0;
}
