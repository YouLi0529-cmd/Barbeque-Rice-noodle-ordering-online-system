/* pages/about/about.wxss */
.about-page {
  min-height: 100vh;
  background: #f7f4ef;
}

.about-header {
  position: relative;
  background: #f5e7d5;
  padding-left: 30rpx;
  padding-right: 30rpx;
  box-sizing: content-box;
}

.about-nav {
  position: relative;
  display: block;
}

.about-nav-content {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  box-sizing: border-box;
}

.back-btn {
  position: absolute;
  left: 24rpx;
  top: 0;
  width: 64rpx;
  height: 100%;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  color: #5f3d20;
  box-sizing: border-box;
}

.back-icon {
  position: relative;
  border-left-style: solid;
  border-bottom-style: solid;
  border-color: #5f3d20;
  transform: rotate(45deg);
  box-sizing: border-box;
  margin-top: 4rpx;
}

.about-title {
  color: #5f3d20;
  font-weight: 700;
  line-height: 1;
  text-align: center;
  box-sizing: border-box;
  position: relative;
}

.about-content {
  padding: 36rpx 30rpx;
}

.policy-card {
  border-radius: 16rpx;
  background: #ffffff;
  padding: 0 30rpx;
  box-shadow: 0 6rpx 20rpx rgba(82, 57, 35, 0.08);
}

.policy-row {
  min-height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.policy-name {
  color: #3f3021;
  font-size: 30rpx;
  font-weight: 600;
}

.policy-actions {
  display: flex;
  align-items: center;
}

.revoke-action {
  padding: 14rpx 0 14rpx 24rpx;
  color: #a74834;
  font-size: 26rpx;
}

.policy-arrow {
  margin-left: 18rpx;
  color: #a49689;
  font-size: 42rpx;
  line-height: 1;
}

.revoke-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 42rpx;
  background: rgba(0, 0, 0, 0.48);
  box-sizing: border-box;
}

.revoke-dialog {
  width: 100%;
  padding: 38rpx 32rpx 30rpx;
  border-radius: 16rpx;
  background: #fffaf3;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.22);
  box-sizing: border-box;
}

.revoke-title {
  color: #3f3021;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
  text-align: center;
}

.revoke-content {
  margin-top: 24rpx;
  color: #6d5c4c;
  font-size: 25rpx;
  line-height: 1.75;
}

.revoke-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 32rpx;
}

.revoke-btn {
  flex: 1;
  height: 76rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.revoke-btn.confirm {
  border: 1rpx solid #dbcbb8;
  background: #ffffff;
  color: #a74834;
}

.revoke-btn.cancel {
  background: #e8bd63;
  color: #4a321c;
}

.logout-entry {
  margin-top: 28rpx;
  height: 92rpx;
  border: 1rpx solid #eadac7;
  border-radius: 12rpx;
  background: #ffffff;
  color: #a74834;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.logout-entry-hover {
  background: #fff8f1;
}
