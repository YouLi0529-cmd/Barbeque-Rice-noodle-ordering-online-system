/* pages/myorder/myorder.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f7ead8;
  padding-bottom: 144rpx;
  box-sizing: border-box;
}

.top-safe-bg {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  z-index: 20;
  background: #f5e7d5;
  pointer-events: none;
}

.order-page-header {
  position: relative;
  z-index: 21;
  background: #f5e7d5;
  padding-left: 30rpx;
  padding-right: 30rpx;
  text-align: center;
  box-sizing: content-box;
}

.order-page-nav {
  position: relative;
  display: block;
}

.order-page-nav-content {
  position: absolute;
  left: 0;
  right: 0;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  box-sizing: border-box;
}

.order-page-title {
  color: #5f3d20;
  font-weight: bold;
  line-height: 1;
  text-align: center;
  box-sizing: border-box;
  position: relative;
}

/* 标签栏 */
.tabs {
  background: #fffaf1;
  display: flex;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #ead6b8;
}

.tab-item {
  position: relative;
  flex: 1;
  text-align: center;
  padding: 30rpx 0;
}

.tab-text {
  font-size: 30rpx;
  color: #666;
  transition: all 0.3s;
}

.tab-item.active .tab-text {
  color: #5f3d20;
  font-weight: bold;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #d8b47e;
  border-radius: 3rpx;
}

/* 订单列表 */
.order-list {
  flex: 1;
  padding: 20rpx;
  padding-bottom: 164rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.order-item {
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

/* 订单头部 */
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #f5f5f5;
}

.user-info-text {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 5rpx;
}

.user-phone {
  font-size: 24rpx;
  color: #999;
}

.order-type {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.order-status {
  font-size: 26rpx;
  color: #e54d42;
  padding: 6rpx 20rpx;
  background: rgba(229, 77, 66, 0.1);
  border-radius: 20rpx;
}

.order-status.cancel {
  color: #999;
  background: #f5f5f5;
}

/* 订单内容 */
.order-content {
  padding: 30rpx;
}

/* 充值订单信息 */
.recharge-info {
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.recharge-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.recharge-item:last-child {
  margin-bottom: 0;
}

.recharge-label {
  font-size: 28rpx;
  color: #666;
}

.recharge-value {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.recharge-value.gift {
  color: #ff6b6b;
}

.recharge-value.total {
  color: #e54d42;
  font-size: 36rpx;
}

/* 点餐订单商品列表 */
.goods-list {
  margin-bottom: 20rpx;
}

.goods-item {
  display: flex;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.goods-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 10rpx;
}

/* 商品标签 */
.goods-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.tag-text {
  font-size: 22rpx;
  color: #e54d42;
  background: rgba(229, 77, 66, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid rgba(229, 77, 66, 0.3);
}

.goods-detail {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 28rpx;
  color: #e54d42;
  font-weight: bold;
}

.goods-count {
  font-size: 26rpx;
  color: #999;
}

/* 免单标识 */
.miandan-tag {
  background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 100%);
  color: white;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
  margin-top: 10rpx;
}

/* 订单底部 */
.order-footer {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f5f5f5;
  text-align: right;
}

.order-info {
  text-align: right;
  margin-bottom: 15rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.order-table-code {
  font-size: 24rpx;
  color: #38b2ac;
  font-weight: 500;
}

.order-actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.order-price {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 26rpx;
  color: #666;
}

.price-num {
  font-size: 36rpx;
  color: #e54d42;
  font-weight: bold;
  margin-left: 10rpx;
}

.action-btns {
  display: flex;
  gap: 15rpx;
}

.action-btn {
  padding: 12rpx 30rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  text-align: center;
}

.action-btn.detail {
  background: #f5f5f5;
  color: #666;
}

.action-btn.cancel {
  background: rgba(229, 77, 66, 0.1);
  color: #e54d42;
}

/* 空状态 */
.empty-order {
  min-height: 62vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx 120rpx;
  box-sizing: border-box;
}

.empty-order-image {
  width: 620rpx;
  height: 620rpx;
  display: block;
}

.cover-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  height: 144rpx;
  border-top: 2rpx solid rgba(225, 195, 157, 0.9);
  background: rgba(235, 208, 171, 0.96);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  box-shadow: 0 -10rpx 28rpx rgba(95, 61, 32, 0.12);
}

.cover-tab {
  color: #684626;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-tab.active {
  color: #4f321a;
  background: rgba(225, 195, 157, 0.72);
}

.btn-hover {
  opacity: 0.86;
}

.action-loading-layer {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 9998;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.action-loading-card {
  width: 260rpx;
  min-height: 260rpx;
  background: transparent;
  box-shadow: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.action-loading-img {
  width: 230rpx;
  height: 230rpx;
}

.action-loading-text {
  margin-top: 4rpx;
  color: #6a4527;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.3;
}

.order-list {
  flex: 1;
  padding: 24rpx 24rpx 168rpx;
  box-sizing: border-box;
  overflow-y: auto;
  background: #f7ead8;
}

.order-card {
  position: relative;
  margin-bottom: 22rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: rgba(255, 250, 241, 0.98);
  border: 1rpx solid rgba(210, 170, 112, 0.42);
  box-shadow: 0 12rpx 30rpx rgba(95, 61, 32, 0.09);
  box-sizing: border-box;
}

.order-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.order-card-meta {
  min-width: 0;
  flex: 1;
}

.order-label {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 38rpx;
  padding: 0 14rpx;
  border: 1rpx solid rgba(174, 126, 60, 0.62);
  border-radius: 6rpx;
  color: #735026;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  background: rgba(255, 246, 231, 0.84);
}

.order-time {
  margin-top: 12rpx;
  color: #9b8567;
  font-size: 23rpx;
  line-height: 1.2;
}

.order-card-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: flex-start;
  min-width: 190rpx;
}

.delete-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.trash-icon {
  position: relative;
  width: 24rpx;
  height: 25rpx;
  border: 3rpx solid #9b7650;
  border-top: 0;
  border-radius: 0 0 6rpx 6rpx;
  box-sizing: border-box;
}

.trash-icon::before {
  content: "";
  position: absolute;
  left: -6rpx;
  top: -8rpx;
  width: 30rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #9b7650;
}

.trash-icon::after {
  content: "";
  position: absolute;
  left: 5rpx;
  top: -14rpx;
  width: 10rpx;
  height: 6rpx;
  border: 3rpx solid #9b7650;
  border-bottom: 0;
  border-radius: 6rpx 6rpx 0 0;
  box-sizing: border-box;
}

.order-status {
  margin-top: 8rpx;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  font-weight: 700;
  white-space: nowrap;
}

.status-saved {
  color: #9a7042;
  background: rgba(218, 182, 126, 0.18);
}

.status-submitted {
  color: #9b5f16;
  background: rgba(235, 185, 83, 0.2);
}

.status-done {
  color: #587445;
  background: rgba(123, 154, 92, 0.18);
}

.status-cancel {
  color: #9a8d7d;
  background: rgba(174, 160, 143, 0.16);
}

.dish-preview-list {
  position: relative;
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 28rpx;
  padding: 20rpx 0 18rpx;
  border-top: 1rpx solid rgba(213, 185, 145, 0.34);
  border-bottom: 1rpx solid rgba(213, 185, 145, 0.34);
}

.dish-preview {
  width: 142rpx;
  min-width: 0;
}

.dish-preview-img,
.dish-preview-fallback {
  width: 142rpx;
  height: 112rpx;
  border-radius: 12rpx;
  background: #f1dfc6;
  box-shadow: inset 0 0 0 1rpx rgba(165, 126, 76, 0.12);
}

.dish-preview-img {
  display: block;
}

.dish-preview-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8d6333;
  font-size: 42rpx;
  font-weight: 700;
}

.dish-preview-name {
  margin-top: 10rpx;
  color: #5f3d20;
  font-size: 23rpx;
  line-height: 1.25;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-more {
  align-self: flex-start;
  width: 42rpx;
  height: 112rpx;
  margin-left: -4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
}

.dish-more-square {
  width: 8rpx;
  height: 8rpx;
  border-radius: 2rpx;
  background: rgba(145, 103, 54, 0.58);
}

.order-summary-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 18rpx;
}

.summary-spacer {
  flex: 1;
}

.summary-text {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
  gap: 16rpx;
  color: #8d7657;
  font-size: 24rpx;
  font-weight: 600;
}

.summary-price {
  color: #c88824;
  font-size: 34rpx;
  font-weight: 800;
}

.order-table-row {
  margin-top: 16rpx;
  color: #7d6140;
  font-size: 24rpx;
  font-weight: 600;
}
