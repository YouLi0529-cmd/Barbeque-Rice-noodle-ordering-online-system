<!--packages/user/pages/myorder/myorder.wxml-->
<view class="page">
  <view class="order-page-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="order-page-nav" style="height: {{navBarHeight}}px;">
      <view class="order-page-nav-content" style="top: {{navContentTop}}px; height: {{navContentHeight}}px;">
        <view class="order-page-title" style="font-size: {{navTitleFontSize}}px; line-height: {{navTitleFontSize}}px;">我的订单</view>
      </view>
    </view>
  </view>

  <!-- 顶部标签栏 -->
  <view class="tabs">
    <view 
      class="tab-item {{currentTab === tabIndex ? 'active' : ''}}"
      wx:for="{{tabs}}"
      wx:for-index="tabIndex"
      wx:key="*this"
      bindtap="switchTab"
      data-index="{{tabIndex}}">
      <text class="tab-text">{{item}}</text>
      <view class="tab-line" wx:if="{{currentTab === tabIndex}}"></view>
    </view>
  </view>

  <!-- 订单摘要列表 -->
  <view class="order-list">
    <view
      class="order-card"
      wx:for="{{orderList}}"
      wx:for-item="order"
      wx:key="_id"
      bindtap="viewOrderDetail"
      data-order="{{order}}">
      <view class="order-card-top">
        <view class="order-card-meta">
          <view class="order-label">点餐单</view>
          <view class="order-time">{{order.createTimeText}}</view>
        </view>
        <view class="order-card-actions">
          <view class="delete-btn" catchtap="deleteOrder" data-order="{{order}}">
            <view class="trash-icon"></view>
          </view>
          <view class="order-status {{order.statusClass}}">{{order.statusText}}</view>
        </view>
      </view>

      <view class="dish-preview-list">
        <view
          class="dish-preview"
          wx:for="{{order.previewGoods}}"
          wx:for-item="goods"
          wx:key="previewKey">
          <image wx:if="{{goods.dishImage}}" class="dish-preview-img" src="{{goods.dishImage}}" mode="aspectFill"></image>
          <view wx:else class="dish-preview-fallback">{{goods.shortName}}</view>
          <view class="dish-preview-name">{{goods.dishName}}</view>
        </view>
        <view class="dish-more" wx:if="{{order.hasMoreGoods}}">
          <view class="dish-more-square"></view>
          <view class="dish-more-square"></view>
          <view class="dish-more-square"></view>
        </view>
      </view>

      <view class="order-summary-row">
        <view class="summary-spacer"></view>
        <view class="summary-text">
          <text>共{{order.goodsCount}}件菜品</text>
          <text class="summary-price">¥{{order.finalPriceText}}</text>
        </view>
      </view>

      <view class="order-table-row" wx:if="{{order.tableNumberText}}">
        <text>{{order.tableNumberText}}</text>
      </view>
    </view>
    <view class="empty-order" wx:if="{{orderList.length === 0}}">
      <image class="empty-order-image" src="/packages/user/images/meidingdan-transparent.png" mode="aspectFit"></image>
    </view>
  </view>

  <view class="action-loading-layer" wx:if="{{actionLoading}}" catchtouchmove="catchActionLoadingMove">
    <view class="action-loading-card">
      <image class="action-loading-img" src="{{actionLoadingGif}}" mode="aspectFit"></image>
      <view class="action-loading-text">{{actionLoadingText}}</view>
    </view>
  </view>

  <view class="cover-tabbar">
    <view class="cover-tab" hover-class="btn-hover" bindtap="goCover">
      <text>首页</text>
    </view>
    <view class="cover-tab active" hover-class="btn-hover" bindtap="goMyOrder">
      <text>订单</text>
    </view>
    <view class="cover-tab" hover-class="btn-hover" bindtap="goMyHome">
      <text>我的</text>
    </view>
  </view>
</view>
