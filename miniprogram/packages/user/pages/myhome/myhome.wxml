<!--packages/user/pages/myhome/myhome.wxml-->
<view class="page">
  <view class="top-safe-bg" style="height: {{statusBarHeight}}px;"></view>
  <view class="my-page-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="my-page-nav" style="height: {{navBarHeight}}px;">
      <view class="my-page-nav-content" style="top: {{navContentTop}}px; height: {{navContentHeight}}px;">
        <view class="my-page-title" style="font-size: {{navTitleFontSize}}px; line-height: {{navTitleFontSize}}px;">我的</view>
      </view>
    </view>
  </view>

  <!-- 用户头部（统一布局） -->
  <view class="user-header">
    <view class="member-card">
      <view class="card-shine"></view>
      <view class="card-top">
        <view class="user-detail">
          <view class="user-name">
              {{userInfo && userInfo.nickName ? userInfo.nickName : '会员'}}
          </view>
          <view class="user-phone" wx:if="{{userInfo && userInfo.phoneNumber}}">
            {{userInfo.phoneNumber}}
          </view>
          <view class="user-phone login-prompt-text" wx:else bindtap="showAuthModal">
            请先完善个人信息
          </view>
        </view>
      </view>
      <view class="card-mark">ZN</view>
      <view class="member-code-block" wx:if="{{userInfo && userInfo.userCode}}">
        <view class="member-code">{{userInfo.userCode}}</view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <!-- <view class="menu-section">
    <van-grid column-num="2" border="{{false}}" custom-class="service-grid">
      <van-grid-item custom-class="service-item">
        <button class="service-btn" open-type="contact">
          <view class="service-icon">💬</view>
          <view class="service-text">联系客服</view>
        </button>
      </van-grid-item>
      <van-grid-item custom-class="service-item">
        <button class="service-btn" open-type="contact">
          <view class="service-icon">📞</view>
          <view class="service-text">在线咨询</view>
        </button>
      </van-grid-item>
    </van-grid>
  </view> -->

  <!-- 管理员入口触发区域（隐藏在右下角） -->
  <view class="profile-menu">
    <view class="profile-menu-item" hover-class="menu-hover" bindtap="goAbout">
      <view class="menu-icon">›</view>
      <view class="menu-title">关于</view>
      <view class="menu-arrow">›</view>
    </view>
  </view>

  <view class="admin-trigger" bindtap="onAdminTrigger"></view>

  <!-- 密码输入弹窗 -->
  <view class="modal-mask" wx:if="{{showPasswordModal}}" catchtap="noop">
    <view class="modal-dialog" catchtap="stopPropagation">
      <view class="modal-title">{{isFirstTime ? '设置管理员密码' : '管理员登录'}}</view>
      <view class="modal-content">
        <input 
          class="password-input" 
          type="password" 
          placeholder="{{isFirstTime ? '请设置管理员密码（至少6位）' : '请输入管理员密码'}}" 
          value="{{adminPassword}}"
          bindinput="onPasswordInput"
        />
        <view class="password-hint" wx:if="{{isFirstTime}}">
          首次设置，请设置一个安全的密码
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="closePasswordModal">取消</view>
        <view class="modal-btn confirm" bindtap="verifyPassword">{{isFirstTime ? '设置' : '登录'}}</view>
      </view>
    </view>
  </view>

  <!-- 用户信息授权组件 -->
  <avatar-nickname-modal 
    showAvaModal="{{showAuthModal}}" 
    loadingGif="{{actionLoadingGif}}"
    bind:saved="onUserInfoSaved"
    bind:closed="onAuthModalClosed">
  </avatar-nickname-modal>

  <view class="action-loading-layer" wx:if="{{actionLoading}}" catchtouchmove="catchActionLoadingMove">
    <view class="action-loading-card">
      <image class="action-loading-img" src="{{actionLoadingGif}}" mode="aspectFit"></image>
      <view class="action-loading-text">{{actionLoadingText}}</view>
    </view>
  </view>

  <!-- 版本号显示 -->
  <view class="version-info">
    <text class="version-text">版本号：{{version}}</text>
  </view>
  <view class="cover-tabbar">
    <view class="cover-tab" hover-class="btn-hover" bindtap="goCover">
      <text>首页</text>
    </view>
    <view class="cover-tab" hover-class="btn-hover" bindtap="goMyOrder">
      <text>订单</text>
    </view>
    <view class="cover-tab active" hover-class="btn-hover" bindtap="goMyHome">
      <text>我的</text>
    </view>
  </view>
</view>
