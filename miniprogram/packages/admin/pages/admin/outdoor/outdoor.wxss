  border-radius: 999rpx;
  color: #8A4B18;
  background: #FFF2D3;
  text-align: center;
  line-height: 20rpx;
  font-size: 9rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.table-meta-row {
  margin-top: 6rpx;
  min-width: 0;
  color: rgba(58, 36, 24, 0.56);
  font-size: 9rpx;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
}

.empty-bill {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-title {
  color: rgba(58, 36, 24, 0.72);
  font-size: 12rpx;
  font-weight: 900;
}

.bill-groups {
  flex: 1;
  min-height: 0;
  height: 0;
  box-sizing: border-box;
}

.bill-group {
  padding: 7rpx 0;
}

.dish-group-title {
  margin: 4rpx 5rpx 3rpx;
  padding-left: 6rpx;
  color: #8A5526;
  font-size: 9rpx;
  font-weight: 900;
  line-height: 16rpx;
  border-left: 3rpx solid rgba(177, 91, 24, 0.56);
  background: linear-gradient(90deg, rgba(255, 242, 211, 0.88), rgba(255, 247, 236, 0));
  border-radius: 4rpx;
  box-sizing: border-box;
}

.dish-row {
  min-height: 24rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 30rpx 58rpx;
  gap: 6rpx;
  padding: 4rpx 5rpx;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.dish-row-active {
  background: #FFF2D3;
  box-shadow: inset 0 0 0 1rpx rgba(189, 123, 35, 0.3);
}

.dish-main {
  min-width: 0;
}

.dish-name {
  display: flex;
  align-items: baseline;
  min-width: 0;
  color: #2C1A12;
  font-size: 10rpx;
  font-weight: 900;
}

.dish-name-text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-sent-tag {
  flex: 0 0 auto;
  margin-left: 4rpx;
  color: rgba(138, 85, 38, 0.72);
  font-size: 7rpx;
  font-weight: 800;
}

.dish-paid-tag {
  flex: 0 0 auto;
  margin-left: 4rpx;
  color: rgba(116, 103, 94, 0.72);
  font-size: 7rpx;
  font-weight: 800;
}

.dish-tags {
  margin-top: 2rpx;
  color: rgba(58, 36, 24, 0.46);
  font-size: 8rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-count {
  color: rgba(58, 36, 24, 0.58);
  font-size: 9rpx;
  font-weight: 900;
  text-align: center;
}

.dish-price {
  color: #B15B18;
  font-size: 9rpx;
  font-weight: 900;
  text-align: right;
  white-space: nowrap;
}

.bill-summary-footer {
  height: 26rpx;
  flex: none;
  justify-content: space-between;
  border-top: 1rpx solid rgba(58, 36, 24, 0.08);
  color: rgba(58, 36, 24, 0.62);
  font-size: 10rpx;
  font-weight: 900;
}

.summary-total-price {
  color: #B15B18;
  font-size: 12rpx;
  font-weight: 900;
}

.bill-total {
  height: 26rpx;
  flex: none;
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr) 42rpx;
  gap: 6rpx;
  border-top: 1rpx solid rgba(58, 36, 24, 0.08);
  color: rgba(58, 36, 24, 0.64);
  font-size: 10rpx;
  font-weight: 900;
}

.total-area {
  justify-content: center;
  min-width: 0;
}

.mini-send-kitchen,
.mini-refresh,
.operation-btn,
.pay-option,
.checkout-btn {
  margin: 0;
  padding: 0;
  border: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  overflow: hidden;
}

.mini-send-kitchen::after,
.mini-refresh::after,
.operation-btn::after,
.pay-option::after,
.checkout-btn::after {
  border: 0;
}

.mini-send-kitchen,
.mini-refresh {
  height: 18rpx;
  border-radius: 999rpx;
  font-size: 9rpx;
  font-weight: 900;
  line-height: 18rpx;
}

.mini-refresh {
  width: 42rpx;
  color: #6B4B34;
  background: #FFF7EC;
}

.mini-send-kitchen {
  width: 64rpx;
  color: #FFF7EC;
  background: #B15B18;
  font-size: 8rpx;
}

.dish-action-strip {
  padding: 5rpx 3rpx;
}

.strip-title {
  margin-bottom: 4rpx;
  color: rgba(58, 36, 24, 0.62);
  font-size: 8rpx;
  font-weight: 900;
  text-align: center;
}

.operation-btn {
  width: 100%;
  min-height: 18rpx;
  margin-bottom: 3rpx;
  border-radius: 5rpx;
  color: #4B2B18;
  background: #FFF2D3;
  font-size: 8rpx;
  font-weight: 900;
  line-height: 18rpx;
  border: 1rpx solid rgba(177, 91, 24, 0.16);
}

.pay-panel {
  display: flex;
  flex-direction: column;
  padding: 10rpx;
}

.pay-section {
  margin-top: 10rpx;
}

.pay-section-title,
.summary-title {
  color: rgba(58, 36, 24, 0.62);
  font-size: 9rpx;
  font-weight: 900;
}

.option-row {
  margin-top: 6rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 5rpx;
}

.pay-option {
  height: 24rpx;
  border-radius: 6rpx;
  color: #5B351E;
  background: #FFF7EC;
  font-size: 8rpx;
  font-weight: 900;
  line-height: 24rpx;
  border: 1rpx solid rgba(58, 36, 24, 0.1);
}

.pay-option-active {
  color: #2C1A12;
  background: #F5D58B;
  border-color: rgba(177, 91, 24, 0.32);
}

.summary-card {
  margin-top: 12rpx;
  padding: 9rpx;
  border-radius: 9rpx;
  background: #FFF7EC;
  border: 1rpx solid rgba(58, 36, 24, 0.08);
}

.summary-row {
  height: 24rpx;
  color: rgba(58, 36, 24, 0.62);
  font-size: 9rpx;
  font-weight: 800;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.06);
}

.discount-summary-label {
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}

.summary-row:last-child {
  border-bottom: 0;
}

.strong-row {
  color: #2C1A12;
  font-size: 11rpx;
  font-weight: 900;
}

.discount-summary-text {
  color: #B15B18;
  font-size: 8rpx;
  font-weight: 900;
}

.checkout-btn {
  height: 38rpx;
  margin-top: 8rpx;
  border-radius: 10rpx;
  color: #FFF7EC;
  background: #B15B18;
  font-size: 11rpx;
  font-weight: 900;
  line-height: 38rpx;
  box-shadow: 0 5rpx 12rpx rgba(177, 91, 24, 0.2);
}

.return-all-btn {
  height: 32rpx;
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9rpx;
  color: #5B351E;
  background: #FFF2D3;
  font-size: 10rpx;
  font-weight: 900;
  line-height: 1;
  border: 1rpx solid rgba(177, 91, 24, 0.22);
}

.discount-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.42);
}

.discount-dialog {
  width: 300rpx;
  padding: 16rpx;
  border-radius: 10rpx;
  background: #FFF7EC;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.2);
  box-sizing: border-box;
}

.discount-title {
  color: #2C1A12;
  font-size: 13rpx;
  font-weight: 900;
}

.discount-input {
  width: 100%;
  height: 34rpx;
  margin-top: 12rpx;
  padding: 0 10rpx;
  border-radius: 8rpx;
  background: #FFFFFF;
  color: #2C1A12;
  font-size: 12rpx;
  box-sizing: border-box;
}

.discount-actions {
  margin-top: 14rpx;
  display: flex;
  gap: 10rpx;
}

.discount-action {
  flex: 1;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  font-size: 10rpx;
  font-weight: 900;
}

.discount-action.cancel {
  color: #6B4B34;
  background: #FFFFFF;
}

.discount-action.confirm {
  color: #2C1A12;
  background: #F1C46B;
}

/* Keep the order cards compact so detail gets most of the landscape space. */
.outdoor-page {
  grid-template-columns: 260rpx minmax(0, 1fr);
}

.outdoor-page .search-row {
  grid-template-columns: minmax(0, 1fr) 36rpx 36rpx;
  gap: 5rpx;
}

.outdoor-page .search-btn,
.outdoor-page .clear-btn {
  font-size: 8rpx;
}

.outdoor-page .order-card {
  width: 100%;
  height: auto;
  min-height: 84rpx;
  margin: 0 0 8rpx;
  padding: 9rpx 10rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 7rpx;
}

.outdoor-page .order-card-head,
.outdoor-page .order-card-meta,
.outdoor-page .order-card-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  min-width: 0;
}

.outdoor-page .order-no {
  flex: 1;
  min-width: 0;
  font-size: 14rpx;
  line-height: 1.15;
}

.outdoor-page .order-status {
  flex: none;
  max-width: 58rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.outdoor-page .order-card-meta {
  color: rgba(58, 36, 24, 0.54);
  font-size: 8rpx;
  font-weight: 800;
  line-height: 1;
}

.outdoor-page .order-card-meta text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.outdoor-page .order-card-foot {
  color: rgba(58, 36, 24, 0.62);
  font-size: 9rpx;
  font-weight: 900;
}

.outdoor-page .order-price {
  font-size: 13rpx;
}

/* Compact order tabs, close to table-card scale. */
.outdoor-page {
  grid-template-columns: 170rpx minmax(0, 1fr);
}

.outdoor-page .search-row {
  height: 38rpx;
  padding: 6rpx;
  grid-template-columns: minmax(0, 1fr) 30rpx 30rpx;
  gap: 4rpx;
}

.outdoor-page .search-input {
  height: 26rpx;
  padding: 0 7rpx;
  font-size: 8rpx;
}

.outdoor-page .search-btn,
.outdoor-page .clear-btn {
  height: 26rpx;
  line-height: 26rpx;
  font-size: 7rpx;
}

.outdoor-page .order-list {
  padding: 6rpx;
}

.outdoor-page .order-card {
  width: calc(100% - 8rpx);
  min-height: 60rpx;
  margin-bottom: 6rpx;
  padding: 5rpx 6rpx;
  gap: 3rpx;
  border-radius: 8rpx;
  box-shadow:
    0 8rpx 18rpx rgba(58, 36, 24, 0.16),
    0 2rpx 4rpx rgba(58, 36, 24, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.42);
}

.outdoor-page .order-card-head,
.outdoor-page .order-card-meta,
.outdoor-page .order-card-foot {
  gap: 4rpx;
}

.outdoor-page .order-no {
  font-size: 10rpx;
}

.outdoor-page .order-status {
  max-width: 44rpx;
  padding: 1rpx 4rpx;
  font-size: 7rpx;
}

.outdoor-page .order-card-meta {
  font-size: 6rpx;
}

.outdoor-page .order-card-foot {
  font-size: 7rpx;
}

.outdoor-page .order-price {
  font-size: 9rpx;
}

/* Give order detail more room than payment on the merged outdoor page. */
.outdoor-workspace {
  grid-template-columns: minmax(0, 1fr) 250rpx;
}

.bill-total {
  grid-template-columns: 64rpx minmax(0, 1fr);
}

/* Outdoor list tools: no dark header, search on top and actions below. */
.outdoor-tools {
  flex: none;
  padding: 7rpx;
  background: #FFF7EC;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.outdoor-tools .search-input {
  width: 100%;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #2C1A12;
  font-size: 8rpx;
  box-sizing: border-box;
}

.tool-actions {
  margin-top: 6rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 5rpx;
}

.tool-btn {
  height: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #5B351E;
  background: #FFFFFF;
  border: 1rpx solid rgba(177, 91, 24, 0.14);
  font-size: 8rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.tool-btn.search-btn {
  color: #2C1A12;
  background: #F1C46B;
}

.tool-btn.refresh-btn,
.tool-btn.clear-btn {
  color: rgba(58, 36, 24, 0.68);
}
