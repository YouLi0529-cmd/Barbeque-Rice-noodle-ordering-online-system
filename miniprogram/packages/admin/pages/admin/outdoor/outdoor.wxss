  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #2C1A12;
  background: #F1C46B;
  font-size: 12rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.empty-text,
.empty-goods,
.detail-empty {
  color: rgba(58, 36, 24, 0.46);
  text-align: center;
  font-size: 13rpx;
}

.empty-text {
  padding: 60rpx 20rpx;
}

.empty-goods {
  padding: 80rpx 20rpx;
}

.detail-empty {
  flex: 1;
