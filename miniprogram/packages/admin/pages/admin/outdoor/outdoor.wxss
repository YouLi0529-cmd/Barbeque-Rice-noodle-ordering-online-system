/* Merged outdoor order workspace */
.outdoor-page {
  width: 100vw;
  height: 100vh;
  padding: 8rpx;
  display: grid;
  grid-template-columns: 330rpx minmax(0, 1fr);
  gap: 8rpx;
  color: #3A2418;
  background: #FFF7EC;
  box-sizing: border-box;
  overflow: hidden;
}

.outdoor-left,
.order-panel,
.dish-action-strip,
.pay-panel {
  min-width: 0;
  height: 100%;
  border-radius: 10rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(58, 36, 24, 0.08);
  box-shadow: 0 5rpx 14rpx rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.outdoor-left {
  width: auto;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.outdoor-workspace {
  min-width: 0;
  height: 100%;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 300rpx;
  gap: 8rpx;
  overflow: hidden;
}

.bill-shell {
  min-width: 0;
  height: 100%;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 62rpx;
  gap: 8rpx;
  overflow: hidden;
}

.outdoor-header {
  width: auto;
  height: 62rpx;
  flex: none;
  padding: 10rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  border-radius: 0;
  background: #1E1714;
  color: #FFF7EC;
  box-sizing: border-box;
}

.outdoor-title {
  font-size: 18rpx;
  line-height: 1;
  font-weight: 900;
}

.outdoor-subtitle {
  margin-top: 6rpx;
  color: rgba(255, 247, 236, 0.68);
  font-size: 9rpx;
  line-height: 1;
  font-weight: 800;
}

.outdoor-header .header-btn {
  width: 56rpx;
  min-width: 56rpx;
  height: 28rpx;
  line-height: 28rpx;
  border-radius: 999rpx;
  color: #2C1A12;
  background: #F1C46B;
  font-size: 10rpx;
  font-weight: 900;
}

.outdoor-page .search-row {
  width: auto;
  height: 44rpx;
  flex: none;
  padding: 8rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 42rpx 42rpx;
  align-items: center;
  gap: 6rpx;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.08);
  background: #FFFFFF;
  box-sizing: border-box;
}

.outdoor-page .search-input {
  min-width: 0;
  height: 28rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #FFF7EC;
  color: #2C1A12;
  font-size: 10rpx;
  box-sizing: border-box;
}

.outdoor-page .search-btn,
.outdoor-page .clear-btn {
  width: auto;
  height: 28rpx;
  line-height: 28rpx;
  border-radius: 999rpx;
  font-size: 9rpx;
  font-weight: 900;
}

.outdoor-page .order-list {
  width: auto;
  height: auto;
  flex: 1;
  min-height: 0;
  padding: 8rpx;
  box-sizing: border-box;
}

.outdoor-page .order-card {
  width: auto;
  height: 36rpx;
  min-height: 0;
  margin: 0 0 6rpx;
  padding: 0 8rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 112rpx;
  align-items: center;
  gap: 8rpx;
  vertical-align: initial;
  border-radius: 7rpx;
  background: #FFFBF4;
  border: 1rpx solid rgba(177, 91, 24, 0.1);
  box-shadow:
    0 5rpx 12rpx rgba(58, 36, 24, 0.1),
    0 1rpx 4rpx rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.outdoor-page .order-card:nth-child(3n) {
  margin-right: 0;
}

.outdoor-page .order-card.active {
  border-color: rgba(177, 91, 24, 0.48);
  background: #FFF1DC;
}

.order-main,
.order-side,
.bill-title-row,
.table-meta-row,
