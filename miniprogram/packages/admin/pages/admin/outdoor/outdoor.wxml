<!-- packages/admin/pages/admin/outdoor/outdoor.wxml -->
<view class="outdoor-page">
  <view class="outdoor-left">
    <view class="outdoor-tools">
      <input class="search-input" placeholder="{{ui.searchPlaceholder}}" value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" bindconfirm="doSearch" />
      <view class="tool-actions">
        <view class="tool-btn refresh-btn" bindtap="loadList">{{ui.refresh}}</view>
        <view class="tool-btn clear-btn" bindtap="clearSearch">{{ui.clear}}</view>
        <view class="tool-btn search-btn" bindtap="doSearch">{{ui.search}}</view>
      </view>
    </view>

    <scroll-view class="order-list" scroll-y>
      <view
        class="order-card {{selectedOrderId === item._id ? 'active' : ''}}"
        wx:for="{{list}}"
        wx:key="_id"
        bindtap="selectOrder"
        data-id="{{item._id}}"
      >
        <view class="order-card-head">
          <view class="order-no">{{item._displayTitle}}</view>
          <view class="order-status status-{{item._statusClass}}">{{item._displayStatus}}</view>
        </view>
        <view class="order-card-meta">
          <text>{{item._outdoorPointText}}</text>
          <text>{{item._createTimeText}}</text>
        </view>
        <view class="order-card-foot">
          <text>{{item._goodsCountText}}</text>
          <text class="order-price">{{item._priceText}}</text>
        </view>
      </view>

      <view class="empty-text" wx:if="{{!loading && list.length === 0}}">{{ui.empty}}</view>
      <view class="empty-text" wx:if="{{loading}}">{{ui.loading}}</view>
    </scroll-view>
  </view>

  <view class="outdoor-workspace">
    <view class="bill-shell">
      <view class="order-panel">
        <view class="bill-top" wx:if="{{selectedOrder}}">
          <view class="bill-title-row">
            <view class="panel-title">{{orderTitle}}</view>
            <view class="status-pill status-{{statusClass}}">{{statusText}}</view>
          </view>
          <view class="table-meta-row">
            <text>{{outdoorPointText}}</text>
          </view>
        </view>

        <view class="kitchen-failure-banner" wx:if="{{selectedOrder && hasKitchenPrintFailure}}">
          <view class="kitchen-failure-copy">
            <view class="kitchen-failure-title">{{ui.kitchenPrintFailed}}</view>
            <view class="kitchen-failure-dishes">{{ui.failedDishesPrefix}}{{kitchenFailedDishText}}</view>
          </view>
          <view
            class="kitchen-failure-retry {{retryingKitchen ? 'kitchen-failure-retry-disabled' : ''}}"
            catchtap="retryFailedKitchenItems"
          >{{ui.retryFailedKitchen}}</view>
        </view>

        <view class="empty-bill" wx:if="{{loading}}">
          <view class="empty-title">{{ui.loading}}</view>
        </view>

        <view class="empty-bill" wx:elif="{{!selectedOrder}}">
          <view class="empty-title">{{ui.selectTip}}</view>
        </view>

        <scroll-view class="bill-groups" scroll-y wx:else>
          <view class="bill-group">
            <view wx:for="{{goodsList}}" wx:key="key">
              <view class="dish-group-title" wx:if="{{item.showGroupTitle}}">{{item.groupTitle}}</view>
              <view
                class="dish-row {{item.selected ? 'dish-row-active' : ''}}"
                data-key="{{item.key}}"
                bindtap="toggleGoodsSelection"
              >
                <view class="dish-main">
                  <view class="dish-name">
                    <text class="dish-paid-tag" wx:if="{{item.isPaid}}">{{ui.paidItem}}</text>
                    <text class="dish-name-text">{{item.name}}</text>
                    <text class="dish-sent-tag" wx:if="{{item.kitchenSent}}">{{ui.sentToKitchen}}</text>
                  </view>
                  <view class="dish-tags" wx:if="{{item.optionText}}">{{item.optionText}}</view>
                  <view class="dish-print-error" wx:if="{{item.kitchenFailed}}">{{ui.kitchenPrintFailed}}</view>
                </view>
                <view class="dish-count">x{{item.count}}</view>
                <view class="dish-price">{{ui.moneySymbol}}{{item.subtotalText}}</view>
              </view>
            </view>
          </view>
        </scroll-view>

        <view class="bill-summary-footer" wx:if="{{selectedOrder && !loading}}">
          <text>{{goodsCountText}}</text>
          <text class="summary-total-price">{{ui.moneySymbol}}{{totalPriceText}}</text>
        </view>

        <view class="bill-total">
          <view class="mini-send-kitchen" bindtap="sendKitchen">{{ui.sendKitchen}}</view>
          <view class="total-area"></view>
        </view>
      </view>

      <view class="dish-action-strip">
        <view class="strip-title">{{ui.orderActions}}</view>
        <view
          class="operation-btn"
          wx:for="{{orderActions}}"
          wx:key="label"
          data-index="{{index}}"
          bindtap="runOrderAction"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <view class="pay-panel">
      <view class="panel-title">{{ui.payTitle}}</view>

      <view class="pay-section">
        <view class="pay-section-title">{{ui.discountTitle}}</view>
        <view class="option-row">
          <view
            class="pay-option {{item.value === 'direct_reduce' ? (directReduceValue !== '' ? 'pay-option-active' : '') : (discountType === item.value ? 'pay-option-active' : '')}}"
            wx:for="{{discountOptions}}"
            wx:key="value"
            data-value="{{item.value}}"
            bindtap="selectDiscount"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="pay-section">
        <view class="pay-section-title">{{ui.paymentTitle}}</view>
        <view class="option-row">
          <view
            class="pay-option {{paymentMethod === item.value ? 'pay-option-active' : ''}}"
            wx:for="{{paymentOptions}}"
            wx:key="value"
            data-value="{{item.value}}"
            bindtap="selectPayment"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="summary-card">
        <view class="summary-title">{{ui.billSummary}}</view>
        <view class="summary-row">
          <text>{{ui.priceTotal}}</text>
          <text>{{ui.moneySymbol}}{{paySummary.totalText}}</text>
        </view>
        <view class="summary-row strong-row">
          <view class="discount-summary-label">
            <text>{{ui.receivable}}</text>
            <text class="discount-summary-text" wx:if="{{paySummary.discountText}}">{{paySummary.discountText}}</text>
          </view>
          <text>{{ui.moneySymbol}}{{paySummary.receivableText}}</text>
        </view>
        <view class="summary-row">
          <text>{{paySummary.paymentLabel}}</text>
          <text>{{ui.actualReceived}}{{ui.moneySymbol}}{{paySummary.receivedText}}</text>
        </view>
      </view>

      <button
        class="return-all-btn"
        loading="{{saving}}"
        disabled="{{saving || !selectedOrder}}"
        bindtap="confirmAllReturned"
      >{{ui.confirmAllReturned}}</button>

      <button
        class="checkout-btn"
        loading="{{saving}}"
        disabled="{{saving || !selectedOrder}}"
        bindtap="finishCheckout"
      >{{ui.finishCheckout}}</button>
    </view>
  </view>

  <view class="discount-mask" wx:if="{{showDiscountDialog}}" catchtap="closeDiscountDialog">
    <view class="discount-dialog" catchtap="stopDiscountDialogTap">
      <view class="discount-title">{{discountDialogType === 'direct_reduce' ? ui.directReduceDialogTitle : ui.discountDialogTitle}}</view>
      <input
        class="discount-input"
        type="digit"
        value="{{discountInput}}"
        placeholder="{{discountDialogType === 'direct_reduce' ? ui.directReduceInputPlaceholder : ui.discountInputPlaceholder}}"
        bindinput="onDiscountInput"
      />
      <view class="discount-actions">
        <view class="discount-action cancel" bindtap="closeDiscountDialog">{{ui.discountCancel}}</view>
        <view class="discount-action confirm" bindtap="confirmDiscountDialog">{{ui.discountConfirm}}</view>
      </view>
    </view>
  </view>
</view>
<admin-info-center />
