.feedback-admin-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #fff7ec;
  color: #3a2418;
}

.top-bar {
  flex: none;
  min-height: 54rpx;
  padding: 10rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  box-sizing: border-box;
}

.page-title {
  color: #2c1a12;
  font-size: 22rpx;
  font-weight: 900;
}

.top-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.search-box {
  width: 240rpx;
  height: 32rpx;
  padding: 0 12rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.search-box input {
  height: 32rpx;
  color: #3a2418;
  font-size: 13rpx;
}

.top-btn {
  min-width: 62rpx;
  height: 32rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  color: #9a642a;
  background: #fff1dc;
  font-size: 13rpx;
  font-weight: 900;
  line-height: 32rpx;
  text-align: center;
  box-sizing: border-box;
}

.feedback-list {
  flex: 1;
  min-height: 0;
  padding: 4rpx 18rpx 18rpx;
  box-sizing: border-box;
}

.feedback-item {
  margin-bottom: 10rpx;
  padding: 14rpx 16rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(58, 36, 24, 0.07);
  box-sizing: border-box;
}

.feedback-item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.feedback-user {
  color: #2c1a12;
  font-size: 15rpx;
  font-weight: 900;
}

.feedback-status {
  padding: 3rpx 8rpx;
  border-radius: 999rpx;
  color: #9a642a;
  background: #fff1dc;
  font-size: 11rpx;
  font-weight: 800;
}

.feedback-text {
  margin-top: 8rpx;
  color: #4d3829;
  font-size: 14rpx;
  line-height: 1.55;
  white-space: pre-wrap;
  word-break: break-all;
}

.feedback-time {
  margin-top: 7rpx;
  color: rgba(58, 36, 24, 0.46);
  font-size: 11rpx;
}

.state-text {
  padding: 90rpx 20rpx;
  color: rgba(58, 36, 24, 0.5);
  font-size: 14rpx;
  text-align: center;
}
