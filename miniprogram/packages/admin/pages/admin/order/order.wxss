.admin-simple-page {
  min-height: 100vh;
  background: #FFF7EC;
  color: #3A2418;
  box-sizing: border-box;
}

.admin-simple-header {
  padding: 28rpx 24rpx 22rpx;
  background: #1E1714;
  color: #FFF7EC;
}

.admin-simple-title {
  font-size: 38rpx;
  font-weight: 900;
}

.admin-simple-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.header-btn {
  min-width: 128rpx;
  height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  border-radius: 999rpx;
  color: rgba(255, 247, 236, 0.86);
  background: rgba(255, 247, 236, 0.12);
  font-size: 25rpx;
  font-weight: 900;
}

.header-btn.primary {
  color: #3A2418;
  background: #F1C46B;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 24rpx 0;
}

.search-input {
  flex: 1;
  height: 70rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  font-size: 25rpx;
  box-sizing: border-box;
}

.search-btn,
.clear-btn {
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.search-btn {
  width: 110rpx;
  color: #3A2418;
  background: #F1C46B;
}

.clear-btn {
  width: 70rpx;
  color: rgba(58, 36, 24, 0.58);
  background: #FFF1DC;
}

.admin-list {
  height: calc(100vh - 190rpx);
  padding: 22rpx 24rpx 38rpx;
  box-sizing: border-box;
}

.admin-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  box-shadow: 0 10rpx 26rpx rgba(58, 36, 24, 0.08);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.card-title {
  flex: 1;
  min-width: 0;
  color: #2C1A12;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
  word-break: break-all;
}

.card-status {
  max-width: 180rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: #9A642A;
  background: #FFF1DC;
  font-size: 21rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-subtitle {
  margin-top: 8rpx;
  color: rgba(58, 36, 24, 0.56);
  font-size: 24rpx;
}

.line-row {
  display: flex;
  gap: 18rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.line-label {
  width: 150rpx;
  flex-shrink: 0;
  color: rgba(58, 36, 24, 0.5);
}

.line-value {
  flex: 1;
  color: rgba(58, 36, 24, 0.82);
  word-break: break-all;
}

.card-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.mini-btn {
  min-width: 112rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 999rpx;
  color: #9A642A;
  background: #FFF1DC;
  font-size: 23rpx;
  font-weight: 900;
}

.mini-btn.danger {
  color: #C04B36;
}

.empty-text {
  padding: 120rpx 20rpx;
  color: rgba(58, 36, 24, 0.46);
  text-align: center;
  font-size: 26rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0, 0, 0, 0.45);
  box-sizing: border-box;
}

.modal-dialog {
  width: 100%;
  max-height: 88vh;
  overflow: hidden;
  border-radius: 24rpx;
  background: #FFF7EC;
}

.modal-title {
  padding: 28rpx 30rpx 18rpx;
  color: #2C1A12;
  font-size: 32rpx;
  font-weight: 900;
}

.modal-content {
  max-height: 62vh;
  padding: 0 30rpx 22rpx;
  box-sizing: border-box;
}

.form-item {
  margin-top: 20rpx;
}

.form-label {
  margin-bottom: 10rpx;
  color: rgba(58, 36, 24, 0.72);
  font-size: 24rpx;
  font-weight: 900;
}

.form-input,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #FFFFFF;
  color: #2C1A12;
  font-size: 26rpx;
}

.form-input {
  height: 72rpx;
  padding: 0 20rpx;
}

.form-textarea {
  min-height: 140rpx;
  padding: 18rpx 20rpx;
}

.switch-row {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 30rpx 30rpx;
  border-top: 1rpx solid rgba(58, 36, 24, 0.08);
}

.modal-btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.modal-btn.cancel {
  color: #7A6659;
  background: #FFFFFF;
}

.modal-btn.confirm {
  color: #3A2418;
  background: #F1C46B;
}

@media (orientation: landscape) {
  page {
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background: #FFF7EC;
  }

  .admin-simple-page {
    width: 100vw;
    height: 100vh;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .admin-simple-header {
    flex-shrink: 0;
    height: 86rpx;
    padding: 16rpx 28rpx;
    display: flex;
    align-items: center;
    justify-content: space-between;
    box-sizing: border-box;
  }

  .admin-simple-title {
    font-size: 34rpx;
    line-height: 1;
  }

  .admin-simple-actions {
    margin-top: 0;
    gap: 12rpx;
  }

  .header-btn {
    min-width: 112rpx;
    height: 52rpx;
    line-height: 52rpx;
    font-size: 23rpx;
  }

  .search-row {
    flex-shrink: 0;
    padding: 14rpx 28rpx 0;
    gap: 12rpx;
  }

  .search-input {
    height: 58rpx;
    font-size: 23rpx;
  }

  .search-btn,
  .clear-btn {
    height: 58rpx;
    line-height: 58rpx;
    font-size: 22rpx;
  }

  .search-btn {
    width: 96rpx;
  }

  .clear-btn {
    width: 58rpx;
  }

  .admin-list {
    flex: 1;
    height: auto;
    min-height: 0;
    padding: 18rpx 28rpx 28rpx;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18rpx;
    align-content: start;
    box-sizing: border-box;
  }

  .admin-card {
    min-height: 246rpx;
    margin-bottom: 0;
    padding: 20rpx;
    border-radius: 16rpx;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  .card-title {
    font-size: 27rpx;
    line-height: 1.25;
  }

  .card-status {
    max-width: 150rpx;
    padding: 5rpx 12rpx;
    font-size: 20rpx;
  }

  .card-subtitle {
    margin-top: 6rpx;
    font-size: 22rpx;
  }

  .line-row {
    gap: 12rpx;
    margin-top: 8rpx;
    font-size: 21rpx;
    line-height: 1.34;
  }

  .line-label {
    width: 112rpx;
  }

  .card-actions {
    margin-top: auto;
    padding-top: 14rpx;
    gap: 10rpx;
  }

  .mini-btn {
    min-width: 96rpx;
    height: 46rpx;
    line-height: 46rpx;
    font-size: 20rpx;
  }

  .empty-text {
    grid-column: 1 / -1;
    padding: 100rpx 20rpx;
  }

  .modal-dialog {
    width: 720rpx;
    max-width: 58vw;
  }

  .modal-title {
    padding: 24rpx 28rpx 14rpx;
    font-size: 29rpx;
  }

  .modal-content {
    max-height: 58vh;
    padding: 0 28rpx 18rpx;
  }

  .form-item {
    margin-top: 16rpx;
  }

  .form-input {
    height: 64rpx;
    font-size: 24rpx;
  }

  .form-textarea {
    min-height: 110rpx;
    font-size: 24rpx;
  }

  .modal-footer {
    padding: 18rpx 28rpx 24rpx;
  }

  .modal-btn {
    height: 66rpx;
    line-height: 66rpx;
    font-size: 25rpx;
  }
}
