/* packages/admin/pages/admin/dish/dish.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFF7EC;
  color: #3A2418;
}

.top-bar {
  padding: 28rpx 24rpx 18rpx;
  background: #1E1714;
  color: #FFF7EC;
}

.page-title {
  font-size: 38rpx;
  font-weight: 900;
  margin-bottom: 20rpx;
}

.menu-tabs {
  display: flex;
  gap: 16rpx;
}

.menu-tab {
  min-width: 128rpx;
  height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  border-radius: 999rpx;
  color: rgba(255, 247, 236, 0.78);
  background: rgba(255, 247, 236, 0.12);
  font-size: 25rpx;
  font-weight: 800;
}

.menu-tab.active {
  color: #3A2418;
  background: #F1C46B;
}

.main-content {
  flex: 1;
  display: flex;
  min-height: 0;
  overflow: hidden;
}

.category-sidebar {
  width: 214rpx;
  height: 100%;
  background: #FFF1DC;
  border-right: 1rpx solid rgba(58, 36, 24, 0.08);
}

.category-item {
  padding: 28rpx 14rpx;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.category-item.active {
  background: #F1C46B;
}

.category-name {
  display: block;
  color: #3A2418;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
  line-height: 1.35;
  word-break: break-all;
}

.category-actions {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.action-icon {
  padding: 4rpx 8rpx;
  color: rgba(58, 36, 24, 0.66);
  font-size: 20rpx;
}

.action-icon.delete {
  color: #C04B36;
}

.add-category-btn {
  padding: 30rpx 16rpx;
  text-align: center;
  color: #9A642A;
  font-weight: 900;
}

.add-icon {
  font-size: 34rpx;
  line-height: 1;
}

.add-text {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
}

.dish-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  min-height: 0;
}

.dish-header {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 22rpx;
  background: #FFF7EC;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.08);
}

.header-title {
  font-size: 30rpx;
  font-weight: 900;
}

.add-dish-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 60rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #3A2418;
  background: #F1C46B;
  font-size: 24rpx;
  font-weight: 900;
}

.dish-list {
  flex: 1;
  height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}

.dish-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  margin-bottom: 18rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  box-shadow: 0 10rpx 26rpx rgba(58, 36, 24, 0.08);
}

.dish-image {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 14rpx;
  background: #FFF1DC;
}

.dish-image image,
.no-image {
  width: 100%;
  height: 100%;
}

.no-image {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(58, 36, 24, 0.45);
  font-size: 22rpx;
  text-align: center;
}

.image-upload-box {
  position: relative;
  width: 168rpx;
  height: 132rpx;
  overflow: hidden;
  border-radius: 12rpx;
  border: 2rpx dashed rgba(154, 100, 42, 0.36);
  background: #FFF1DC;
}

.image-upload-preview,
.image-upload-empty {
  width: 100%;
  height: 100%;
}

.image-upload-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(58, 36, 24, 0.52);
  font-size: 22rpx;
  font-weight: 800;
}

.image-upload-action {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  color: #3A2418;
  background: rgba(241, 196, 107, 0.92);
  font-size: 20rpx;
  font-weight: 900;
}

.dish-status {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  color: white;
  font-size: 18rpx;
}

.dish-status.online {
  background: #4B9D64;
}

.dish-status.offline {
  background: #9B8E83;
}

.dish-info {
  flex: 1;
  min-width: 0;
}

.dish-name {
  color: #2C1A12;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
}

.dish-desc {
  min-height: 34rpx;
  margin-top: 8rpx;
  color: rgba(58, 36, 24, 0.58);
  font-size: 23rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-price {
  display: flex;
  align-items: baseline;
  margin-top: 14rpx;
}

.price-current {
  color: #C85F1D;
  font-size: 31rpx;
  font-weight: 900;
}

.price-unit {
  margin-left: 4rpx;
  color: rgba(58, 36, 24, 0.52);
  font-size: 21rpx;
}

.dish-actions {
  width: 104rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex-shrink: 0;
}

.action-btn {
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #FFF1DC;
  color: #9A642A;
  font-size: 21rpx;
  font-weight: 900;
}

.action-btn.delete {
  color: #C04B36;
}

.empty-list,
.empty-category {
  padding: 90rpx 20rpx;
  color: rgba(58, 36, 24, 0.48);
  text-align: center;
  font-size: 26rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0, 0, 0, 0.45);
  box-sizing: border-box;
}

.modal-dialog {
  width: 100%;
  max-height: 86vh;
  overflow: hidden;
  border-radius: 24rpx;
  background: #FFF7EC;
}

.modal-dialog.large {
  max-height: 90vh;
}

.modal-title {
  padding: 28rpx 30rpx 18rpx;
  color: #2C1A12;
  font-size: 32rpx;
  font-weight: 900;
}

.modal-content {
  max-height: 64vh;
  padding: 0 30rpx 22rpx;
  box-sizing: border-box;
}

.form-row {
  display: flex;
  gap: 18rpx;
}

.form-item {
  margin-top: 20rpx;
}

.form-item.half {
  flex: 1;
  min-width: 0;
}

.form-label {
  margin-bottom: 10rpx;
  color: rgba(58, 36, 24, 0.72);
  font-size: 24rpx;
  font-weight: 900;
}

.form-input,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #FFFFFF;
  color: #2C1A12;
  font-size: 26rpx;
}

.form-input {
  height: 72rpx;
  padding: 0 20rpx;
}

.form-textarea {
  min-height: 130rpx;
  padding: 18rpx 20rpx;
}

.form-tip {
  margin-top: 10rpx;
  color: rgba(58, 36, 24, 0.46);
  font-size: 21rpx;
  line-height: 1.4;
}

.switch-row {
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: rgba(58, 36, 24, 0.76);
  font-size: 25rpx;
  font-weight: 900;
}

.spec-preview {
  margin-top: 8rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(201, 154, 74, 0.28);
  box-shadow: 0 10rpx 24rpx rgba(58, 36, 24, 0.06);
}

.spec-preview-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.spec-preview-title {
  flex: none;
  color: #3A2418;
  font-size: 24rpx;
  font-weight: 900;
}

.spec-preview-tip {
  color: rgba(58, 36, 24, 0.46);
  font-size: 20rpx;
  line-height: 1.3;
}

.spec-template-section {
  padding: 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 247, 236, 0.72);
}

.spec-template-title {
  color: rgba(58, 36, 24, 0.72);
  font-size: 21rpx;
  font-weight: 900;
}

.spec-template-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.spec-template-chip {
  height: 46rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #7A6659;
  background: #FFFFFF;
  border: 1rpx solid rgba(58, 36, 24, 0.1);
  font-size: 21rpx;
  font-weight: 900;
}

.spec-template-chip.active {
  color: #3A2418;
  background: #F1C46B;
  border-color: rgba(154, 100, 42, 0.36);
}

.spec-custom-editor {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.62);
}

.spec-preview-divider {
  height: 1rpx;
  margin: 16rpx 0 6rpx;
  background: rgba(58, 36, 24, 0.08);
}

.spec-preview-group {
  margin-top: 14rpx;
}

.spec-group-title {
  color: rgba(58, 36, 24, 0.76);
  font-size: 22rpx;
  font-weight: 900;
}

.spec-option-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.spec-option {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  color: #6F451F;
  background: #FFF7EC;
  border: 1rpx solid rgba(201, 154, 74, 0.36);
  font-size: 21rpx;
  font-weight: 800;
}

.spec-note {
  margin-top: 8rpx;
  color: rgba(58, 36, 24, 0.52);
  font-size: 20rpx;
  line-height: 1.35;
}

.spec-remark-row {
  height: 54rpx;
  margin-top: 16rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-radius: 14rpx;
  color: rgba(58, 36, 24, 0.54);
  background: rgba(255, 247, 236, 0.84);
  font-size: 21rpx;
  font-weight: 800;
}

.modal-footer {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 30rpx 30rpx;
  border-top: 1rpx solid rgba(58, 36, 24, 0.08);
}

.modal-btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.modal-btn.cancel {
  color: #7A6659;
  background: #FFFFFF;
}

.modal-btn.confirm {
  color: #3A2418;
  background: #F1C46B;
}

/* Landscape admin layout */
page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #FFF7EC;
}

.page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}

.top-bar {
  height: 62rpx;
  flex: none;
  padding: 9rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  box-sizing: border-box;
}

.page-title {
  flex: none;
  margin-bottom: 0;
  font-size: 22rpx;
  line-height: 1;
}

.menu-tabs {
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
}

.menu-tab {
  min-width: 76rpx;
  height: 34rpx;
  padding: 0 12rpx;
  line-height: 34rpx;
  font-size: 13rpx;
  box-sizing: border-box;
}

.main-content {
  padding: 12rpx 14rpx 10rpx;
  gap: 12rpx;
  box-sizing: border-box;
}

.category-sidebar {
  width: 170rpx;
  flex: none;
  border-radius: 10rpx;
  border: 1rpx solid rgba(58, 36, 24, 0.08);
  box-shadow: 0 8rpx 20rpx rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.category-item {
  min-height: 42rpx;
  padding: 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6rpx;
}

.category-name {
  flex: 1;
  min-width: 0;
  text-align: left;
  font-size: 13rpx;
  line-height: 1.22;
}

.category-actions {
  flex: none;
  align-items: center;
  gap: 4rpx;
  margin-top: 0;
}

.action-icon {
  padding: 2rpx 4rpx;
  font-size: 10rpx;
  font-weight: 900;
  line-height: 1.2;
}

.add-category-btn {
  min-height: 42rpx;
  padding: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  box-sizing: border-box;
}

.add-icon {
  font-size: 18rpx;
}

.add-text {
  display: inline;
  margin-top: 0;
  font-size: 12rpx;
  line-height: 1;
}

.dish-content {
  overflow: hidden;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(58, 36, 24, 0.08);
  box-shadow: 0 8rpx 20rpx rgba(58, 36, 24, 0.06);
  box-sizing: border-box;
}

.dish-header {
  height: 48rpx;
  flex: none;
  padding: 0 14rpx;
  background: rgba(255, 247, 236, 0.92);
  box-sizing: border-box;
}

.header-title {
  font-size: 18rpx;
  line-height: 1;
}

.add-dish-btn {
  height: 32rpx;
  padding: 0 12rpx;
  gap: 5rpx;
  font-size: 12rpx;
  box-sizing: border-box;
}

.dish-list {
  height: 100%;
  padding: 12rpx;
  box-sizing: border-box;
}

.dish-item {
  width: calc(50% - 7rpx);
  min-height: 104rpx;
  margin: 0 10rpx 10rpx 0;
  padding: 10rpx;
  display: inline-flex;
  gap: 10rpx;
  vertical-align: top;
  border-radius: 10rpx;
  border: 1rpx solid rgba(58, 36, 24, 0.08);
  box-shadow: 0 8rpx 18rpx rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.dish-item:nth-child(2n) {
  margin-right: 0;
}

.dish-image {
  width: 82rpx;
  height: 82rpx;
  border-radius: 8rpx;
}

.no-image {
  font-size: 10rpx;
}

.dish-status {
  right: 4rpx;
  top: 4rpx;
  padding: 2rpx 5rpx;
  font-size: 8rpx;
  font-weight: 900;
  line-height: 1.25;
}

.dish-info {
  padding-top: 2rpx;
}

.dish-name {
  font-size: 17rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-desc {
  height: 18rpx;
  min-height: 0;
  margin-top: 6rpx;
  font-size: 10rpx;
  line-height: 18rpx;
}

.dish-price {
  margin-top: 7rpx;
}

.price-current {
  font-size: 17rpx;
  line-height: 1;
}

.price-unit {
  margin-left: 3rpx;
  font-size: 10rpx;
}

.dish-actions {
  width: 58rpx;
  gap: 6rpx;
}

.action-btn {
  height: 24rpx;
  line-height: 24rpx;
  font-size: 10rpx;
  overflow: hidden;
}

.empty-list,
.empty-category {
  padding: 70rpx 18rpx;
  font-size: 16rpx;
  font-weight: 800;
}

.modal-mask {
  padding: 24rpx;
}

.modal-dialog {
  width: 420rpx;
  max-height: 86vh;
  border-radius: 12rpx;
  box-shadow: 0 18rpx 46rpx rgba(0, 0, 0, 0.2);
}

.modal-dialog.large {
  width: 650rpx;
  max-height: 90vh;
}

.modal-title {
  padding: 16rpx 18rpx 10rpx;
  font-size: 19rpx;
}

.modal-content {
  max-height: 58vh;
  padding: 0 18rpx 14rpx;
}

.form-row {
  gap: 12rpx;
}

.form-item {
  margin-top: 12rpx;
}

.form-label {
  margin-bottom: 6rpx;
  font-size: 12rpx;
}

.form-input,
.form-textarea {
  border-radius: 8rpx;
  font-size: 13rpx;
}

.form-input {
  height: 38rpx;
  padding: 0 10rpx;
}

.form-textarea {
  min-height: 74rpx;
  padding: 9rpx 10rpx;
}

.form-tip {
  margin-top: 6rpx;
  font-size: 10rpx;
}

.image-upload-box {
  width: 118rpx;
  height: 90rpx;
  border-radius: 8rpx;
}

.image-upload-empty {
  font-size: 12rpx;
}

.image-upload-action {
  height: 24rpx;
  line-height: 24rpx;
  font-size: 10rpx;
}

.switch-row {
  height: 44rpx;
  font-size: 13rpx;
}

.spec-preview {
  margin-top: 4rpx;
  padding: 10rpx;
  border-radius: 8rpx;
}

.spec-preview-header {
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.spec-preview-title {
  font-size: 12rpx;
}

.spec-preview-tip {
  font-size: 10rpx;
}

.spec-template-section {
  padding: 7rpx;
  border-radius: 8rpx;
}

.spec-template-title {
  font-size: 10rpx;
}

.spec-template-list {
  gap: 5rpx;
  margin-top: 5rpx;
}

.spec-template-chip {
  height: 23rpx;
  padding: 0 9rpx;
  font-size: 10rpx;
}

.spec-custom-editor {
  margin-top: 7rpx;
  padding: 7rpx;
  border-radius: 8rpx;
}

.spec-preview-divider {
  margin: 8rpx 0 3rpx;
}

.spec-preview-group {
  margin-top: 8rpx;
}

.spec-group-title {
  font-size: 11rpx;
}

.spec-option-list {
  gap: 5rpx;
  margin-top: 5rpx;
}

.spec-option {
  padding: 4rpx 9rpx;
  font-size: 10rpx;
}

.spec-note {
  margin-top: 4rpx;
  font-size: 10rpx;
}

.spec-remark-row {
  height: 28rpx;
  margin-top: 8rpx;
  padding: 0 9rpx;
  border-radius: 7rpx;
  font-size: 10rpx;
}

.modal-footer {
  padding: 12rpx 18rpx 16rpx;
  gap: 12rpx;
}

.modal-btn {
  height: 40rpx;
  line-height: 40rpx;
  font-size: 14rpx;
}

.title-search {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.dish-search {
  width: 250rpx;
  height: 34rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  background: rgba(255, 247, 236, 0.14);
  border: 1rpx solid rgba(255, 247, 236, 0.18);
}

.dish-search-input {
  flex: 1;
  min-width: 0;
  height: 30rpx;
  color: #FFF7EC;
  font-size: 12rpx;
  font-weight: 800;
  line-height: 30rpx;
}

.search-clear {
  width: 18rpx;
  height: 18rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #3A2418;
  background: rgba(255, 247, 236, 0.78);
  font-size: 12rpx;
  font-weight: 900;
  line-height: 18rpx;
}
