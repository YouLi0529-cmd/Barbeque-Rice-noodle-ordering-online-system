/* packages/admin/pages/admin/dish/dish.wxss */
.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFF7EC;
  color: #3A2418;
}

.top-bar {
  padding: 28rpx 24rpx 18rpx;
  background: #1E1714;
  color: #FFF7EC;
}

.page-title {
  font-size: 38rpx;
  font-weight: 900;
  margin-bottom: 20rpx;
}

.menu-tabs {
  display: flex;
  gap: 16rpx;
}

.menu-tab {
  min-width: 128rpx;
  height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  border-radius: 999rpx;
  color: rgba(255, 247, 236, 0.78);
  background: rgba(255, 247, 236, 0.12);
  font-size: 25rpx;
  font-weight: 800;
}

.menu-tab.active {
  color: #3A2418;
  background: #F1C46B;
}

.main-content {
  flex: 1;
  display: flex;
  min-height: 0;
  overflow: hidden;
}

.category-sidebar {
  width: 214rpx;
  height: 100%;
  background: #FFF1DC;
  border-right: 1rpx solid rgba(58, 36, 24, 0.08);
}

.category-item {
  padding: 28rpx 14rpx;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.category-item.active {
  background: #F1C46B;
}

.category-name {
  display: block;
  color: #3A2418;
  font-size: 25rpx;
  font-weight: 900;
  text-align: center;
  line-height: 1.35;
  word-break: break-all;
}

.category-actions {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-top: 14rpx;
}

.action-icon {
  padding: 4rpx 8rpx;
  color: rgba(58, 36, 24, 0.66);
  font-size: 20rpx;
}

.action-icon.delete {
  color: #C04B36;
}

.add-category-btn {
  padding: 30rpx 16rpx;
  text-align: center;
  color: #9A642A;
  font-weight: 900;
}

.add-icon {
  font-size: 34rpx;
  line-height: 1;
}

.add-text {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
}

.dish-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  min-height: 0;
}

.dish-header {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 22rpx;
  background: #FFF7EC;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.08);
}

.header-title {
  font-size: 30rpx;
  font-weight: 900;
}

.add-dish-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 60rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  color: #3A2418;
  background: #F1C46B;
  font-size: 24rpx;
  font-weight: 900;
}

.dish-list {
  flex: 1;
  height: 100%;
  padding: 20rpx;
  box-sizing: border-box;
}

.dish-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx;
  margin-bottom: 18rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  box-shadow: 0 10rpx 26rpx rgba(58, 36, 24, 0.08);
}

.dish-image {
  position: relative;
  width: 150rpx;
  height: 150rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 14rpx;
  background: #FFF1DC;
}

.dish-image image,
.no-image {
  width: 100%;
  height: 100%;
}

.no-image {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(58, 36, 24, 0.45);
  font-size: 22rpx;
  text-align: center;
}

.dish-status {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  color: white;
  font-size: 18rpx;
}

.dish-status.online {
  background: #4B9D64;
}

.dish-status.offline {
  background: #9B8E83;
}

.dish-info {
  flex: 1;
  min-width: 0;
}

.dish-name {
  color: #2C1A12;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.25;
}

.dish-desc {
  min-height: 34rpx;
  margin-top: 8rpx;
  color: rgba(58, 36, 24, 0.58);
  font-size: 23rpx;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-price {
  display: flex;
  align-items: baseline;
  margin-top: 14rpx;
}

.price-current {
  color: #C85F1D;
  font-size: 31rpx;
  font-weight: 900;
}

.price-unit {
  margin-left: 4rpx;
  color: rgba(58, 36, 24, 0.52);
  font-size: 21rpx;
}

.dish-actions {
  width: 104rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex-shrink: 0;
}

.action-btn {
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  border-radius: 999rpx;
  background: #FFF1DC;
  color: #9A642A;
  font-size: 21rpx;
  font-weight: 900;
}

.action-btn.delete {
  color: #C04B36;
}

.empty-list,
.empty-category {
  padding: 90rpx 20rpx;
  color: rgba(58, 36, 24, 0.48);
  text-align: center;
  font-size: 26rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0, 0, 0, 0.45);
  box-sizing: border-box;
}

.modal-dialog {
  width: 100%;
  max-height: 86vh;
  overflow: hidden;
  border-radius: 24rpx;
  background: #FFF7EC;
}

.modal-dialog.large {
  max-height: 90vh;
}

.modal-title {
  padding: 28rpx 30rpx 18rpx;
  color: #2C1A12;
  font-size: 32rpx;
  font-weight: 900;
}

.modal-content {
  max-height: 64vh;
  padding: 0 30rpx 22rpx;
  box-sizing: border-box;
}

.form-row {
  display: flex;
  gap: 18rpx;
}

.form-item {
  margin-top: 20rpx;
}

.form-item.half {
  flex: 1;
  min-width: 0;
}

.form-label {
  margin-bottom: 10rpx;
  color: rgba(58, 36, 24, 0.72);
  font-size: 24rpx;
  font-weight: 900;
}

.form-input,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #FFFFFF;
  color: #2C1A12;
  font-size: 26rpx;
}

.form-input {
  height: 72rpx;
  padding: 0 20rpx;
}

.form-textarea {
  min-height: 130rpx;
  padding: 18rpx 20rpx;
}

.form-tip {
  margin-top: 10rpx;
  color: rgba(58, 36, 24, 0.46);
  font-size: 21rpx;
  line-height: 1.4;
}

.switch-row {
  height: 82rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: rgba(58, 36, 24, 0.76);
  font-size: 25rpx;
  font-weight: 900;
}

.modal-footer {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 30rpx 30rpx;
  border-top: 1rpx solid rgba(58, 36, 24, 0.08);
}

.modal-btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.modal-btn.cancel {
  color: #7A6659;
  background: #FFFFFF;
}

.modal-btn.confirm {
  color: #3A2418;
  background: #F1C46B;
}