<!-- packages/admin/pages/admin/dish/dish.wxml -->
<view class="page">
  <view class="top-bar">
    <view class="title-search">
      <view class="page-title">{{ui.pageTitle}}</view>
      <view class="dish-search">
        <input
          class="dish-search-input"
          value="{{searchKeyword}}"
          placeholder="{{ui.searchPlaceholder}}"
          placeholder-style="color: rgba(255, 247, 236, 0.52);"
          confirm-type="search"
          bindinput="onSearchInput"
          bindconfirm="confirmSearch" />
        <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">x</text>
      </view>
    </view>
    <view class="menu-tabs">
      <view
        wx:for="{{menuTypes}}"
        wx:key="value"
        class="menu-tab {{currentMenuType === item.value ? 'active' : ''}}"
        bindtap="changeMenuType"
        data-type="{{item.value}}">
        {{item.label}}
      </view>
    </view>
  </view>

  <view class="main-content">
    <scroll-view class="category-sidebar" scroll-y>
      <view
        class="category-item {{currentCategoryId === item._id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="_id"
        bindtap="switchCategory"
        data-id="{{item._id}}">
        <text class="category-name">{{item.name}}</text>
        <view class="category-actions">
          <text class="action-icon edit" catchtap="showEditCategoryModal" data-category="{{item}}">{{ui.edit}}</text>
          <text class="action-icon delete" catchtap="deleteCategory" data-category="{{item}}">{{ui.delete}}</text>
        </view>
      </view>

      <view class="add-category-btn" bindtap="showAddCategoryModal">
        <text class="add-icon">+</text>
        <text class="add-text">{{ui.addCategory}}</text>
      </view>
    </scroll-view>

    <view class="dish-content">
      <view class="dish-header">
        <view class="header-title">{{isSearching ? ui.searchResult : (currentCategoryId ? ui.pageTitle : ui.selectCategory)}}</view>
        <view class="add-dish-btn" bindtap="showAddDishModal" wx:if="{{currentCategoryId && !isSearching}}">
          <text class="add-icon">+</text>
          <text>{{ui.addDish}}</text>
        </view>
      </view>

      <scroll-view class="dish-list" scroll-y wx:if="{{currentCategoryId || isSearching}}">
        <view class="dish-item" wx:for="{{dishes}}" wx:key="_id">
          <view class="dish-image">
            <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill"></image>
            <view wx:else class="no-image">{{ui.noImage}}</view>
            <view class="dish-status {{item.status === 1 ? 'online' : 'offline'}}">
              {{item.status === 1 ? ui.online : ui.offline}}
            </view>
          </view>

          <view class="dish-info">
            <view class="dish-name">{{item.name}}</view>
            <view class="dish-desc">{{item.description || item.categoryName}}</view>
            <view class="dish-price">
              <text class="price-current">{{ui.currency}}{{item.price}}</text>
              <text class="price-unit">{{ui.slash}}{{item.unit || ui.defaultUnit}}</text>
            </view>
          </view>

          <view class="dish-actions">
            <view class="action-btn status" bindtap="toggleDishStatus" data-dish="{{item}}">
              {{item.status === 1 ? ui.setOffline : ui.setOnline}}
            </view>
            <view class="action-btn edit" bindtap="showEditDishModal" data-dish="{{item}}">{{ui.edit}}</view>
            <view class="action-btn delete" bindtap="deleteDish" data-dish="{{item}}">{{ui.delete}}</view>
          </view>
        </view>

        <view class="empty-list" wx:if="{{dishes.length === 0 && !loadingDishes}}">{{isSearching ? ui.emptySearch : ui.emptyDish}}</view>
        <view class="empty-list" wx:if="{{loadingDishes}}">{{ui.loading}}</view>
      </scroll-view>

      <view class="empty-category" wx:if="{{!currentCategoryId}}">{{ui.selectCategory}}</view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showCategoryModal}}" catchtap="closeCategoryModal">
    <view class="modal-dialog" catchtap="stopPropagation">
      <view class="modal-title">{{editCategoryMode ? ui.editCategory : ui.addCategory}}</view>
      <view class="modal-content">
        <view class="form-item">
          <view class="form-label">{{ui.categoryName}}</view>
          <input class="form-input" placeholder="{{ui.inputCategoryName}}" value="{{currentCategory.name}}" bindinput="onCategoryNameInput" />
        </view>
        <view class="form-item">
          <view class="form-label">{{ui.sort}}</view>
          <input class="form-input" type="number" placeholder="{{ui.inputSort}}" value="{{currentCategory.sort}}" bindinput="onCategorySortInput" />
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="closeCategoryModal">{{ui.cancel}}</view>
        <view class="modal-btn confirm" bindtap="saveCategory">{{ui.save}}</view>
      </view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showDishModal}}" catchtap="closeDishModal">
    <view class="modal-dialog large" catchtap="stopPropagation">
      <view class="modal-title">{{editDishMode ? ui.editDish : ui.addDish}}</view>
      <scroll-view class="modal-content" scroll-y>
        <view class="form-item">
          <view class="form-label">{{ui.dishName}}</view>
          <input class="form-input" placeholder="{{ui.inputDishName}}" value="{{currentDish.name}}" data-field="name" bindinput="onDishInput" />
        </view>
        <view class="form-row">
          <view class="form-item half">
            <view class="form-label">{{ui.price}}</view>
            <input class="form-input" type="digit" placeholder="{{ui.inputPrice}}" value="{{currentDish.price}}" data-field="price" bindinput="onDishInput" />
          </view>
          <view class="form-item half">
            <view class="form-label">{{ui.unit}}</view>
            <input class="form-input" placeholder="{{ui.inputUnit}}" value="{{currentDish.unit}}" data-field="unit" bindinput="onDishInput" />
          </view>
        </view>
        <view class="form-row">
          <view class="form-item half">
            <view class="form-label">{{ui.originalPrice}}</view>
            <input class="form-input" type="digit" placeholder="{{ui.inputPrice}}" value="{{currentDish.originalPrice}}" data-field="originalPrice" bindinput="onDishInput" />
          </view>
          <view class="form-item half">
            <view class="form-label">{{ui.sort}}</view>
            <input class="form-input" type="number" placeholder="{{ui.inputSort}}" value="{{currentDish.sort}}" data-field="sort" bindinput="onDishInput" />
          </view>
        </view>
        <view class="form-item">
          <view class="form-label">{{ui.description}}</view>
          <textarea class="form-textarea" placeholder="{{ui.inputDescription}}" value="{{currentDish.description}}" data-field="description" bindinput="onDishInput" />
        </view>
        <view class="form-item">
          <view class="form-label">{{ui.image}}</view>
          <view class="image-upload-box" bindtap="chooseDishImage">
            <image wx:if="{{currentDish.imagePreview}}" class="image-upload-preview" src="{{currentDish.imagePreview}}" mode="aspectFill"></image>
            <view wx:else class="image-upload-empty">{{ui.uploadImage}}</view>
            <view class="image-upload-action">{{currentDish.imagePreview ? ui.changeImage : ui.uploadImage}}</view>
          </view>
          <view class="form-tip">{{ui.imageTip}}</view>
        </view>
        <view class="switch-row">
          <text>{{ui.status}}</text>
          <switch checked="{{currentDish.status === 1}}" bindchange="onDishStatusChange" color="#C99A4A" />
        </view>
        <view class="switch-row">
          <text>{{ui.needPopup}}</text>
          <switch checked="{{currentDish.needPopup}}" bindchange="onDishNeedPopupChange" color="#C99A4A" />
        </view>
        <view class="spec-preview" wx:if="{{currentDish.needPopup}}">
          <view class="spec-preview-header">
            <text class="spec-preview-title">{{ui.specPreviewTitle}}</text>
            <text class="spec-preview-tip">{{ui.specPreviewTip}}</text>
          </view>
          <view class="spec-template-section">
            <view class="spec-template-title">{{ui.specTemplate}}</view>
            <view class="spec-template-list">
              <view
                wx:for="{{specTemplates}}"
                wx:key="value"
                class="spec-template-chip {{currentDish.specTemplate === item.value ? 'active' : ''}}"
                data-template="{{item.value}}"
                bindtap="selectSpecTemplate"
              >{{item.label}}</view>
            </view>
          </view>
          <view class="spec-custom-editor" wx:if="{{currentDish.specTemplate === 'custom'}}">
            <view class="form-row">
              <view class="form-item half">
                <view class="form-label">{{ui.customSpecTitle}}</view>
                <input class="form-input" placeholder="{{ui.inputCustomSpecTitle}}" value="{{currentDish.customSpecTitle}}" data-field="customSpecTitle" bindinput="onCustomSpecInput" />
              </view>
              <view class="form-item half">
                <view class="form-label">{{ui.customSpecOptions}}</view>
                <input class="form-input" placeholder="{{ui.inputCustomSpecOptions}}" value="{{currentDish.customSpecOptionsText}}" data-field="customSpecOptionsText" bindinput="onCustomSpecInput" />
              </view>
            </view>
            <view class="form-tip">{{ui.customSpecOptionsTip}}</view>
            <view class="form-item">
              <view class="form-label">{{ui.customSpecNote}}</view>
              <input class="form-input" placeholder="{{ui.inputCustomSpecNote}}" value="{{currentDish.customSpecNote}}" data-field="customSpecNote" bindinput="onCustomSpecInput" />
            </view>
          </view>
          <view class="spec-preview-divider"></view>
          <view class="spec-preview-group" wx:for="{{specPreviewGroups}}" wx:key="title">
            <view class="spec-group-title">{{item.title}}</view>
            <view class="spec-option-list">
              <text class="spec-option" wx:for="{{item.options}}" wx:for-item="option" wx:key="*this">{{option}}</text>
            </view>
            <view class="spec-note" wx:if="{{item.note}}">{{item.note}}</view>
          </view>
          <view class="spec-remark-row">
            <text>{{ui.specRemark}}</text>
            <text>{{ui.specRemarkLimit}}</text>
          </view>
        </view>
        <view class="form-item printer-form-item">
          <view class="form-label">{{ui.printer}}</view>
          <view class="printer-select">
            <view class="printer-picker {{showPrinterDropdown ? 'open' : ''}}" bindtap="togglePrinterDropdown">
              <text>{{currentDish.printerLabel}}</text>
              <text class="printer-arrow {{showPrinterDropdown ? 'open' : ''}}">∨</text>
            </view>
            <view class="printer-dropdown" wx:if="{{showPrinterDropdown}}">
              <view
                class="printer-option {{currentDish.printerIndex === index ? 'active' : ''}}"
                wx:for="{{printerOptions}}"
                wx:key="value"
                data-index="{{index}}"
                catchtap="selectPrinterOption"
              >
                <text>{{item.label}}</text>
              </view>
            </view>
          </view>
          <view class="form-tip">{{ui.printerTip}}</view>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="modal-btn cancel" bindtap="closeDishModal">{{ui.cancel}}</view>
        <view class="modal-btn confirm" bindtap="saveDish">{{ui.save}}</view>
      </view>
    </view>
  </view>
</view>
