<view class="notice-admin-page">
  <view class="top-bar">
    <view class="title-block">
      <view class="page-title">{{ui.title}}</view>
    </view>
    <view class="top-actions">
      <view class="top-btn" bindtap="goBack">{{ui.back}}</view>
      <view class="top-btn" bindtap="loadList">{{ui.refresh}}</view>
      <view class="top-btn primary" bindtap="createNotice">{{ui.add}}</view>
    </view>
  </view>

  <view class="main-content">
    <view class="notice-list-panel">
      <view class="panel-head">
        <view class="panel-title">{{ui.listTitle}}</view>
        <view class="panel-count">{{list.length}}</view>
      </view>

      <scroll-view class="notice-list" scroll-y>
        <view class="list-loading" wx:if="{{loading}}">{{ui.loading}}</view>
        <view class="empty-state" wx:elif="{{list.length === 0}}">{{ui.empty}}</view>
        <block wx:else>
          <view class="notice-item {{selectedNoticeId === item._id ? 'active' : ''}}" wx:for="{{list}}" wx:key="_id" data-id="{{item._id}}" bindtap="selectNotice">
            <view class="notice-item-head">
              <view class="notice-brief">{{item.brief}}</view>
              <view class="notice-status {{item.statusClass}}">{{item.displayStatus}}</view>
            </view>
            <view class="notice-meta">{{item.displaySort}}</view>
            <view class="notice-actions">
              <view class="mini-btn" catchtap="toggleNotice" data-id="{{item._id}}" data-status="{{item.status}}">{{item.toggleText}}</view>
              <view class="mini-btn danger" catchtap="deleteNotice" data-id="{{item._id}}">{{ui.delete}}</view>
            </view>
          </view>
        </block>
      </scroll-view>
    </view>

    <view class="editor-panel">
      <view class="panel-head editor-head">
        <view class="panel-title">{{ui.editorTitle}}</view>
        <view class="edit-mode">{{form._id ? '编辑中' : '新公告'}}</view>
      </view>

      <view class="form-area">
        <view class="form-group content-group">
          <view class="form-label">{{ui.contentLabel}}</view>
          <textarea class="content-input" maxlength="120" placeholder="{{ui.contentPlaceholder}}" value="{{form.content}}" bindinput="onContentInput" />
          <view class="content-count">{{contentLength}}/120</view>
        </view>

        <view class="form-row">
          <view class="form-group sort-group">
            <view class="form-label">{{ui.sortLabel}}</view>
            <input class="sort-input" type="number" placeholder="{{ui.sortPlaceholder}}" value="{{form.sort}}" bindinput="onSortInput" />
          </view>

          <view class="form-group status-group">
            <view class="form-label">{{ui.statusLabel}}</view>
            <view class="status-options">
              <view class="status-option {{form.status === item.value ? 'active' : ''}}" wx:for="{{statusOptions}}" wx:key="value" data-status="{{item.value}}" bindtap="chooseStatus">{{item.label}}</view>
            </view>
          </view>
        </view>

        <view class="preview-box">
          <view class="preview-label">{{ui.previewLabel}}</view>
          <view class="preview-content">{{previewText}}</view>
        </view>
      </view>

      <view class="editor-actions">
        <view class="editor-btn primary" bindtap="saveNotice">{{saving ? ui.saving : ui.save}}</view>
      </view>
    </view>
  </view>
</view>