.notice-admin-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #FFF7EC;
  color: #3A2418;
  box-sizing: border-box;
}

.top-bar {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 8rpx 18rpx 6rpx;
  background: #FFF7EC;
  color: #3A2418;
  box-sizing: border-box;
}

.title-block {
  min-width: 0;
}

.page-title {
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.2;
}

.top-actions {
  flex: none;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.top-btn {
  min-width: 74rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #9A642A;
  background: #FFF1DC;
  font-size: 14rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.top-btn.primary {
  color: #3A2418;
  background: #F1C46B;
}

.main-content {
  flex: 1;
  min-height: 0;
  display: flex;
  gap: 14rpx;
  padding: 12rpx 18rpx 16rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.notice-list-panel,
.editor-panel {
  flex: 1;
  min-height: 0;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(122, 74, 31, 0.08);
  box-shadow: 0 8rpx 18rpx rgba(58, 36, 24, 0.07);
  box-sizing: border-box;
}

.notice-list-panel {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.editor-panel {
  display: flex;
  flex-direction: column;
  min-width: 0;
  overflow: hidden;
}

.panel-head {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  padding: 12rpx 14rpx 10rpx;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.panel-title {
  color: #2C1A12;
  font-size: 17rpx;
  font-weight: 900;
}

.panel-count,
.edit-mode {
  min-width: 34rpx;
  height: 24rpx;
  line-height: 24rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #9A642A;
  background: #FFF1DC;
  font-size: 12rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.notice-list {
  flex: 1;
  min-height: 0;
  height: auto;
  padding: 10rpx;
  box-sizing: border-box;
}

.notice-item {
  margin-bottom: 9rpx;
  padding: 10rpx;
  border-radius: 10rpx;
  background: #FFFFFF;
  border: 1rpx solid transparent;
  box-shadow: 0 5rpx 12rpx rgba(58, 36, 24, 0.055);
  box-sizing: border-box;
}

.notice-item.active {
  border-color: #D1A24F;
  background: #FFF8EA;
}

.notice-item-head {
  display: flex;
  align-items: flex-start;
  gap: 7rpx;
}

.notice-brief {
  flex: 1;
  min-width: 0;
  color: #2C1A12;
  font-size: 15rpx;
  font-weight: 900;
  line-height: 1.35;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notice-target {
  flex: none;
  height: 22rpx;
  line-height: 22rpx;
  padding: 0 7rpx;
  border-radius: 999rpx;
  color: #7A4A1F;
  background: #FFF1DC;
  font-size: 10rpx;
  font-weight: 900;
}

.notice-status {
  flex: none;
  height: 22rpx;
  line-height: 22rpx;
  padding: 0 7rpx;
  border-radius: 999rpx;
  font-size: 10rpx;
  font-weight: 900;
}

.notice-status.enabled {
  color: #7A4A1F;
  background: #F5D99D;
}

.notice-status.disabled {
  color: rgba(58, 36, 24, 0.48);
  background: rgba(58, 36, 24, 0.08);
}

.notice-meta {
  margin-top: 6rpx;
  color: rgba(58, 36, 24, 0.5);
  font-size: 12rpx;
}

.notice-actions {
  display: flex;
  gap: 6rpx;
  margin-top: 8rpx;
}

.mini-btn {
  min-width: 52rpx;
  height: 26rpx;
  line-height: 26rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #9A642A;
  background: #FFF1DC;
  font-size: 11rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.mini-btn.danger {
  color: #B34932;
  background: #FCE7DD;
}

.empty-state,
.list-loading {
  padding: 70rpx 12rpx;
  color: rgba(58, 36, 24, 0.46);
  text-align: center;
  font-size: 14rpx;
}

.notice-list-footer {
  flex: none;
  padding: 0 10rpx 10rpx;
  box-sizing: border-box;
}

.footer-refresh {
  width: 74rpx;
  height: 28rpx;
  line-height: 28rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #9A642A;
  background: #FFF1DC;
  font-size: 12rpx;
  font-weight: 900;
}

.editor-head {
  padding-left: 14rpx;
  padding-right: 14rpx;
}

.form-area {
  flex: 1;
  min-height: 0;
  padding: 12rpx 14rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

.form-group {
  position: relative;
}

.form-label {
  margin-bottom: 6rpx;
  color: rgba(58, 36, 24, 0.68);
  font-size: 13rpx;
  font-weight: 900;
}

.content-input,
.sort-input {
  width: 100%;
  border-radius: 9rpx;
  background: #FFFFFF;
  color: #2C1A12;
  font-size: 15rpx;
  box-sizing: border-box;
}

.content-input {
  height: 102rpx;
  padding: 10rpx 12rpx 22rpx;
  line-height: 1.45;
}

.content-count {
  position: absolute;
  right: 10rpx;
  bottom: 7rpx;
  color: rgba(58, 36, 24, 0.42);
  font-size: 11rpx;
}

.form-row {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.sort-group {
  width: 190rpx;
}

.sort-input {
  height: 36rpx;
  padding: 0 10rpx;
}

.target-option {
  min-width: 70rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  text-align: center;
  color: rgba(58, 36, 24, 0.68);
  background: #FFFFFF;
  border: 1rpx solid rgba(58, 36, 24, 0.12);
  font-size: 13rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.target-option.active {
  color: #3A2418;
  background: #F1C46B;
  border-color: #D1A24F;
}

.target-section {
  margin-top: 10rpx;
  padding: 9rpx 10rpx;
  border-radius: 10rpx;
  background: rgba(255, 241, 220, 0.58);
}

.target-options {
  display: flex;
  gap: 7rpx;
}

.target-option {
  min-width: 86rpx;
}

.target-error {
  margin-top: 6rpx;
  color: #B34932;
  font-size: 11rpx;
  font-weight: 800;
  line-height: 1.35;
}

.editor-actions {
  flex: none;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: flex-end;
  gap: 8rpx;
  padding: 9rpx 14rpx 12rpx;
  border-top: 1rpx solid rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.action-error {
  margin-top: 0;
  text-align: right;
}

.editor-btn {
  min-width: 98rpx;
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #9A642A;
  background: #FFF1DC;
  font-size: 13rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.editor-btn.primary {
  min-width: 118rpx;
  color: #3A2418;
  background: #F1C46B;
}

.editor-btn.danger {
  color: #B34932;
  background: #FCE7DD;
}
