.notice-admin-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #FFF7EC;
  color: #3A2418;
  box-sizing: border-box;
}

.top-bar {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 28rpx;
  padding: 14rpx 24rpx 12rpx;
  background: #1E1714;
  color: #FFF7EC;
  box-sizing: border-box;
}

.title-block {
  min-width: 0;
}

.page-title {
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.top-actions {
  flex: none;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.top-btn {
  min-width: 104rpx;
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  text-align: center;
  color: rgba(255, 247, 236, 0.86);
  background: rgba(255, 247, 236, 0.12);
  font-size: 21rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.top-btn.primary {
  color: #3A2418;
  background: #F1C46B;
}

.main-content {
  flex: 1;
  min-height: 0;
  display: flex;
  gap: 20rpx;
  padding: 22rpx 24rpx 24rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.notice-list-panel,
.editor-panel {
  min-height: 0;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(122, 74, 31, 0.08);
  box-shadow: 0 12rpx 26rpx rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.notice-list-panel {
  width: 410rpx;
  display: flex;
  flex-direction: column;
}

.editor-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  overflow: hidden;
}

.panel-head {
  flex: none;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 20rpx 22rpx 16rpx;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.panel-title {
  color: #2C1A12;
  font-size: 25rpx;
  font-weight: 900;
}

.panel-count,
.edit-mode {
  min-width: 52rpx;
  height: 34rpx;
  line-height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #9A642A;
  background: #FFF1DC;
  font-size: 18rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.notice-list {
  flex: 1;
  min-height: 0;
  height: 100%;
  padding: 16rpx;
  box-sizing: border-box;
}

.notice-item {
  margin-bottom: 14rpx;
  padding: 18rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 2rpx solid transparent;
  box-shadow: 0 7rpx 18rpx rgba(58, 36, 24, 0.06);
  box-sizing: border-box;
}

.notice-item.active {
  border-color: #D1A24F;
  background: #FFF8EA;
}

.notice-item-head {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.notice-brief {
  flex: 1;
  min-width: 0;
  color: #2C1A12;
  font-size: 23rpx;
  font-weight: 900;
  line-height: 1.35;
  word-break: break-all;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.notice-status {
  flex: none;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  font-size: 17rpx;
  font-weight: 900;
}

.notice-status.enabled {
  color: #7A4A1F;
  background: #F5D99D;
}

.notice-status.disabled {
  color: rgba(58, 36, 24, 0.48);
  background: rgba(58, 36, 24, 0.08);
}

.notice-meta {
  margin-top: 10rpx;
  color: rgba(58, 36, 24, 0.5);
  font-size: 19rpx;
}

.notice-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 14rpx;
}

.mini-btn {
  min-width: 80rpx;
  height: 38rpx;
  line-height: 38rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #9A642A;
  background: #FFF1DC;
  font-size: 18rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.mini-btn.danger {
  color: #B34932;
  background: #FCE7DD;
}

.empty-state,
.list-loading {
  padding: 110rpx 20rpx;
  color: rgba(58, 36, 24, 0.46);
  text-align: center;
  font-size: 22rpx;
}

.editor-head {
  padding-left: 26rpx;
  padding-right: 26rpx;
}

.form-area {
  flex: 1;
  min-height: 0;
  padding: 22rpx 26rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.form-group {
  position: relative;
}

.form-label {
  margin-bottom: 10rpx;
  color: rgba(58, 36, 24, 0.68);
  font-size: 20rpx;
  font-weight: 900;
}

.content-input,
.sort-input {
  width: 100%;
  border-radius: 16rpx;
  background: #FFFFFF;
  color: #2C1A12;
  font-size: 24rpx;
  box-sizing: border-box;
}

.content-input {
  height: 168rpx;
  padding: 18rpx 20rpx 34rpx;
  line-height: 1.45;
}

.content-count {
  position: absolute;
  right: 18rpx;
  bottom: 12rpx;
  color: rgba(58, 36, 24, 0.42);
  font-size: 18rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.sort-group {
  width: 300rpx;
}

.status-group {
  flex: 1;
  min-width: 0;
}

.sort-input {
  height: 58rpx;
  padding: 0 18rpx;
}

.status-options {
  display: flex;
  gap: 12rpx;
}

.status-option {
  min-width: 110rpx;
  height: 58rpx;
  line-height: 58rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  text-align: center;
  color: rgba(58, 36, 24, 0.68);
  background: #FFFFFF;
  border: 1rpx solid rgba(58, 36, 24, 0.12);
  font-size: 21rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.status-option.active {
  color: #3A2418;
  background: #F1C46B;
  border-color: #D1A24F;
}

.preview-box {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #FFF1DC;
  border: 1rpx solid rgba(209, 162, 79, 0.24);
  box-sizing: border-box;
}

.preview-label {
  color: rgba(58, 36, 24, 0.58);
  font-size: 18rpx;
  font-weight: 900;
}

.preview-content {
  margin-top: 10rpx;
  color: #7A4A1F;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 1.4;
  word-break: break-all;
}

.editor-actions {
  flex: none;
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
  padding: 16rpx 26rpx 22rpx;
  border-top: 1rpx solid rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.editor-btn {
  min-width: 150rpx;
  height: 54rpx;
  line-height: 54rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  text-align: center;
  color: #9A642A;
  background: #FFF1DC;
  font-size: 21rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.editor-btn.primary {
  min-width: 188rpx;
  color: #3A2418;
  background: #F1C46B;
}

.editor-btn.danger {
  color: #B34932;
  background: #FCE7DD;
}