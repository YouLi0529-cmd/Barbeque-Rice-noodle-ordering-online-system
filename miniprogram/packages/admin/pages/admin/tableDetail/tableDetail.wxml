<!-- packages/admin/pages/admin/tableDetail/tableDetail.wxml -->
<view class="detail-page">
  <view class="main-layout">
    <view class="bill-shell">
      <view class="order-panel">
        <view class="bill-top">
          <view class="bill-title-row">
            <view class="panel-title">{{ui.pageTitle}}</view>
            <view class="status-pill {{table.statusClass}}">{{table.statusText}}</view>
          </view>
          <view class="table-meta-row">
            <text class="meta-strong">{{table.areaName}}{{table.tableNumber}}{{ui.tableUnit}}</text>
            <text>{{ui.people}} {{table.peopleText}}</text>
            <text class="modify-hint" bindtap="editPeople">{{ui.modifyPeople}}</text>
            <text>{{ui.diningTime}} {{table.diningTimeText}}</text>
            <text class="meta-price">{{ui.moneySymbol}}{{totalPriceText}}</text>
          </view>
          <view class="merged-table-row" wx:if="{{table.mergedTableText}}">
            <text>{{ui.mergedTables}}</text>
            <text class="merged-table-text">{{table.mergedTableText}}</text>
          </view>
        </view>

        <view class="empty-bill" wx:if="{{loading}}">
          <view class="empty-title">{{ui.loading}}</view>
        </view>

        <view class="empty-bill" wx:elif="{{!billGroups.length}}">
          <view class="empty-title">{{ui.emptyBill}}</view>
          <view class="empty-tip">{{ui.emptyTip}}</view>
        </view>

        <scroll-view class="bill-groups" scroll-y wx:else>
          <view class="bill-group" wx:for="{{billGroups}}" wx:key="id">
            <view
              class="bill-group-head {{item.selected ? 'bill-group-head-active' : ''}} {{item.partialSelected ? 'bill-group-head-partial' : ''}}"
              data-group-id="{{item.id}}"
              bindtap="toggleGroupSelection"
            >
              <view class="bill-group-title-wrap">
                <view class="bill-group-check {{item.selected ? 'bill-group-check-active' : ''}} {{item.partialSelected ? 'bill-group-check-partial' : ''}}"></view>
                <view>
                <view class="bill-group-title">{{item.title}}</view>
                <view class="bill-group-meta">{{item.statusText}}</view>
                </view>
              </view>
              <view class="bill-group-price">{{ui.moneySymbol}}{{item.finalPriceText}}</view>
            </view>

            <view
              class="dish-row {{dish.selected ? 'dish-row-active' : ''}}"
              wx:for="{{item.goods}}"
              wx:for-item="dish"
              wx:for-index="dishIndex"
              wx:key="rowId"
              data-row-id="{{dish.rowId}}"
              data-dish-name="{{dish.dishName}}"
              data-dish-index="{{dishIndex}}"
              data-group-id="{{item.id}}"
              bindtap="toggleDishSelection"
            >
              <view
                class="dish-check-wrap"
                data-row-id="{{dish.rowId}}"
                data-dish-name="{{dish.dishName}}"
                data-dish-index="{{dishIndex}}"
                data-group-id="{{item.id}}"
                bindtouchstart="startDishDragSelect"
                bindtouchmove="moveDishDragSelect"
                bindtouchend="endDishDragSelect"
                bindtouchcancel="endDishDragSelect"
                catchtap="toggleDishSelection"
              >
                <view class="dish-check {{dish.selected ? 'dish-check-active' : ''}}"></view>
              </view>
              <view class="dish-main">
                <view class="dish-name">
                  <text class="dish-name-text">{{dish.dishName}}</text>
                  <text class="dish-sent-tag" wx:if="{{dish.kitchenSent}}">已发送</text>
                </view>
                <view class="dish-tags" wx:if="{{dish.tagText}}">{{dish.tagText}}</view>
                <view class="dish-tags" wx:if="{{dish.remarkText}}">{{dish.remarkText}}</view>
              </view>
              <view class="dish-count">x{{dish.count}}</view>
              <view class="dish-price">{{ui.moneySymbol}}{{dish.subtotalText}}</view>
            </view>
          </view>
        </scroll-view>

        <view class="bill-total">
          <view class="mini-send-kitchen" bindtap="sendKitchen">{{ui.sendKitchen}}</view>
          <view class="total-area">
            <text>{{ui.total}}</text>
            <text class="total-price">{{ui.moneySymbol}}{{totalPriceText}}</text>
          </view>
          <view class="mini-refresh" bindtap="loadDetail">{{ui.refresh}}</view>
        </view>
      </view>

      <view class="dish-action-strip">
        <view class="strip-title">{{ui.dishActions}}</view>
        <view
          class="operation-btn"
          wx:for="{{dishActions}}"
          wx:key="*this"
          data-action="{{item}}"
          bindtap="handleDishAction"
        >
          {{item}}
        </view>
      </view>
    </view>

    <view class="pay-panel">
      <view class="panel-title">{{ui.payTitle}}</view>

      <view class="pay-section">
        <view class="pay-section-title">{{ui.discountTitle}}</view>
        <view class="option-row">
          <view
            class="pay-option {{item.value === 'direct_reduce' ? (directReduceValue !== '' ? 'pay-option-active' : '') : (discountType === item.value ? 'pay-option-active' : '')}}"
            wx:for="{{discountOptions}}"
            wx:key="value"
            data-value="{{item.value}}"
            bindtap="selectDiscount"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="pay-section">
        <view class="pay-section-title">{{ui.paymentTitle}}</view>
        <view class="option-row">
          <view
            class="pay-option {{paymentMethod === item.value ? 'pay-option-active' : ''}}"
            wx:for="{{paymentOptions}}"
            wx:key="value"
            data-value="{{item.value}}"
            bindtap="selectPayment"
          >
            {{item.label}}
          </view>
        </view>
      </view>

      <view class="summary-card">
        <view class="summary-title">{{ui.billSummary}}</view>
        <view class="summary-row">
          <text>{{ui.priceTotal}}</text>
          <text>{{ui.moneySymbol}}{{paySummary.totalText}}</text>
        </view>
        <view class="summary-row strong-row">
          <view class="discount-summary-label">
            <text>{{ui.receivable}}</text>
            <text class="discount-summary-text" wx:if="{{paySummary.discountText}}">{{paySummary.discountText}}</text>
          </view>
          <text>{{ui.moneySymbol}}{{paySummary.receivableText}}</text>
        </view>
        <view class="summary-row">
          <text>{{paySummary.paymentLabel}}</text>
          <text>{{ui.actualReceived}}{{ui.moneySymbol}}{{paySummary.receivedText}}</text>
        </view>
      </view>

      <button
        class="checkout-btn"
        loading="{{checkingOut}}"
        disabled="{{checkingOut}}"
        bindtap="finishCheckout"
      >{{ui.finishCheckout}}</button>
    </view>
  </view>
  <view class="discount-mask" wx:if="{{showDiscountDialog}}" catchtap="closeDiscountDialog">
    <view class="discount-dialog" catchtap="stopDiscountDialogTap">
      <view class="discount-title">{{discountDialogType === 'direct_reduce' ? ui.directReduceDialogTitle : ui.discountDialogTitle}}</view>
      <input
        class="discount-input"
        type="digit"
        value="{{discountInput}}"
        placeholder="{{discountDialogType === 'direct_reduce' ? ui.directReduceInputPlaceholder : ui.discountInputPlaceholder}}"
        bindinput="onDiscountInput"
      />
      <view class="discount-actions">
        <view class="discount-action cancel" bindtap="closeDiscountDialog">{{ui.discountCancel}}</view>
        <view class="discount-action confirm" bindtap="confirmDiscountDialog">{{ui.discountConfirm}}</view>
      </view>
    </view>
  </view>
  <view class="people-mask" wx:if="{{showPeopleDialog}}" catchtap="closePeopleDialog">
    <view class="people-dialog" catchtap="stopPeopleDialogTap">
      <view class="people-title">{{ui.peopleDialogTitle}}</view>
      <input
        class="people-input"
        type="number"
        value="{{peopleInput}}"
        placeholder="{{ui.peopleInputPlaceholder}}"
        bindinput="onPeopleInput"
      />
      <view class="people-actions">
        <view class="people-action cancel" bindtap="closePeopleDialog">{{ui.discountCancel}}</view>
        <view class="people-action confirm" bindtap="confirmPeopleDialog">{{ui.discountConfirm}}</view>
      </view>
    </view>
  </view>
  <view class="edit-dish-mask" wx:if="{{showEditDishDialog}}" catchtap="closeEditDishDialog">
    <view class="edit-dish-dialog" catchtap="stopEditDishDialogTap">
      <view class="edit-dish-title">{{ui.editDishTitle}}</view>
      <view class="edit-dish-name">{{editDishTitle}}</view>
      <view class="edit-dish-form">
        <view class="edit-dish-field">
          <view class="edit-dish-label">{{ui.editDishOptionsLabel}}</view>
          <input
            class="edit-dish-input"
            value="{{editDishOptionsInput}}"
            placeholder="{{ui.editDishOptionsPlaceholder}}"
            bindinput="onEditDishOptionsInput"
          />
        </view>
        <view class="edit-dish-field">
          <view class="edit-dish-label">{{ui.editDishRemarkLabel}}</view>
          <input
            class="edit-dish-input"
            maxlength="50"
            value="{{editDishRemark}}"
            placeholder="{{ui.editDishRemarkPlaceholder}}"
            bindinput="onEditDishRemarkInput"
          />
        </view>
      </view>
      <view class="edit-dish-actions">
        <view class="edit-dish-action cancel" bindtap="closeEditDishDialog">{{ui.discountCancel}}</view>
        <view class="edit-dish-action confirm" bindtap="confirmEditDishDialog">{{ui.discountConfirm}}</view>
      </view>
    </view>
  </view>
  <view class="merge-mask" wx:if="{{showMergeDialog}}" catchtap="closeMergeDialog">
    <view class="merge-dialog" catchtap="stopMergeDialogTap">
      <view class="merge-head">
        <view>
          <view class="merge-title">{{ui.mergeDialogTitle}}</view>
          <view class="merge-tip">{{ui.mergeDialogTip}}</view>
        </view>
        <view class="merge-close" bindtap="closeMergeDialog">×</view>
      </view>

      <view class="merge-loading" wx:if="{{mergeLoading}}">{{ui.loading}}</view>
      <view class="merge-loading" wx:elif="{{!mergeTableSections.length}}">{{ui.mergeEmpty}}</view>
      <scroll-view class="merge-table-board" scroll-y wx:else>
        <view class="merge-section" wx:for="{{mergeTableSections}}" wx:for-item="section" wx:key="areaKey">
          <view class="merge-section-title">{{section.areaName}}</view>
          <view class="merge-table-grid">
            <view
              class="merge-table-card {{table.statusClass}} {{table.selected ? 'merge-table-card-active' : ''}}"
              wx:for="{{section.tables}}"
              wx:for-item="table"
              wx:key="tableKey"
              data-table-key="{{table.tableKey}}"
              bindtap="toggleMergeTable"
            >
              <view class="merge-table-name">{{table.label}}</view>
              <view class="merge-table-info">
                <text>{{ui.moneySymbol}}{{table.priceText}}</text>
                <text>{{table.peopleText}}</text>
              </view>
              <view class="merge-table-status">{{table.statusText}}</view>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="merge-actions">
        <view class="merge-action cancel" bindtap="closeMergeDialog">{{ui.discountCancel}}</view>
        <view
          class="merge-action confirm"
          bindtap="confirmMergeTables"
        >{{ui.mergeTable}} {{selectedMergeTableCount}}</view>
      </view>
    </view>
  </view>
</view>
<admin-info-center />
