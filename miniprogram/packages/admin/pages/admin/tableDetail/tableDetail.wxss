page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #FFF7EC;
}

.detail-page {
  width: 100vw;
  height: 100vh;
  padding: 8rpx;
  color: #3A2418;
  background: #FFF7EC;
  box-sizing: border-box;
  overflow: hidden;
}

.main-layout {
  width: 100%;
  height: 100%;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 300rpx;
  gap: 8rpx;
  overflow: hidden;
}

.bill-shell {
  min-width: 0;
  height: 100%;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 60rpx;
  gap: 8rpx;
  overflow: hidden;
}

.order-panel,
.dish-action-strip,
.pay-panel {
  min-width: 0;
  height: 100%;
  border-radius: 10rpx;
  background: #FFFFFF;
  border: 1rpx solid rgba(58, 36, 24, 0.08);
  box-shadow: 0 5rpx 14rpx rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
  overflow: hidden;
}

.order-panel {
  display: flex;
  flex-direction: column;
  padding: 8rpx 10rpx 0;
}

.bill-top {
  flex: none;
  padding-bottom: 7rpx;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.08);
}

.bill-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.panel-title {
  color: #2C1A12;
  font-size: 12rpx;
  font-weight: 900;
  line-height: 1.15;
}

.status-pill {
  min-width: 48rpx;
  height: 20rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  text-align: center;
  line-height: 20rpx;
  font-size: 9rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.table-meta-row {
  margin-top: 6rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
  color: rgba(58, 36, 24, 0.56);
  font-size: 10rpx;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
}

.meta-strong {
  color: #2C1A12;
  font-size: 12rpx;
  font-weight: 900;
}

.modify-hint {
  color: #9B541D;
  font-size: 9rpx;
  font-weight: 900;
  text-decoration: underline;
}

.meta-price {
  margin-left: auto;
  color: #B15B18;
  font-size: 12rpx;
  font-weight: 900;
}

.merged-table-row {
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
  color: rgba(58, 36, 24, 0.5);
  font-size: 8rpx;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
}

.merged-table-text {
  min-width: 0;
  color: #8A4B18;
  overflow: hidden;
  text-overflow: ellipsis;
}

.empty-bill {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-title {
  color: rgba(58, 36, 24, 0.72);
  font-size: 12rpx;
  font-weight: 900;
}

.empty-tip {
  margin-top: 6rpx;
  color: rgba(58, 36, 24, 0.42);
  font-size: 9rpx;
  font-weight: 700;
}

.bill-groups {
  flex: 1;
  min-height: 0;
  height: 0;
  box-sizing: border-box;
}

.bill-group {
  padding: 7rpx 0;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.08);
}

.bill-group:last-child {
  border-bottom: 0;
}

.bill-group-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 4rpx;
  padding: 3rpx 5rpx;
  border-radius: 6rpx;
  transition: background 0.12s ease, box-shadow 0.12s ease;
}

.bill-group-head-active,
.bill-group-head-partial {
  background: #FFF7EC;
  box-shadow: inset 0 0 0 1rpx rgba(189, 123, 35, 0.18);
}

.bill-group-title-wrap {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.bill-group-check {
  width: 10rpx;
  height: 10rpx;
  flex: none;
  border-radius: 50%;
  border: 1rpx solid rgba(177, 91, 24, 0.28);
  background: #FFFFFF;
  box-sizing: border-box;
}

.bill-group-check-active {
  border-color: #B15B18;
  background: #D6A343;
  box-shadow: 0 0 0 2rpx rgba(214, 163, 67, 0.16);
}

.bill-group-check-partial {
  border-color: #B15B18;
  background: linear-gradient(90deg, #D6A343 50%, #FFFFFF 50%);
}

.bill-group-title {
  color: #2C1A12;
  font-size: 10rpx;
  font-weight: 900;
  line-height: 1.2;
}

.bill-group-meta {
  margin-top: 2rpx;
  color: rgba(58, 36, 24, 0.42);
  font-size: 8rpx;
  font-weight: 800;
}

.bill-group-price {
  color: #B15B18;
  font-size: 10rpx;
  font-weight: 900;
  white-space: nowrap;
}

.dish-row {
  min-height: 24rpx;
  display: grid;
  grid-template-columns: 16rpx minmax(0, 1fr) 30rpx 56rpx;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 5rpx;
  border-radius: 6rpx;
  box-sizing: border-box;
  transition: background 0.12s ease, box-shadow 0.12s ease;
}

.dish-row-active {
  background: #FFF2D3;
  box-shadow: inset 0 0 0 1rpx rgba(189, 123, 35, 0.3);
}

.dish-main {
  min-width: 0;
}

.dish-check-wrap {
  width: 16rpx;
  height: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dish-check {
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(177, 91, 24, 0.28);
  background: #FFFFFF;
  box-sizing: border-box;
}

.dish-check-active {
  border-color: #B15B18;
  background: #D6A343;
  box-shadow: 0 0 0 2rpx rgba(214, 163, 67, 0.16);
}

.dish-name {
  color: #2C1A12;
  font-size: 10rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-tags {
  margin-top: 2rpx;
  color: rgba(58, 36, 24, 0.46);
  font-size: 8rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-count {
  color: rgba(58, 36, 24, 0.58);
  font-size: 9rpx;
  font-weight: 900;
  text-align: center;
}

.dish-price {
  color: #B15B18;
  font-size: 9rpx;
  font-weight: 900;
  text-align: right;
  white-space: nowrap;
}

.bill-total {
  height: 26rpx;
  flex: none;
  display: grid;
  grid-template-columns: 64rpx minmax(0, 1fr) 42rpx;
  align-items: center;
  gap: 6rpx;
  border-top: 1rpx solid rgba(58, 36, 24, 0.08);
  color: rgba(58, 36, 24, 0.64);
  font-size: 10rpx;
  font-weight: 900;
}

.total-area {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-width: 0;
}

.total-price {
  color: #B15B18;
  font-size: 13rpx;
}

.mini-back,
.mini-send-kitchen,
.mini-refresh,
.operation-btn,
.pay-option,
.checkout-btn {
  margin: 0;
  padding: 0;
  border: 0;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
  overflow: hidden;
}

.mini-back::after,
.mini-send-kitchen::after,
.mini-refresh::after,
.operation-btn::after,
.pay-option::after,
.checkout-btn::after {
  border: 0;
}

.mini-back,
.mini-send-kitchen,
.mini-refresh {
  height: 18rpx;
  border-radius: 999rpx;
  color: #6B4B34;
  background: #FFF7EC;
  font-size: 9rpx;
  font-weight: 900;
  line-height: 18rpx;
}

.mini-back,
.mini-refresh {
  width: 42rpx;
}

.mini-send-kitchen {
  width: 64rpx;
  color: #FFF7EC;
  background: #B15B18;
  font-size: 8rpx;
}

.dish-action-strip {
  padding: 5rpx 3rpx;
}

.strip-title {
  margin-bottom: 4rpx;
  color: rgba(58, 36, 24, 0.62);
  font-size: 8rpx;
  font-weight: 900;
  text-align: center;
}

.operation-btn {
  width: 100%;
  min-height: 18rpx;
  margin-bottom: 3rpx;
  border-radius: 5rpx;
  color: #4B2B18;
  background: #FFF2D3;
  font-size: 8rpx;
  font-weight: 900;
  line-height: 18rpx;
  border: 1rpx solid rgba(177, 91, 24, 0.16);
}

.operation-btn:last-child {
  margin-bottom: 0;
}

.pay-panel {
  display: flex;
  flex-direction: column;
  padding: 10rpx;
}

.pay-section {
  margin-top: 10rpx;
}

.pay-section-title,
.summary-title {
  color: rgba(58, 36, 24, 0.62);
  font-size: 9rpx;
  font-weight: 900;
}

.option-row {
  margin-top: 6rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 5rpx;
}

.pay-option {
  height: 24rpx;
  border-radius: 6rpx;
  color: #5B351E;
  background: #FFF7EC;
  font-size: 8rpx;
  font-weight: 900;
  line-height: 24rpx;
  border: 1rpx solid rgba(58, 36, 24, 0.1);
}

.pay-option-active {
  color: #2C1A12;
  background: #F5D58B;
  border-color: rgba(177, 91, 24, 0.32);
}

.summary-card {
  margin-top: 12rpx;
  padding: 9rpx;
  border-radius: 9rpx;
  background: #FFF7EC;
  border: 1rpx solid rgba(58, 36, 24, 0.08);
}

.summary-row {
  height: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: rgba(58, 36, 24, 0.62);
  font-size: 9rpx;
  font-weight: 800;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.06);
}


.discount-summary-label {
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
}

.discount-summary-text {
  color: #B15B18;
  font-size: 8rpx;
  font-weight: 900;
}
.summary-row:last-child {
  border-bottom: 0;
}

.strong-row {
  color: #2C1A12;
  font-size: 11rpx;
  font-weight: 900;
}

.checkout-btn {
  height: 38rpx;
  margin-top: auto;
  border-radius: 10rpx;
  color: #FFF7EC;
  background: #B15B18;
  font-size: 11rpx;
  font-weight: 900;
  line-height: 38rpx;
  box-shadow: 0 5rpx 12rpx rgba(177, 91, 24, 0.2);
}

.status-empty {
  color: #3A2418;
  background: #FFFFFF;
  border: 1rpx solid rgba(58, 36, 24, 0.12);
}

.status-submitted {
  color: #3A2418;
  background: #F1C46B;
}

.status-preparing {
  color: #FFF7EC;
  background: #C85F1D;
}

.status-paid {
  color: #FFF7EC;
  background: #4B9D64;
}
.discount-mask,
.people-mask,
.merge-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.34);
}

.discount-dialog,
.people-dialog {
  width: 260rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 28rpx rgba(58, 36, 24, 0.22);
  box-sizing: border-box;
}

.discount-title,
.people-title {
  color: #2C1A12;
  font-size: 15rpx;
  font-weight: 900;
  text-align: center;
}

.discount-input,
.people-input {
  height: 38rpx;
  margin-top: 14rpx;
  padding: 0 12rpx;
  border-radius: 9rpx;
  background: #FFF7EC;
  color: #2C1A12;
  font-size: 14rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.discount-actions,
.people-actions {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.discount-action,
.people-action {
  height: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9rpx;
  font-size: 13rpx;
  font-weight: 900;
}

.discount-action.cancel,
.people-action.cancel {
  color: #6B4B34;
  background: #FFF7EC;
}

.discount-action.confirm,
.people-action.confirm {
  color: #FFF7EC;
  background: #B15B18;
}

.merge-dialog {
  width: 560rpx;
  height: 330rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #FFFFFF;
  box-shadow: 0 12rpx 28rpx rgba(58, 36, 24, 0.22);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.merge-head {
  flex: none;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.merge-title {
  color: #2C1A12;
  font-size: 14rpx;
  font-weight: 900;
  line-height: 1.2;
}

.merge-tip {
  margin-top: 4rpx;
  color: rgba(58, 36, 24, 0.48);
  font-size: 8rpx;
  font-weight: 800;
}

.merge-close {
  width: 24rpx;
  height: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: rgba(58, 36, 24, 0.62);
  background: #FFF7EC;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 24rpx;
}

.merge-loading {
  flex: 1;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(58, 36, 24, 0.58);
  font-size: 12rpx;
  font-weight: 900;
}

.merge-table-board {
  flex: 1;
  min-height: 0;
  height: 0;
  margin-top: 10rpx;
}

.merge-section {
  margin-bottom: 10rpx;
}

.merge-section-title {
  margin-bottom: 5rpx;
  color: rgba(58, 36, 24, 0.58);
  font-size: 9rpx;
  font-weight: 900;
}

.merge-table-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 7rpx;
}

.merge-table-card {
  min-width: 0;
  height: 58rpx;
  padding: 6rpx 7rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(58, 36, 24, 0.1);
  box-shadow: 0 4rpx 10rpx rgba(58, 36, 24, 0.08);
}

.merge-table-card-active {
  border-color: #B15B18;
  box-shadow: 0 0 0 2rpx rgba(214, 163, 67, 0.22), 0 5rpx 14rpx rgba(58, 36, 24, 0.14);
}

.merge-table-name {
  color: #2C1A12;
  font-size: 10rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.merge-table-info {
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: rgba(58, 36, 24, 0.62);
  font-size: 8rpx;
  font-weight: 900;
}

.merge-table-status {
  margin-top: 3rpx;
  color: rgba(58, 36, 24, 0.48);
  font-size: 7rpx;
  font-weight: 900;
}

.merge-actions {
  flex: none;
  margin-top: 10rpx;
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 10rpx;
}

.merge-action {
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9rpx;
  font-size: 11rpx;
  font-weight: 900;
}

.merge-action.cancel {
  color: #6B4B34;
  background: #FFF7EC;
}

.merge-action.confirm {
  color: #FFF7EC;
  background: #B15B18;
}
