<view class="table-code-page">
  <view class="table-code-header">
    <view>
      <view class="page-title">{{ui.title}}</view>
      <view class="page-subtitle">{{ui.subtitle}}</view>
    </view>
    <view class="header-actions">
      <view class="header-action" bindtap="loadList">{{ui.refresh}}</view>
      <view class="header-action primary {{batchGenerating ? 'disabled' : ''}}" bindtap="generateMissingCodes">
        {{batchGenerating ? ui.generating : ui.generateMissing}}
      </view>
    </view>
  </view>

  <view class="progress-tip" wx:if="{{batchGenerating}}">{{ui.generating}} {{batchProgress}}</view>

  <scroll-view class="table-code-scroll" scroll-y>
    <view class="table-code-section" wx:for="{{sections}}" wx:for-item="section" wx:key="areaKey">
      <view class="section-title">{{section.name}}</view>
      <view class="table-code-grid">
        <view class="table-code-card" wx:for="{{section.tables}}" wx:for-item="table" wx:key="tableKey">
          <view class="table-name">{{table.tableNumber}}{{ui.tableSuffix}}</view>
          <image class="table-qr" wx:if="{{table.hasCode}}" src="{{table.qrCodeUrl}}" mode="aspectFit" />
          <view class="table-qr-placeholder" wx:else>{{ui.notGenerated}}</view>
          <view class="table-card-actions">
            <view
              class="table-action primary {{generatingKey === table.tableKey ? 'disabled' : ''}}"
              bindtap="generateCode"
              data-area-key="{{table.areaKey}}"
              data-table-number="{{table.tableNumber}}"
              data-table-key="{{table.tableKey}}">
              {{generatingKey === table.tableKey ? ui.generating : (table.hasCode ? ui.regenerate : ui.generate)}}
            </view>
            <view class="table-action" wx:if="{{table.hasCode}}" bindtap="previewCode" data-url="{{table.qrCodeUrl}}">{{ui.preview}}</view>
            <view class="table-action" wx:if="{{table.hasCode}}" bindtap="saveCode" data-url="{{table.qrCodeUrl}}">{{ui.save}}</view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
