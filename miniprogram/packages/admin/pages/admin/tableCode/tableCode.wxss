.admin-simple-page {
  min-height: 100vh;
  background: #FFF7EC;
  color: #3A2418;
  box-sizing: border-box;
}

.admin-simple-header {
  padding: 28rpx 24rpx 22rpx;
  background: #1E1714;
  color: #FFF7EC;
}

.admin-simple-title {
  font-size: 38rpx;
  font-weight: 900;
}

.admin-simple-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.header-btn {
  min-width: 128rpx;
  height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  border-radius: 999rpx;
  color: rgba(255, 247, 236, 0.86);
  background: rgba(255, 247, 236, 0.12);
  font-size: 25rpx;
  font-weight: 900;
}

.header-btn.primary {
  color: #3A2418;
  background: #F1C46B;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 20rpx 24rpx 0;
}

.search-input {
  flex: 1;
  height: 70rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  font-size: 25rpx;
  box-sizing: border-box;
}

.search-btn,
.clear-btn {
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 900;
}

.search-btn {
  width: 110rpx;
  color: #3A2418;
  background: #F1C46B;
}

.clear-btn {
  width: 70rpx;
  color: rgba(58, 36, 24, 0.58);
  background: #FFF1DC;
}

.admin-list {
  height: calc(100vh - 190rpx);
  padding: 22rpx 24rpx 38rpx;
  box-sizing: border-box;
}

.admin-card {
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-radius: 18rpx;
  background: #FFFFFF;
  box-shadow: 0 10rpx 26rpx rgba(58, 36, 24, 0.08);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.card-title {
  flex: 1;
  min-width: 0;
  color: #2C1A12;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.35;
  word-break: break-all;
}

.card-status {
  max-width: 180rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  color: #9A642A;
  background: #FFF1DC;
  font-size: 21rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-subtitle {
  margin-top: 8rpx;
  color: rgba(58, 36, 24, 0.56);
  font-size: 24rpx;
}

.line-row {
  display: flex;
  gap: 18rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.line-label {
  width: 150rpx;
  flex-shrink: 0;
  color: rgba(58, 36, 24, 0.5);
}

.line-value {
  flex: 1;
  color: rgba(58, 36, 24, 0.82);
  word-break: break-all;
}

.card-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.mini-btn {
  min-width: 112rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 999rpx;
  color: #9A642A;
  background: #FFF1DC;
  font-size: 23rpx;
  font-weight: 900;
}

.mini-btn.danger {
  color: #C04B36;
}

.empty-text {
  padding: 120rpx 20rpx;
  color: rgba(58, 36, 24, 0.46);
  text-align: center;
  font-size: 26rpx;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(0, 0, 0, 0.45);
  box-sizing: border-box;
}

.modal-dialog {
  width: 100%;
  max-height: 88vh;
  overflow: hidden;
  border-radius: 24rpx;
  background: #FFF7EC;
}

.modal-title {
  padding: 28rpx 30rpx 18rpx;
  color: #2C1A12;
  font-size: 32rpx;
  font-weight: 900;
}

.modal-content {
  max-height: 62vh;
  padding: 0 30rpx 22rpx;
  box-sizing: border-box;
}

.form-item {
  margin-top: 20rpx;
}

.form-label {
  margin-bottom: 10rpx;
  color: rgba(58, 36, 24, 0.72);
  font-size: 24rpx;
  font-weight: 900;
}

.form-input,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 14rpx;
  background: #FFFFFF;
  color: #2C1A12;
  font-size: 26rpx;
}

.form-input {
  height: 72rpx;
  padding: 0 20rpx;
}

.form-textarea {
  min-height: 140rpx;
  padding: 18rpx 20rpx;
}

.switch-row {
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 18rpx;
  border-radius: 14rpx;
  background: #FFFFFF;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  gap: 18rpx;
  padding: 22rpx 30rpx 30rpx;
  border-top: 1rpx solid rgba(58, 36, 24, 0.08);
}

.modal-btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  text-align: center;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.modal-btn.cancel {
  color: #7A6659;
  background: #FFFFFF;
}

.modal-btn.confirm {
  color: #3A2418;
  background: #F1C46B;
}

.table-code-page {
  min-height: 100vh;
  background: #fff7ec;
  color: #3a2418;
  box-sizing: border-box;
}

.table-code-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.1);
  background: #fff2dd;
}

.page-title {
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.page-subtitle {
  margin-top: 6rpx;
  color: rgba(58, 36, 24, 0.58);
  font-size: 20rpx;
}

.header-actions {
  display: flex;
  gap: 10rpx;
  flex: none;
}

.header-action,
.table-action {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 1rpx solid rgba(143, 62, 23, 0.18);
  border-radius: 10rpx;
  color: #8f3e17;
  background: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
}

.header-action {
  min-width: 106rpx;
  height: 52rpx;
  padding: 0 14rpx;
}

.header-action.primary,
.table-action.primary {
  color: #ffffff;
  border-color: #b36a27;
  background: #b36a27;
}

.disabled {
  opacity: 0.52;
}

.progress-tip {
  padding: 10rpx 28rpx;
  color: #8f3e17;
  background: rgba(241, 196, 107, 0.26);
  font-size: 20rpx;
  font-weight: 800;
}

.table-code-scroll {
  height: calc(100vh - 122rpx);
  padding: 20rpx 28rpx 40rpx;
  box-sizing: border-box;
}

.table-code-section {
  margin-bottom: 28rpx;
}

.section-title {
  margin-bottom: 12rpx;
  color: #6f3b1d;
  font-size: 24rpx;
  font-weight: 900;
}

.table-code-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(170rpx, 1fr));
  gap: 12rpx;
}

.table-code-card {
  min-width: 0;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(58, 36, 24, 0.08);
  box-sizing: border-box;
}

.table-name {
  margin-bottom: 10rpx;
  color: #3a2418;
  font-size: 22rpx;
  font-weight: 900;
}

.table-qr,
.table-qr-placeholder {
  width: 100%;
  height: 144rpx;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.table-qr {
  display: block;
  background: #ffffff;
}

.table-qr-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(58, 36, 24, 0.42);
  border: 1rpx dashed rgba(58, 36, 24, 0.2);
  background: #fffaf3;
  font-size: 18rpx;
}

.table-card-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.table-action {
  min-width: 56rpx;
  height: 40rpx;
  padding: 0 10rpx;
  font-size: 18rpx;
}
