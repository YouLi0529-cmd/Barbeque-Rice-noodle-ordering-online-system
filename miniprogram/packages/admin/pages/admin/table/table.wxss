page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #FFF7EC;
}

.table-page {
  width: 100vw;
  height: 100vh;
  color: #3A2418;
  background: #FFF7EC;
  overflow: hidden;
}

.table-board {
  height: calc(100vh - 34rpx);
  padding: 14rpx 18rpx 8rpx;
  box-sizing: border-box;
}

.table-section {
  margin-bottom: 8rpx;
}

.section-title {
  margin: 0 0 8rpx;
  color: rgba(58, 36, 24, 0.58);
  font-size: 15rpx;
  font-weight: 900;
  line-height: 1;
}

.table-section-body {
  font-size: 0;
}

.table-card {
  width: 11.55%;
  min-height: 76rpx;
  margin: 0 1.08% 10rpx 0;
  padding: 7rpx 9rpx 7rpx;
  display: inline-flex;
  flex-direction: column;
  vertical-align: top;
  border-radius: 10rpx;
  box-sizing: border-box;
  box-shadow:
    0 8rpx 18rpx rgba(58, 36, 24, 0.16),
    0 2rpx 4rpx rgba(58, 36, 24, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.42);
  border: 1rpx solid rgba(58, 36, 24, 0.13);
}

.table-card:nth-child(8n) {
  margin-right: 0;
}

.table-card-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 4rpx;
}

.table-name {
  display: flex;
  align-items: baseline;
  min-width: 0;
  flex-shrink: 0;
}

.table-number {
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1;
}

.table-unit {
  margin-left: 3rpx;
  color: rgba(58, 36, 24, 0.48);
  font-size: 10rpx;
  font-weight: 900;
  white-space: nowrap;
}

.compact-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4rpx;
  margin-top: 3rpx;
  font-size: 11rpx;
  line-height: 1.25;
}

.price-line {
  display: flex;
  align-items: baseline;
  justify-content: flex-start;
  gap: 2rpx;
  margin-top: 4rpx;
  min-width: 0;
}

.money-icon {
  color: #9A642A;
  font-size: 10rpx;
  font-weight: 800;
  white-space: nowrap;
}

.info-icon {
  position: relative;
  width: 10rpx;
  height: 10rpx;
  flex: 0 0 10rpx;
  color: rgba(58, 36, 24, 0.5);
  box-sizing: border-box;
}

.people-icon::before {
  position: absolute;
  top: 0;
  left: 3rpx;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: currentColor;
  content: "";
}

.people-icon::after {
  position: absolute;
  right: 1rpx;
  bottom: 0;
  left: 1rpx;
  height: 5rpx;
  border-radius: 6rpx 6rpx 2rpx 2rpx;
  background: currentColor;
  content: "";
}

.time-icon {
  border: 1rpx solid currentColor;
  border-radius: 50%;
}

.time-icon::before {
  position: absolute;
  top: 2rpx;
  left: 4rpx;
  width: 1rpx;
  height: 4rpx;
  background: currentColor;
  border-radius: 999rpx;
  content: "";
}

.time-icon::after {
  position: absolute;
  top: 5rpx;
  left: 4rpx;
  width: 4rpx;
  height: 1rpx;
  background: currentColor;
  border-radius: 999rpx;
  content: "";
}

.line-value {
  flex: 1;
  min-width: 0;
  text-align: left;
  color: #2C1A12;
  font-size: 12rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-value {
  flex: none;
  color: #8F3E17;
  font-size: 14rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time-line .line-value {
  font-size: 10rpx;
  font-weight: 800;
}

.table-card.status-empty {
  background: #FFFFFF;
  color: #3A2418;
}

.table-card.status-submitted {
  background: #F1C46B;
  color: #3A2418;
}

.table-card.status-preparing {
  background: #C85F1D;
  color: #FFF7EC;
}

.table-card.status-paid {
  background: #4B9D64;
  color: #FFF7EC;
}

.table-card.status-preparing .table-unit,
.table-card.status-preparing .money-icon,
.table-card.status-preparing .info-icon,
.table-card.status-preparing .line-value,
.table-card.status-preparing .price-value,
.table-card.status-paid .table-unit,
.table-card.status-paid .money-icon,
.table-card.status-paid .info-icon,
.table-card.status-paid .line-value,
.table-card.status-paid .price-value {
  color: rgba(255, 247, 236, 0.92);
}

.legend-footer {
  height: 34rpx;
  padding: 0 18rpx 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-sizing: border-box;
  background: #FFF7EC;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 5rpx;
  color: rgba(58, 36, 24, 0.52);
  font-size: 11rpx;
  font-weight: 800;
}

.legend-dot {
  width: 9rpx;
  height: 9rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(58, 36, 24, 0.12);
  box-sizing: border-box;
}

.legend-dot.status-empty {
  background: #FFFFFF;
}

.legend-dot.status-submitted {
  background: #F1C46B;
}

.legend-dot.status-preparing {
  background: #C85F1D;
}

.legend-dot.status-paid {
  background: #4B9D64;
}
