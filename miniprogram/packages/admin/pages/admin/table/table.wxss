page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #FFF7EC;
}

.table-page {
  width: 100vw;
  height: 100vh;
  color: #3A2418;
  background: #FFF7EC;
  overflow: hidden;
}

.transfer-banner {
  height: 38rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  box-sizing: border-box;
  background: #2C1A12;
  color: #FFF7EC;
}

.transfer-copy {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  white-space: nowrap;
  overflow: hidden;
}

.transfer-title {
  font-size: 13rpx;
  font-weight: 900;
}

.transfer-source {
  color: #F5D58B;
  font-size: 13rpx;
  font-weight: 900;
}

.transfer-tip {
  color: rgba(255, 247, 236, 0.72);
  font-size: 10rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
}

.transfer-cancel {
  width: 74rpx;
  height: 24rpx;
  flex: none;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(255, 247, 236, 0.14);
  color: #FFF7EC;
  font-size: 10rpx;
  font-weight: 900;
}

.merge-banner-actions {
  flex: none;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.merge-count {
  height: 24rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #2C1A12;
  background: #F5D58B;
  font-size: 10rpx;
  font-weight: 900;
}

.merge-confirm {
  height: 24rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  color: #2C1A12;
  background: #FFF7EC;
  font-size: 10rpx;
  font-weight: 900;
}

.reservation-reminder-bar {
  height: 46rpx;
  padding: 6rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-sizing: border-box;
  background: #FFF7EC;
  border-bottom: 1rpx solid rgba(58, 36, 24, 0.08);
}

.reservation-reminder-copy {
  width: 58rpx;
  flex: none;
  min-width: 0;
}

.reservation-reminder-title {
  color: #3A2418;
  font-size: 12rpx;
  font-weight: 900;
  line-height: 1.15;
}

.reservation-reminder-scroll {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
}

.reservation-reminder-list {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  min-width: 100%;
}

.reservation-reminder-card {
  height: 32rpx;
  padding: 0 10rpx;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  border-radius: 9rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  border: 1rpx solid rgba(154, 100, 42, 0.18);
  box-shadow: 0 5rpx 12rpx rgba(58, 36, 24, 0.08);
}

.reservation-reminder-card.selected {
  background: rgba(245, 213, 139, 0.2);
  border-color: rgba(177, 91, 24, 0.72);
  box-shadow:
    0 0 0 2rpx rgba(245, 213, 139, 0.42),
    0 5rpx 12rpx rgba(58, 36, 24, 0.1);
}

.reservation-reminder-card.priority {
  background: #FFF2EF;
  border-color: rgba(201, 52, 28, 0.6);
  box-shadow: 0 5rpx 12rpx rgba(201, 52, 28, 0.16);
}

.reservation-reminder-card.priority.selected {
  background: #FFE2DA;
  border-color: #C9341C;
  box-shadow:
    0 0 0 2rpx rgba(201, 52, 28, 0.18),
    0 5rpx 12rpx rgba(201, 52, 28, 0.2);
}

.reservation-reminder-card.priority .reservation-room,
.reservation-reminder-card.priority .reservation-time,
.reservation-reminder-card.priority .reservation-people,
.reservation-reminder-card.priority .reservation-phone {
  color: #B3261E;
}

.reservation-room {
  color: #8F3E17;
  font-size: 10rpx;
  font-weight: 900;
}

.reservation-time,
.reservation-people,
.reservation-phone {
  color: rgba(58, 36, 24, 0.72);
  font-size: 9rpx;
  font-weight: 800;
}

.reservation-actions {
  flex: none;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
}

.reservation-action {
  height: 20rpx;
  padding: 0 7rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: 8rpx;
  font-weight: 900;
  white-space: nowrap;
}

.reservation-action.arrived {
  color: #FFFFFF;
  background: #4B9D64;
}

.reservation-action.cancel {
  color: #8F3E17;
  background: rgba(143, 62, 23, 0.1);
  border: 1rpx solid rgba(143, 62, 23, 0.22);
}

.table-board {
  height: calc(100vh - 34rpx);
  padding: 14rpx 18rpx 8rpx;
  box-sizing: border-box;
}

.table-board-transfer {
  height: calc(100vh - 72rpx);
}

.table-board-reservation {
  height: calc(100vh - 80rpx);
  padding-top: 10rpx;
}

.table-section {
  margin-bottom: 8rpx;
}

.section-title {
  margin: 0 0 8rpx;
  color: rgba(58, 36, 24, 0.58);
  font-size: 15rpx;
  font-weight: 900;
  line-height: 1;
}

.table-section-body {
  font-size: 0;
}

.table-card {
  position: relative;
  width: 11.55%;
  min-height: 76rpx;
  margin: 0 1.08% 10rpx 0;
  padding: 7rpx 9rpx 7rpx;
  display: inline-flex;
  flex-direction: column;
  vertical-align: top;
  border-radius: 10rpx;
  box-sizing: border-box;
  box-shadow:
    0 8rpx 18rpx rgba(58, 36, 24, 0.16),
    0 2rpx 4rpx rgba(58, 36, 24, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.42);
  border: 1rpx solid rgba(58, 36, 24, 0.13);
}

.merge-mark {
  position: absolute;
  top: -5rpx;
  right: -5rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fffaf1;
  background: #8A5526;
  border: 1rpx solid rgba(255, 250, 241, 0.9);
  box-shadow: 0 3rpx 8rpx rgba(58, 36, 24, 0.22);
  font-size: 10rpx;
  font-weight: 900;
  line-height: 1;
  z-index: 2;
  box-sizing: border-box;
}

.table-card:nth-child(8n) {
  margin-right: 0;
}

.table-card-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 4rpx;
}

.table-name {
  display: flex;
  align-items: baseline;
  min-width: 0;
  flex-shrink: 0;
}

.table-number {
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1;
}

.table-unit {
  margin-left: 3rpx;
  color: rgba(58, 36, 24, 0.48);
  font-size: 10rpx;
  font-weight: 900;
  white-space: nowrap;
}

.compact-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4rpx;
  margin-top: 3rpx;
  font-size: 11rpx;
  line-height: 1.25;
}

.price-line {
  display: flex;
  align-items: baseline;
  justify-content: flex-start;
  gap: 2rpx;
  margin-top: 4rpx;
  min-width: 0;
}

.money-icon {
  color: #9A642A;
  font-size: 10rpx;
  font-weight: 800;
  white-space: nowrap;
}

.info-icon {
  position: relative;
  width: 10rpx;
  height: 10rpx;
  flex: 0 0 10rpx;
  color: rgba(58, 36, 24, 0.5);
  box-sizing: border-box;
}

.people-icon::before {
  position: absolute;
  top: 0;
  left: 3rpx;
  width: 4rpx;
  height: 4rpx;
  border-radius: 50%;
  background: currentColor;
  content: "";
}

.people-icon::after {
  position: absolute;
  right: 1rpx;
  bottom: 0;
  left: 1rpx;
  height: 5rpx;
  border-radius: 6rpx 6rpx 2rpx 2rpx;
  background: currentColor;
  content: "";
}

.time-icon {
  border: 1rpx solid currentColor;
  border-radius: 50%;
}

.time-icon::before {
  position: absolute;
  top: 2rpx;
  left: 4rpx;
  width: 1rpx;
  height: 4rpx;
  background: currentColor;
  border-radius: 999rpx;
  content: "";
}

.time-icon::after {
  position: absolute;
  top: 5rpx;
  left: 4rpx;
  width: 4rpx;
  height: 1rpx;
  background: currentColor;
  border-radius: 999rpx;
  content: "";
}

.line-value {
  flex: 1;
  min-width: 0;
  text-align: left;
  color: #2C1A12;
  font-size: 12rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-value {
  flex: none;
  color: #8F3E17;
  font-size: 14rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time-line .line-value {
  font-size: 10rpx;
  font-weight: 800;
}

.table-card.status-empty {
  background: #FFFFFF;
  color: #3A2418;
}

.table-card-merge-selected {
  box-shadow:
    0 0 0 3rpx rgba(245, 213, 139, 0.9),
    0 8rpx 18rpx rgba(58, 36, 24, 0.16),
    0 2rpx 4rpx rgba(58, 36, 24, 0.12);
  border-color: #B15B18;
}

.table-card-merge-source {
  box-shadow:
    0 0 0 3rpx rgba(44, 26, 18, 0.72),
    0 8rpx 18rpx rgba(58, 36, 24, 0.16),
    0 2rpx 4rpx rgba(58, 36, 24, 0.12);
}

.table-card-selected {
  box-shadow:
    0 12rpx 26rpx rgba(58, 36, 24, 0.3),
    0 4rpx 9rpx rgba(58, 36, 24, 0.2),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.42);
  border-color: rgba(58, 36, 24, 0.72);
}

.table-card.status-submitted {
  background: #F1C46B;
  color: #3A2418;
}

.table-card.status-preparing {
  background: #C85F1D;
  color: #FFF7EC;
}

.table-card.status-paid {
  background: #4B9D64;
  color: #FFF7EC;
}

.table-card.status-preparing .table-unit,
.table-card.status-preparing .money-icon,
.table-card.status-preparing .info-icon,
.table-card.status-preparing .line-value,
.table-card.status-preparing .price-value,
.table-card.status-paid .table-unit,
.table-card.status-paid .money-icon,
.table-card.status-paid .info-icon,
.table-card.status-paid .line-value,
.table-card.status-paid .price-value {
  color: rgba(255, 247, 236, 0.92);
}

.legend-footer {
  height: 34rpx;
  padding: 0 18rpx 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-sizing: border-box;
  background: #FFF7EC;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 5rpx;
  color: rgba(58, 36, 24, 0.52);
  font-size: 11rpx;
  font-weight: 800;
}

.legend-dot {
  width: 9rpx;
  height: 9rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(58, 36, 24, 0.12);
  box-sizing: border-box;
}

.legend-dot.status-empty {
  background: #FFFFFF;
}

.legend-dot.status-submitted {
  background: #F1C46B;
}

.legend-dot.status-preparing {
  background: #C85F1D;
}

.legend-dot.status-paid {
  background: #4B9D64;
}

.clear-table-btn {
  position: fixed;
  right: 18rpx;
  bottom: 6rpx;
  z-index: 20;
  min-width: 82rpx;
  height: 25rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  box-sizing: border-box;
  color: rgba(58, 36, 24, 0.52);
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(58, 36, 24, 0.12);
  box-shadow: 0 5rpx 12rpx rgba(58, 36, 24, 0.08);
  font-size: 10rpx;
  font-weight: 900;
}

.clear-table-btn.selected {
  color: #FFF7EC;
  background: #8F3E17;
  border-color: rgba(143, 62, 23, 0.78);
  box-shadow: 0 7rpx 16rpx rgba(143, 62, 23, 0.22);
}
